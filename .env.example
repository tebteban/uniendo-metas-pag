# Configuración de Entorno - Ejemplo
# Copia este archivo como .env y completa con tus valores reales

# Entorno de ejecución (development o production)
NODE_ENV=development

# Puerto del servidor
PORT=3000

# Base de datos PostgreSQL (para producción)
# Formato: postgresql://usuario:contraseña@host:puerto/nombre_base_datos
DATABASE_URL=postgresql://postgres:tu_contraseña@localhost:5432/uniendom

# Secreto para sesiones (cambia esto por algo único y seguro)
SESSION_SECRET=uniendo-metas-sde-secret-key-2026

# Credenciales de administrador inicial
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# Cloudinary (para almacenamiento de archivos en producción)
# Obtén estas credenciales en https://cloudinary.com (plan gratuito disponible)
CLOUDINARY_CLOUD_NAME=tu-cloud-name
CLOUDINARY_API_KEY=tu-api-key
CLOUDINARY_API_SECRET=tu-api-secret
