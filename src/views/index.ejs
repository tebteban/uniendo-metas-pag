            <script src="https://unpkg.com/aos@2.3.1/dist/aos.js"></script>
            <script>
            AOS.init({ once: true, offset: 60, duration: 700, easing: 'ease-out-quart' });

            document.addEventListener('DOMContentLoaded', () => {
                const counters = document.querySelectorAll('.counter-animate');
                if (!counters.length) return;
                const animateCounters = () => {
                    counters.forEach(counter => {
                        const target = +counter.getAttribute('data-target');
                        const increment = target / 60;
                        let current = 0;
                        const tick = () => {
                            current = Math.min(current + increment, target);
                            counter.textContent = Math.ceil(current);
                            if (current < target) requestAnimationFrame(tick);
                        };
                        tick();
                    });
                };
                const observer = new IntersectionObserver(entries => {
                    if (entries[0].isIntersecting) { animateCounters(); observer.disconnect(); }
                }, { threshold: 0.4 });
                observer.observe(counters[0].closest('div'));
            });

            const countdownEl = document.getElementById('countdown-container');
            if (countdownEl) {
                const dateStr = countdownEl.getAttribute('data-date');
                if (dateStr) {
                    const eventDate = new Date(eventDateStr.replace(' ', 'T')).getTime();
                    const update = () => {
                        const diff = eventDate - Date.now();
                        if (diff < 0) { ['cd-months','cd-days','cd-hours'].forEach(id => { const el = document.getElementById(id); if (el) el.textContent = '00'; }); return; }
                        const days = Math.floor(diff / 86400000);
                        const hours = Math.floor((diff % 86400000) / 3600000);
                        const months = Math.floor(days / 30);
                        const remDays = days % 30;
                        const fmt = n => String(n).padStart(2, '0');
                        const mEl = document.getElementById('cd-months');
                        const dEl = document.getElementById('cd-days');
                        const hEl = document.getElementById('cd-hours');
                        if (mEl) mEl.textContent = fmt(months);
                        if (dEl) dEl.textContent = fmt(remDays);
                        if (hEl) hEl.textContent = fmt(hours);
                    };
                    setInterval(update, 1000);
                    update();
                }
            }

            function toggleFaq(id) {
                const content = document.getElementById(id);
                const icon = document.getElementById('icon-' + id);
                if (!content) return;
                const isHidden = content.classList.contains('hidden');
                document.querySelectorAll('[id^="faq"]').forEach(el => { if (el.tagName !== 'SECTION') el.classList.add('hidden'); });
                document.querySelectorAll('[id^="icon-faq"]').forEach(el => { el.classList.remove('rotate-180'); });
                if (isHidden) { content.classList.remove('hidden'); icon.classList.add('rotate-180'); }
            }
            </script>

