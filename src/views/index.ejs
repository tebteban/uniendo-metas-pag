<!DOCTYPE html>
<html lang="es" class="scroll-smooth">
<%- include('./partials/head') %>

    <body class="bg-gray-50 text-gray-600 antialiased overflow-x-hidden font-sans">

        <%- include('./partials/navbar') %>

            <!-- MEGA HERO UNIFICADO -->
            <section
                class="relative min-h-[95vh] lg:min-h-[110vh] bg-white overflow-hidden flex flex-col justify-center pt-32 pb-16 lg:pt-40 lg:pb-24">

                <!-- Fondo Animado -->
                <div class="absolute inset-0 overflow-hidden pointer-events-none">
                    <div
                        class="absolute top-0 left-1/4 w-96 h-96 bg-blue-100 rounded-full mix-blend-multiply filter blur-3xl opacity-60 animate-blob">
                    </div>
                    <div
                        class="absolute top-0 right-1/4 w-96 h-96 bg-red-100 rounded-full mix-blend-multiply filter blur-3xl opacity-60 animate-blob animation-delay-2000">
                    </div>
                    <div
                        class="absolute bottom-32 left-1/3 w-96 h-96 bg-yellow-100 rounded-full mix-blend-multiply filter blur-3xl opacity-60 animate-blob animation-delay-4000">
                    </div>
                    <div class="absolute inset-0 bg-[url('https://grainy-gradients.vercel.app/noise.svg')] opacity-20">
                    </div>
                </div>

                <div
                    class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 w-full flex flex-col justify-between h-full">

                    <!-- BLOQUE SUPERIOR: Hero Text -->
                    <div class="max-w-4xl mx-auto text-center mb-12 lg:mb-24" data-aos="fade-up">

                        <div
                            class="inline-flex items-center gap-2 px-3 sm:px-4 py-1.5 rounded-full bg-white/80 backdrop-blur-sm border border-gray-200 shadow-sm hover:shadow-md transition cursor-default mb-6">
                            <span class="relative flex h-2.5 w-2.5">
                                <span
                                    class="animate-ping absolute inline-flex h-full w-full rounded-full bg-brand-red opacity-75"></span>
                                <span class="relative inline-flex rounded-full h-2.5 w-2.5 bg-brand-red"></span>
                            </span>
                            <span
                                class="text-[10px] sm:text-xs md:text-sm font-bold tracking-widest text-gray-500 uppercase">
                                <%= settings.hero_badge || 'XI Edición • Santiago Del Estero' %>
                            </span>
                        </div>

                        <h1
                            class="text-[2.75rem] leading-[1.05] sm:text-6xl md:text-7xl lg:text-8xl xl:text-9xl font-black tracking-tight text-brand-dark mb-6 sm:mb-8">
                            <%- settings.text_home_hero_title || 'JÓVENES PARA <br>' %>
                                <span
                                    class="relative inline-block text-transparent bg-clip-text bg-gradient-to-r from-brand-red via-brand-orange to-brand-yellow pb-2">
                                    <%- settings.text_home_hero_highlight || 'EL FUTURO' %>
                                        <svg class="absolute w-full h-3 sm:h-4 -bottom-0.5 left-0 text-brand-yellow opacity-60"
                                            viewBox="0 0 200 9" fill="none">
                                            <path
                                                d="M2.00025 6.99997C2.00025 6.99997 64.9197 -3.53509 101.956 2.39999C138.992 8.33508 198.001 2.99997 198.001 2.99997"
                                                stroke="currentColor" stroke-width="3" stroke-linecap="round" />
                                        </svg>
                                </span>
                        </h1>

                        <p
                            class="text-base sm:text-lg md:text-xl lg:text-2xl text-gray-500 max-w-2xl mx-auto font-medium leading-relaxed mb-8 sm:mb-10">
                            <%= settings.hero_subtitle
                                || '"Tu voz tiene poder. Úsala para debatir, proponer y construir el futuro."' %>
                        </p>

                        <div class="flex flex-col sm:flex-row justify-center gap-3 sm:gap-4">
                            <a href="/organos"
                                class="px-7 sm:px-10 py-3.5 sm:py-4 bg-brand-red rounded-full text-white font-bold text-base sm:text-lg shadow-xl shadow-red-200 hover:bg-brand-orange hover:scale-105 transition-all duration-300">
                                Ver Órganos
                            </a>
                            <a href="/cronograma"
                                class="px-7 sm:px-10 py-3.5 sm:py-4 bg-white text-gray-700 border border-gray-200 rounded-full font-bold text-base sm:text-lg shadow-md hover:bg-gray-50 hover:border-gray-300 transition-all duration-300">
                                Ver Cronograma
                            </a>
                        </div>
                    </div>

                    <!-- BLOQUE MEDIO: Estadísticas Flotantes (Glassmorphism) -->
                    <div data-aos="fade-up" data-aos-delay="300" class="mb-16">
                        <div
                            class="bg-white/70 backdrop-blur-xl border border-white/60 rounded-[2.5rem] p-8 md:p-10 shadow-[0_20px_40px_-15px_rgba(0,0,0,0.05)] mx-auto max-w-5xl relative overflow-hidden group hover:shadow-[0_25px_50px_-12px_rgba(0,0,0,0.1)] transition-shadow duration-500">
                            <div
                                class="absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-brand-red via-brand-yellow to-brand-green/50">
                            </div>

                            <div class="grid grid-cols-2 md:grid-cols-4 gap-8 md:gap-12 text-center">
                                <div class="flex flex-col">
                                    <h3 class="text-4xl md:text-5xl font-black text-gray-800 mb-1">
                                        <span class="counter-animate" data-target="10">0</span>
                                    </h3>
                                    <p class="text-[10px] md:text-xs font-bold uppercase tracking-widest text-gray-400">
                                        Ediciones</p>
                                </div>
                                <div class="flex flex-col">
                                    <h3 class="text-4xl md:text-5xl font-black text-brand-green mb-1">
                                        +<span class="counter-animate" data-target="550">0</span>
                                    </h3>
                                    <p class="text-[10px] md:text-xs font-bold uppercase tracking-widest text-gray-400">
                                        Alumnos</p>
                                </div>
                                <div class="flex flex-col">
                                    <h3 class="text-4xl md:text-5xl font-black text-brand-blue mb-1">
                                        +<span class="counter-animate" data-target="20">0</span>
                                    </h3>
                                    <p class="text-[10px] md:text-xs font-bold uppercase tracking-widest text-gray-400">
                                        Escuelas</p>
                                </div>
                                <div class="flex flex-col">
                                    <h3 class="text-4xl md:text-5xl font-black text-brand-red mb-1">
                                        +<span class="counter-animate" data-target="40">0</span>
                                    </h3>
                                    <p class="text-[10px] md:text-xs font-bold uppercase tracking-widest text-gray-400">
                                        Voluntarios</p>
                                </div>
                            </div>
                        </div>
                    </div>

                </div>
            </section>

            <!-- SPONSORS — fuera del hero para que el bg-white llegue de borde a borde -->
            <section class="pt-12 pb-8 bg-white border-t border-gray-100">
                <div class="max-w-7xl mx-auto px-4 text-center">

                    <h2 class="text-base font-bold text-gray-400 uppercase tracking-[0.2em] mb-8">
                        Nos Acompañan
                    </h2>

                    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 items-center justify-items-center max-w-5xl mx-auto opacity-80">

                        <a href="https://sde.gob.ar/" target="_blank" rel="noopener noreferrer" class="group transition">
                            <img src="/img/logos/gobierno.png" alt="Gobierno de Santiago"
                                 class="w-40 md:w-56 object-contain grayscale group-hover:grayscale-0 transform group-hover:scale-110 transition duration-300">
                        </a>

                        <a href="https://www.facebook.com/cyt.nodotecnologico/?locale=es_LA" target="_blank" rel="noopener noreferrer" class="group transition">
                            <img src="/img/logos/logo-secretaria.png" alt="Secretaría de CyT"
                                 class="h-20 md:h-28 object-contain grayscale group-hover:grayscale-0 transform group-hover:scale-110 transition duration-300">
                        </a>

                        <a href="https://conciencia.org/" target="_blank" rel="noopener noreferrer" class="group transition">
                            <img src="/img/logos/logo-ccc.png" alt="Asociación Conciencia"
                                 class="h-20 md:h-28 object-contain grayscale group-hover:grayscale-0 transform group-hover:scale-110 transition duration-300">
                        </a>
                    </div>
                </div>
            </section>

            <section class="py-16 bg-gray-50 relative overflow-hidden border-b border-gray-200">

                <div class="max-w-7xl mx-auto px-4 relative z-10">
                    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">

                        <div class="flex flex-col justify-center text-center lg:text-left">
                            <h3 class="text-sm font-bold text-brand-red uppercase tracking-widest mb-3 animate-pulse">
                                Próximamente...
                            </h3>

                            <h2 class="text-4xl md:text-5xl font-black text-brand-dark mb-4 leading-tight">
                                El Modelo 2026 <br> <span
                                    class="text-transparent bg-clip-text bg-gradient-to-r from-brand-blue to-brand-green">se
                                    acerca</span>
                            </h2>

                            <p class="text-gray-500 mb-8 text-lg">
                                Las negociaciones están cerradas. El protocolo está activado. La fecha clave será
                                desclasificada muy pronto. <br>
                                <span class="font-bold text-brand-blue">¿Estás listo para cuando se revele?</span>
                            </p>

                            <% if (settings.mostrar_fecha_modelo==='true' ) { %>
                                <div class="flex flex-wrap justify-center lg:justify-start gap-4"
                                    id="countdown-container" data-date="<%= settings.proxima_edicion_fecha || '' %>">
                                    <div
                                        class="flex flex-col items-center bg-white rounded-2xl p-4 w-24 shadow-md border border-gray-100 transform hover:-translate-y-1 transition duration-300">
                                        <span class="text-4xl font-black text-gray-300" id="cd-months">??</span>
                                        <span
                                            class="text-[10px] uppercase tracking-widest text-gray-400 font-bold mt-1">Meses</span>
                                    </div>
                                    <div
                                        class="flex flex-col items-center bg-white rounded-2xl p-4 w-24 shadow-md border border-gray-100 transform hover:-translate-y-1 transition duration-300">
                                        <span class="text-4xl font-black text-gray-300" id="cd-days">??</span>
                                        <span
                                            class="text-[10px] uppercase tracking-widest text-gray-400 font-bold mt-1">Días</span>
                                    </div>
                                    <div
                                        class="flex flex-col items-center bg-white rounded-2xl p-4 w-24 shadow-md border border-gray-100 transform hover:-translate-y-1 transition duration-300">
                                        <span class="text-4xl font-black text-gray-300" id="cd-hours">??</span>
                                        <span
                                            class="text-[10px] uppercase tracking-widest text-gray-400 font-bold mt-1">Horas</span>
                                    </div>
                                </div>
                                <% } else { %>
                                    <div
                                        class="bg-brand-blue/5 rounded-2xl p-6 border border-brand-blue/10 inline-block text-left">
                                        <p class="text-brand-dark font-bold text-lg mb-1">📅 Fecha a Confirmar</p>
                                        <p class="text-sm text-gray-500">Estamos ultimando detalles logísticos.</p>
                                    </div>
                                    <% } %>

                                        <p class="mt-4 text-xs text-gray-400 font-medium uppercase tracking-wide">
                                            Atentos a las redes de Prensa
                                        </p>
                        </div>

                        <div class="relative group cursor-pointer h-full min-h-[300px]"
                            onclick="window.open('<%= settings.link_fotos || '#' %>', '_blank')">

                            <div
                                class="absolute -inset-0.5 bg-gradient-to-r from-brand-red to-brand-yellow rounded-3xl opacity-30 group-hover:opacity-100 transition duration-500 blur-sm">
                            </div>

                            <div
                                class="relative bg-white rounded-3xl p-10 flex flex-col items-center justify-center text-center h-full shadow-sm hover:shadow-lg transition duration-300">

                                <div
                                    class="w-20 h-20 bg-blue-50 rounded-full flex items-center justify-center text-brand-blue mb-6 group-hover:scale-110 transition duration-300">
                                    <svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                            d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                                    </svg>
                                </div>

                                <h3 class="text-3xl md:text-4xl font-black text-gray-800 italic uppercase mb-3">
                                    Galería de Fotos
                                </h3>

                                <p class="text-gray-500 text-base font-medium mb-8 max-w-xs mx-auto">
                                    ¿Estuviste ahí? Encontrate en la galería oficial del 2025.
                                </p>

                                <span
                                    class="inline-flex items-center gap-2 font-bold text-sm bg-brand-dark text-white px-8 py-3 rounded-full group-hover:bg-brand-red transition duration-300 shadow-lg">
                                    Ver en OneDrive
                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                            d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                                    </svg>
                                </span>
                            </div>
                        </div>

                    </div>
                </div>
            </section>

            <section id="nosotros" class="py-24 bg-white relative">

                <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

                    <div class="text-center max-w-3xl mx-auto mb-16" data-aos="fade-up">
                        <span class="text-brand-blue font-black tracking-[0.2em] uppercase text-[11px]">
                            <%= settings.text_home_about_badge || 'Institucional' %>
                        </span>
                        <h2 class="text-3xl md:text-5xl font-black text-gray-900 mt-3 mb-6 leading-tight">
                            <%= settings.text_home_about_title || '¿Qué es Uniendo Metas?' %>
                        </h2>
                        <p class="text-lg text-gray-500 leading-relaxed">
                            <%= settings.text_home_about_desc || 'Uniendo Metas es la simulación de Naciones Unidas más importante de Argentina. Un programa de Asociación Conciencia que, desde 1994, empodera a los jóvenes a través del diálogo y el consenso.' %>
                        </p>
                    </div>

                    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-20">

                        <div class="group relative bg-white border border-gray-100 rounded-2xl p-8 hover:border-brand-blue hover:shadow-xl transition-all duration-300 overflow-hidden" data-aos="fade-up" data-aos-delay="0">
                            <div class="absolute inset-0 bg-gradient-to-br from-blue-50 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 pointer-events-none"></div>
                            <div class="relative z-10">
                                <div class="w-12 h-12 bg-blue-50 rounded-xl flex items-center justify-center text-brand-blue mb-6 group-hover:scale-110 group-hover:bg-brand-blue group-hover:text-white transition-all duration-300">
                                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                                    </svg>
                                </div>
                                <h3 class="text-xl font-bold text-gray-900 mb-3"><%= settings.text_home_card1_title || 'Metodología Harvard' %></h3>
                                <p class="text-sm text-gray-500 leading-relaxed"><%= settings.text_home_card1_desc || 'Traída de la Universidad de Harvard en 1994. Los tópicos de debate se basan en la Agenda real de las Naciones Unidas, abordando problemáticas globales con seriedad académica.' %></p>
                            </div>
                        </div>

                        <div class="group relative bg-white border border-gray-100 rounded-2xl p-8 hover:border-brand-red hover:shadow-xl transition-all duration-300 overflow-hidden" data-aos="fade-up" data-aos-delay="100">
                            <div class="absolute inset-0 bg-gradient-to-br from-red-50 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 pointer-events-none"></div>
                            <div class="relative z-10">
                                <div class="w-12 h-12 bg-red-50 rounded-xl flex items-center justify-center text-brand-red mb-6 group-hover:scale-110 group-hover:bg-brand-red group-hover:text-white transition-all duration-300">
                                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"/>
                                    </svg>
                                </div>
                                <h3 class="text-xl font-bold text-gray-900 mb-3"><%= settings.text_home_card2_title || 'Red de Voluntarios' %></h3>
                                <p class="text-sm text-gray-500 leading-relaxed"><%= settings.text_home_card2_desc || 'Más de 900 voluntarios en todo el país. Jóvenes ex-participantes comprometidos con la participación ciudadana que organizan cada detalle del encuentro.' %></p>
                            </div>
                        </div>

                        <div class="group relative bg-white border border-gray-100 rounded-2xl p-8 hover:border-brand-green hover:shadow-xl transition-all duration-300 overflow-hidden" data-aos="fade-up" data-aos-delay="200">
                            <div class="absolute inset-0 bg-gradient-to-br from-green-50 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 pointer-events-none"></div>
                            <div class="relative z-10">
                                <div class="w-12 h-12 bg-green-50 rounded-xl flex items-center justify-center text-brand-green mb-6 group-hover:scale-110 group-hover:bg-brand-green group-hover:text-white transition-all duration-300">
                                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/>
                                    </svg>
                                </div>
                                <h3 class="text-xl font-bold text-gray-900 mb-3"><%= settings.text_home_card3_title || 'Acompañamiento Docente' %></h3>
                                <p class="text-sm text-gray-500 leading-relaxed"><%= settings.text_home_card3_desc || 'Consideramos a los docentes piezas clave. Ellos guían el proceso pedagógico para garantizar que el aprendizaje sea la meta central de la experiencia.' %></p>
                            </div>
                        </div>
                    </div>

                    <div class="border-t border-b border-gray-100 py-10 mb-20" data-aos="fade-up">
                        <p class="text-center text-[10px] font-black uppercase tracking-[0.25em] text-gray-400 mb-8">Nuestros Objetivos Educativos</p>
                        <div class="flex flex-wrap justify-center gap-3">
                            <span class="inline-flex items-center gap-2.5 px-5 py-3 rounded-full bg-blue-50 text-brand-blue font-bold text-sm border border-blue-100 hover:bg-brand-blue hover:text-white hover:border-brand-blue transition-all duration-200 cursor-default">
                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11a7 7 0 01-7 7m0 0a7 7 0 01-7-7m7 7v4m0 0H8m4 0h4m-4-8a3 3 0 01-3-3V5a3 3 0 116 0v6a3 3 0 01-3 3z"/></svg>
                                Oratoria y Comunicación
                            </span>
                            <span class="inline-flex items-center gap-2.5 px-5 py-3 rounded-full bg-red-50 text-brand-red font-bold text-sm border border-red-100 hover:bg-brand-red hover:text-white hover:border-brand-red transition-all duration-200 cursor-default">
                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/></svg>
                                Pensamiento Crítico
                            </span>
                            <span class="inline-flex items-center gap-2.5 px-5 py-3 rounded-full bg-yellow-50 text-yellow-600 font-bold text-sm border border-yellow-100 hover:bg-yellow-400 hover:text-white hover:border-yellow-400 transition-all duration-200 cursor-default">
                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"/></svg>
                                Trabajo Colaborativo
                            </span>
                            <span class="inline-flex items-center gap-2.5 px-5 py-3 rounded-full bg-green-50 text-brand-green font-bold text-sm border border-green-100 hover:bg-brand-green hover:text-white hover:border-brand-green transition-all duration-200 cursor-default">
                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                                Visión Global
                            </span>
                            <span class="inline-flex items-center gap-2.5 px-5 py-3 rounded-full bg-purple-50 text-purple-600 font-bold text-sm border border-purple-100 hover:bg-purple-500 hover:text-white hover:border-purple-500 transition-all duration-200 cursor-default">
                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z"/></svg>
                                Liderazgo
                            </span>
                            <span class="inline-flex items-center gap-2.5 px-5 py-3 rounded-full bg-orange-50 text-brand-orange font-bold text-sm border border-orange-100 hover:bg-brand-orange hover:text-white hover:border-brand-orange transition-all duration-200 cursor-default">
