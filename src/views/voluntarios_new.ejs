<!DOCTYPE html>
<html lang="es" class="scroll-smooth">
<%- include('./partials/head') %>

<style>
    @keyframes scroll {
        0%   { transform: translateX(0); }
        100% { transform: translateX(-50%); }
    }
    .animate-scroll {
        animation: scroll 45s linear infinite;
    }
    .animate-scroll:hover {
        animation-play-state: paused;
    }
    #lightbox { transition: opacity 0.3s ease; }
    #lightbox.hidden { opacity: 0; pointer-events: none; }
    #lightbox:not(.hidden) { opacity: 1; pointer-events: auto; }
</style>



<body class="bg-white text-gray-600 antialiased font-sans" style="overflow-x: hidden;">

<%- include('./partials/navbar') %>

<!-- ===== HERO ===== -->
<section class="relative pt-36 pb-20 bg-white overflow-hidden">
    <div class="absolute top-0 right-0 w-[600px] h-[600px] rounded-full pointer-events-none" style="background: radial-gradient(circle, #61B4E410 0%, transparent 70%); transform: translate(30%, -30%);"></div>
    <div class="absolute bottom-0 left-0 w-[500px] h-[500px] rounded-full pointer-events-none" style="background: radial-gradient(circle, #A0214008 0%, transparent 70%); transform: translate(-30%, 30%);"></div>
    <div class="absolute inset-0 opacity-[0.025] pointer-events-none" style="background-image: linear-gradient(#000 1px, transparent 1px), linear-gradient(90deg, #000 1px, transparent 1px); background-size: 60px 60px;"></div>

    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10 text-center">

        <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-white border border-gray-200 shadow-sm mb-8 cursor-default hover:shadow-md transition-all" data-aos="fade-down">
            <span class="flex h-2 w-2 relative">
                <span class="animate-ping absolute inline-flex h-full w-full rounded-full opacity-75" style="background:#73A950;"></span>
                <span class="relative inline-flex rounded-full h-2 w-2" style="background:#73A950;"></span>
            </span>
            <span class="text-xs font-black tracking-widest text-gray-500 uppercase">
                <%= settings.text_vol_hero_badge || 'Equipo de Voluntarios 2026' %>
            </span>
        </div>

        <h1 class="text-5xl md:text-6xl lg:text-7xl font-black text-gray-900 mb-6 tracking-tight leading-[1.05]" data-aos="fade-up">
            El equipo detrás<br>
            <span class="text-transparent bg-clip-text bg-gradient-to-r from-brand-blue to-brand-red">
                de la experiencia.
            </span>
        </h1>

        <p class="text-lg md:text-xl text-gray-500 max-w-2xl mx-auto leading-relaxed mb-10 font-medium" data-aos="fade-up" data-aos-delay="100">
            <%= settings.text_vol_hero_desc || 'Un grupo humano comprometido con la educación y el liderazgo joven. Cada voluntario aporta su tiempo y pasión para construir Uniendo Metas Santiago.' %>
        </p>

        <div data-aos="fade-up" data-aos-delay="200">
            <a href="<%= settings.link_voluntarios_sumate || 'https://instagram.com/umsantiagodelestero' %>" target="_blank"
               class="inline-flex items-center gap-2.5 px-9 py-4 text-white font-bold rounded-full hover:-translate-y-1 hover:brightness-110 transition-all duration-300 text-base"
               style="background:#A02140; box-shadow: 0 12px 30px -6px #A0214050;">
                Sumate al equipo
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/>
                </svg>
            </a>
        </div>
    </div>
</section>

<!-- ===== POR QUÉ SUMARTE ===== -->
<section class="py-20 bg-gray-50 border-t border-gray-100">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">

            <div data-aos="fade-right">
                <span class="inline-block text-xs font-black uppercase tracking-widest mb-5 px-3 py-1.5 rounded-full" style="background:#EDF5E8; color:#73A950;">Por qué sumarte</span>
                <h2 class="text-3xl md:text-4xl font-black text-gray-900 mb-6 leading-tight">
                    <%- settings.text_vol_why_title || '¿Por qué unirte a<br>nuestra familia?' %>
                </h2>
                <p class="text-gray-500 text-lg leading-relaxed mb-8">
                    <%= settings.text_vol_why_desc || 'Ser voluntario no es solo trabajar; es crecer. Es el lugar donde desarrollás habilidades que no se aprenden en un aula: liderazgo bajo presión, empatía, logística y trabajo en equipo real.' %>
                </p>

                <%
                const benColors = ['#73A950','#61B4E4','#A02140'];
                const benBgs    = ['#EDF5E8','#E8F5FB','#F9E8EC'];
                const benIconPaths = {
                    mic:      'M19 11a7 7 0 01-7 7m0 0a7 7 0 01-7-7m7 7v4m0 0H8m4 0h4m-4-8a3 3 0 01-3-3V5a3 3 0 116 0v6a3 3 0 01-3 3z',
                    lightbulb:'M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z',
                    users:    'M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z',
                    globe:    'M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z',
                    star:     'M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z',
                    heart:    'M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z',
                    academic: 'M12 14l9-5-9-5-9 5 9 5z M12 14l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0112 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14z',
                    chart:    'M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z',
                    shield:   'M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z',
                    chat:     'M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z',
                    pencil:   'M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z',
                    flag:     'M3 21v-4m0 0V5a2 2 0 012-2h6.5l1 1H21l-3 6 3 6h-8.5l-1-1H5a2 2 0 00-2 2zm9-13.5V9',
                };
                const benIconDefaults = ['users','academic','shield'];
                const benDefs = [
                    'Hacés amigos para toda la vida.',
                    'Impactás en la educación de cientos de jóvenes.',
                    'Certificado oficial de Asociación Conciencia.',
                ];
                const benKeys = ['vol_benefit_1','vol_benefit_2','vol_benefit_3'];
                %>
                <div class="space-y-4">
                    <% benKeys.forEach((key, i) => {
                        const text     = settings[key] || benDefs[i];
                        const iconKey  = settings[key + '_icon'] || benIconDefaults[i];
                        const iconPath = benIconPaths[iconKey] || benIconPaths['star'];
                        if (!text) return;
                    %>
                    <div class="flex items-center gap-4 p-4 bg-white rounded-2xl border border-gray-100 shadow-sm hover:shadow-md transition-all duration-200 group">
                        <div class="w-10 h-10 rounded-xl flex items-center justify-center flex-shrink-0 group-hover:scale-110 transition-transform" style="background:<%= benBgs[i] %>;">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" style="color:<%= benColors[i] %>;">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="<%= iconPath %>"/>
                            </svg>
                        </div>
                        <span class="text-gray-700 font-semibold text-base"><%= text %></span>
                    </div>
                    <% }); %>
                </div>
            </div>

            <!-- Fotos -->
            <div class="grid grid-cols-2 gap-4" data-aos="fade-left">
                <div class="overflow-hidden rounded-2xl shadow-md mt-8">
                    <img src="<%= settings.vol_hero_1 || '/img/Voluntarios/foto_vol_1.jpg' %>"
                         onerror="this.src='https://images.unsplash.com/photo-1529156069898-49953e39b3ac?auto=format&fit=crop&q=80'"
                         class="w-full h-64 object-cover hover:scale-105 transition-transform duration-500 cursor-zoom-in"
                         onclick="openDirectLightbox(this.src)"
                         alt="Voluntarios">
                </div>
                <div class="overflow-hidden rounded-2xl shadow-md">
                    <img src="<%= settings.vol_hero_2 || '/img/Voluntarios/foto_vol_2.jpg' %>"
                         onerror="this.src='https://images.unsplash.com/photo-1511632765486-a01980e01a18?auto=format&fit=crop&q=80'"
                         class="w-full h-64 object-cover hover:scale-105 transition-transform duration-500 cursor-zoom-in"
                         onclick="openDirectLightbox(this.src)"
                         alt="Staff">
                </div>
            </div>
        </div>
    </div>
</section>

<!-- ===== EQUIPO ===== -->
<section class="py-24 bg-white border-t border-gray-100">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

        <div class="text-center mb-16" data-aos="fade-up">
            <span class="text-xs font-black uppercase tracking-widest text-gray-400 mb-3 block">Estructura 2026</span>
            <h2 class="text-4xl md:text-5xl font-black text-gray-900">Nuestro Equipo</h2>
        </div>

        <%
        let groupList = [];
        if (typeof team !== 'undefined' && team && team.length > 0) {
            let unique = {};
            for (let i = 0; i < team.length; i++) { unique[team[i].group] = true; }
            let keys = Object.keys(unique);
            let manualOrder = ['Coordinación General','Consejo de Seguridad','Asamblea General','Sala de Tratados Internacionales','Sala de Tratados','Tratados','Consejo Económico y Social','ECOSOC','Consejo de Derechos Humanos','Derechos Humanos','CDH','Logística','Capacitación'];
            let prensaGroups = keys.filter(k => k.toLowerCase().includes('prensa') || k.toLowerCase().includes('comunicación'));
            for (let i = 0; i < manualOrder.length; i++) { if (unique[manualOrder[i]]) { groupList.push(manualOrder[i]); unique[manualOrder[i]] = false; } }
            for (let i = 0; i < keys.length; i++) { if (unique[keys[i]] && !prensaGroups.includes(keys[i])) { groupList.push(keys[i]); unique[keys[i]] = false; } }
            prensaGroups.forEach(pg => { if (unique[pg] !== false) groupList.push(pg); });
        }
        %>

        <% for (let g = 0; g < groupList.length; g++) {
            let gName = groupList[g];
            let members = [];
            for (let m = 0; m < team.length; m++) { if (team[m].group === gName) members.push(team[m]); }
            if (members.length === 0) continue;

            let displayName = gName === 'Sala de Tratados' ? 'Sala de Tratados Internacionales' : gName;
            let lowerName = gName.toLowerCase();

            let accentColor = '#8A8A8D';
            let accentBg    = '#F3F3F4';

            if      (lowerName.includes('asamblea'))    { accentColor = '#73A950'; accentBg = '#EDF5E8'; }
            else if (lowerName.includes('económico') || lowerName.includes('ecosoc')) { accentColor = '#E15829'; accentBg = '#FCEEE9'; }
            else if (lowerName.includes('seguridad'))   { accentColor = '#A02140'; accentBg = '#F9E8EC'; }
            else if (lowerName.includes('tratado'))     { accentColor = '#FFB819'; accentBg = '#FEF6E0'; }
            else if (lowerName.includes('derechos') || lowerName.includes('cdh')) { accentColor = '#61B4E4'; accentBg = '#E8F5FB'; }
            else if (lowerName.includes('prensa') || lowerName.includes('comunicación')) { accentColor = '#C026D3'; accentBg = '#FDF4FF'; }
            else if (lowerName.includes('coordinación')) { accentColor = '#1E293B'; accentBg = '#F1F5F9'; }
        %>

        <div class="mb-20" data-aos="fade-up">
            <!-- Header del grupo -->
            <div class="flex items-center gap-4 mb-10">
                <div class="w-1 h-8 rounded-full flex-shrink-0" style="background:<%= accentColor %>;"></div>
                <h3 class="text-2xl font-black" style="color:<%= accentColor %>;"><%= displayName %></h3>
                <div class="flex-1 h-px" style="background:<%= accentColor %>20;"></div>
                <span class="text-xs font-black uppercase tracking-widest px-3 py-1.5 rounded-full" style="background:<%= accentBg %>; color:<%= accentColor %>;"><%= members.length %> miembros</span>
            </div>

            <!-- Cards del grupo -->
            <div class="flex flex-wrap justify-center gap-6 md:gap-8">
                <% for (let k = 0; k < members.length; k++) {
                    let mem = members[k];
                %>
                <div class="flex flex-col items-center text-center group w-36 md:w-40">
                    <!-- Foto -->
                    <div class="w-28 h-28 md:w-32 md:h-32 rounded-full overflow-hidden shadow-sm border border-gray-100 mb-3 relative group-hover:shadow-lg transition-all duration-300">
                        <img src="/img/Voluntarios/<%= mem.image %>"
                             onerror="this.src='https://ui-avatars.com/api/?name=<%= encodeURIComponent(mem.name) %>&background=f8fafc&color=64748b&size=300&bold=true'"
                             class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110"
                             alt="<%= mem.name %>">
                        <!-- Overlay de color al hover -->
                        <div class="absolute inset-0 opacity-0 group-hover:opacity-10 transition-opacity duration-300 rounded-2xl" style="background:<%= accentColor %>;"></div>
                    </div>
                    <!-- Nombre -->
                    <h4 class="font-bold text-gray-900 text-sm leading-tight mb-2"><%= mem.name %></h4>
                    <!-- Rol -->
                    <span class="inline-block text-[10px] font-black uppercase tracking-wider px-3 py-1 rounded-full" style="background:<%= accentBg %>; color:<%= accentColor %>;">
                        <%= mem.role %>
                    </span>
                </div>
                <% } %>
            </div>
        </div>

        <% } %>

        <% if (!team || team.length === 0) { %>
        <div class="text-center py-20">
            <div class="w-16 h-16 bg-gray-50 rounded-2xl flex items-center justify-center mx-auto mb-4">
                <svg class="w-8 h-8 text-gray-200" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"/>
                </svg>
            </div>
            <p class="text-gray-400 font-bold text-base">El equipo se está conformando.</p>
            <p class="text-gray-300 text-sm mt-1">Volvé pronto para conocerlos.</p>
        </div>
        <% } %>

    </div>
</section>

<!-- ===== ADN VOLUNTARIO ===== -->
<section class="py-24 border-t border-gray-100" style="background:#F8FAFC;">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

        <div class="text-center mb-16" data-aos="fade-up">
            <span class="inline-block px-4 py-1.5 rounded-full text-xs font-black uppercase tracking-widest mb-5 border" style="background:#F9E8EC; color:#A02140; border-color:#A0214030;"><%= settings.text_vol_adn_badge || 'Radiografía 2025' %></span>
            <h2 class="text-4xl md:text-5xl font-black text-gray-900 tracking-tight"><%= settings.text_vol_adn_title || 'ADN Voluntario' %></h2>
            <p class="text-gray-500 mt-4 text-lg max-w-xl mx-auto font-medium"><%= settings.text_vol_adn_desc || 'Un análisis de quienes hacen posible Uniendo Metas.' %></p>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-12 gap-6">

            <!-- Efecto Semillero -->
            <div class="lg:col-span-8 bg-white rounded-3xl p-8 md:p-12 border border-gray-100 shadow-sm relative overflow-hidden" data-aos="fade-right">
                <div class="absolute top-0 right-0 w-80 h-80 rounded-full pointer-events-none" style="background: radial-gradient(circle, #61B4E410 0%, transparent 70%); transform: translate(30%, -30%);"></div>
                <div class="relative z-10 flex flex-col md:flex-row items-center gap-10">
                    <div class="flex-1 text-center md:text-left">
                        <span class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full text-xs font-black uppercase tracking-wider mb-6 border" style="background:#E8F5FB; color:#61B4E4; border-color:#61B4E430;">
                            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
                            Dato de Fidelidad
                        </span>
                        <h3 class="text-3xl md:text-4xl font-black text-gray-900 mb-4 leading-tight">
                            <%- settings.text_vol_semillero_title || 'El "Efecto <span class="text-transparent bg-clip-text bg-gradient-to-r from-brand-blue to-blue-600">Semillero"</span>' %>
                        </h3>
                        <p class="text-gray-500 text-lg leading-relaxed mb-8">
                            <%= settings.text_vol_semillero_desc || 'La experiencia es tan transformadora que los participantes deciden volver. 8 de cada 10 voluntarios comenzaron su camino como delegados.' %>
                        </p>
                        <div class="flex items-center justify-center md:justify-start gap-4">
                            <div class="flex -space-x-3">
                                <% for (let i = 0; i < 4; i++) { %>
                                <div class="w-10 h-10 rounded-full bg-gray-100 border-2 border-white flex items-center justify-center shadow-sm">
                                    <svg class="w-5 h-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
                                </div>
                                <% } %>
                                <div class="w-10 h-10 rounded-full border-2 border-white flex items-center justify-center text-xs font-black text-white shadow-md" style="background:#61B4E4;">+30</div>
                            </div>
                            <span class="text-sm font-bold text-gray-400 uppercase tracking-wide">Ex-participantes</span>
                        </div>
                    </div>
                    <div class="flex-shrink-0">
                        <div class="relative w-40 h-40">
                            <svg class="w-full h-full -rotate-90" viewBox="0 0 160 160">
                                <circle cx="80" cy="80" r="64" stroke="#F1F5F9" stroke-width="14" fill="none"/>
                                <%
                                const semPct = parseInt(settings.vol_semillero_pct) || 85;
                                const semOffset = Math.round(402 * (1 - semPct/100));
                                %>
                                <circle cx="80" cy="80" r="64" stroke="#61B4E4" stroke-width="14" fill="none" stroke-dasharray="402" stroke-dashoffset="<%= semOffset %>" stroke-linecap="round"/>
                            </svg>
                            <div class="absolute inset-0 flex flex-col items-center justify-center">
                                <span class="text-4xl font-black text-gray-900"><%= semPct %>%</span>
                                <span class="text-[10px] font-black uppercase tracking-widest text-gray-400 mt-1"><%= settings.vol_semillero_label || 'Retorno' %></span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Paridad + Multidisciplinario -->
            <div class="lg:col-span-4 space-y-5">
                <div class="bg-white rounded-3xl p-7 border border-gray-100 shadow-sm hover:-translate-y-1 transition-transform duration-300" data-aos="fade-left" data-aos-delay="100">
                    <div class="flex items-center gap-2 mb-6">
                        <div class="w-2 h-2 rounded-full" style="background:#A02140;"></div>
                        <h4 class="font-black text-gray-900 text-sm uppercase tracking-widest">Paridad de Género</h4>
                    </div>
                    <%
                    const pctF = parseInt(settings.vol_paridad_f) || 52;
                    const pctM = 100 - pctF;
                    %>
                    <div class="flex items-end justify-center gap-8 h-28">
                        <div class="flex flex-col items-center gap-2 w-20 h-full justify-end group cursor-default">
                            <span class="font-black text-2xl text-gray-300 group-hover:text-brand-red transition-colors"><%= pctF %>%</span>
                            <div class="w-full rounded-t-xl transition-all duration-500" style="height:<%= pctF %>%; background:#A0214020;" onmouseover="this.style.background='#A02140'" onmouseout="this.style.background='#A0214020'"></div>
                            <span class="text-[10px] font-black uppercase tracking-wider text-gray-400"><%= settings.vol_paridad_f_label || 'Mujeres' %></span>
                        </div>
                        <div class="flex flex-col items-center gap-2 w-20 h-full justify-end group cursor-default">
                            <span class="font-black text-2xl text-gray-300 group-hover:text-brand-blue transition-colors"><%= pctM %>%</span>
                            <div class="w-full rounded-t-xl transition-all duration-500" style="height:<%= pctM %>%; background:#61B4E420;" onmouseover="this.style.background='#61B4E4'" onmouseout="this.style.background='#61B4E420'"></div>
                            <span class="text-[10px] font-black uppercase tracking-wider text-gray-400"><%= settings.vol_paridad_m_label || 'Varones' %></span>
                        </div>
                    </div>
                </div>
                <div class="bg-white rounded-3xl p-7 border border-gray-100 shadow-sm hover:-translate-y-1 transition-transform duration-300" data-aos="fade-left" data-aos-delay="200">
                    <h4 class="font-black text-sm uppercase tracking-widest mb-2" style="color:#73A950;">Multidisciplinario</h4>
                    <p class="text-3xl font-black text-gray-900 leading-tight mb-4"><%= settings.vol_multi_count || '+8' %> Carreras<br><span class="text-gray-400">Universitarias</span></p>
                    <div class="flex flex-wrap gap-2">
                        <% (settings.vol_multi_carreras || 'Abogacía,Medicina,Ingeniería').split(',').filter(Boolean).forEach(c => { %>
                        <span class="px-3 py-1.5 bg-gray-50 rounded-xl text-xs font-bold text-gray-600 border border-gray-100"><%= c.trim() %></span>
                        <% }); %>
                        <% if (settings.vol_multi_extra) { %>
                        <span class="px-3 py-1.5 rounded-xl text-xs font-bold border" style="background:#EDF5E8; color:#73A950; border-color:#73A95030;"><%= settings.vol_multi_extra %></span>
                        <% } %>
                    </div>
                </div>
            </div>

            <!-- Habilidades -->
            <div class="lg:col-span-12 bg-white rounded-3xl p-8 md:p-12 border border-gray-100 shadow-sm" data-aos="fade-up">
                <div class="flex flex-col md:flex-row gap-12 items-start">
                    <div class="md:w-1/3 flex-shrink-0">
                        <div class="w-14 h-14 rounded-2xl flex items-center justify-center mb-6" style="background:#FCEEE9;">
                            <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24" style="color:#E15829;">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>
                            </svg>
                        </div>
                        <h3 class="text-3xl font-black text-gray-900 mb-4 leading-tight">Potenciador de Habilidades</h3>
                        <p class="text-gray-500 leading-relaxed font-medium">Lo que los voluntarios afirman haber aprendido y reforzado durante su experiencia en el modelo.</p>
                    </div>
                    <div class="md:w-2/3 w-full grid grid-cols-1 sm:grid-cols-2 gap-x-12 gap-y-8">
                        <%
                        const habColors = ['#73A950','#61B4E4','#A02140','#E15829'];
                        const habDefs = [
                            { lKey: 'vol_hab_1_label', pKey: 'vol_hab_1_pct', defL: 'Trabajo en Equipo', defP: 83 },
                            { lKey: 'vol_hab_2_label', pKey: 'vol_hab_2_pct', defL: 'Oratoria',          defP: 78 },
                            { lKey: 'vol_hab_3_label', pKey: 'vol_hab_3_pct', defL: 'Confianza',         defP: 66 },
                            { lKey: 'vol_hab_4_label', pKey: 'vol_hab_4_pct', defL: 'Liderazgo',         defP: 51 },
                        ];
                        habDefs.forEach((h, i) => {
                            const label = settings[h.lKey] || h.defL;
                            const pct   = parseInt(settings[h.pKey]) || h.defP;
                            const color = habColors[i];
                        %>
                        <div class="space-y-2.5">
                            <div class="flex justify-between items-center">
                                <span class="font-bold text-gray-700 text-sm uppercase tracking-wide"><%= label %></span>
                                <span class="font-black text-sm" style="color:<%= color %>;"><%= pct %>%</span>
                            </div>
                            <div class="h-2 w-full bg-gray-100 rounded-full overflow-hidden">
                                <div class="h-full rounded-full" style="width:<%= pct %>%; background:<%= color %>;" data-aos="slide-right"></div>
                            </div>
                        </div>
                        <% }); %>
                    </div>
                </div>
            </div>

        </div>
    </div>
</section>

<!-- ===== VOCES DEL EQUIPO ===== -->
<section class="py-24 bg-white border-t border-gray-100">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">

        <div class="text-center mb-16" data-aos="fade-up">
            <span class="inline-block px-4 py-1.5 rounded-full text-xs font-black uppercase tracking-widest mb-5 border" style="background:#EDF5E8; color:#73A950; border-color:#73A95030;"><%= settings.text_vol_test_badge || 'Voces del equipo' %></span>
            <h2 class="text-4xl md:text-5xl font-black text-gray-900 tracking-tight"><%= settings.text_vol_test_title || 'Lo que dejó el modelo' %></h2>
            <p class="text-gray-500 mt-4 text-lg max-w-xl mx-auto font-medium"><%= settings.text_vol_test_desc || 'Palabras reales de quienes vivieron la experiencia desde adentro.' %></p>
        </div>

        <%
        const testColors = ['#A02140','#61B4E4','#73A950'];
        const testBgs    = ['#F9E8EC','#E8F5FB','#EDF5E8'];
        const testDefs = [
            { fKey:'vol_test_1_frase', nKey:'vol_test_1_nombre', rKey:'vol_test_1_rol',
              defF:'El modelo me enseñó que podés organizar algo enorme con puro compromiso y sin cobrar un peso.',
              defN:'Valentina R.', defR:'Ex Presidenta de Sala · 3 ediciones' },
            { fKey:'vol_test_2_frase', nKey:'vol_test_2_nombre', rKey:'vol_test_2_rol',
              defF:'Vine a ayudar y terminé siendo ayudado. Las habilidades que desarrollé en UM las uso todos los días.',
              defN:'Matías G.', defR:'Ex Secretario General · 2 ediciones' },
            { fKey:'vol_test_3_frase', nKey:'vol_test_3_nombre', rKey:'vol_test_3_rol',
              defF:'Entré sin saber nada de ONU y salí con amigos para toda la vida.',
              defN:'Rocío T.', defR:'Ex Coordinadora de Logística · 4 ediciones' },
        ];
        %>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6" data-aos="fade-up">
            <% testDefs.forEach((t, i) => {
                const frase  = settings[t.fKey]  || t.defF;
                const nombre = settings[t.nKey]  || t.defN;
                const rol    = settings[t.rKey]  || t.defR;
                const color  = testColors[i];
                const bg     = testBgs[i];
            %>
            <div class="bg-white rounded-2xl p-7 border border-gray-100 shadow-sm hover:shadow-xl hover:-translate-y-1 transition-all duration-300 flex flex-col" data-aos="fade-up" data-aos-delay="<%= i * 80 %>">
                <div class="text-6xl font-black leading-none mb-2 select-none" style="color:<%= color %>; opacity:0.15;">"</div>
                <p class="text-gray-600 text-base leading-relaxed font-medium flex-1 mb-6"><%= frase %></p>
                <div class="flex items-center gap-3 pt-5 border-t border-gray-50">
                    <div class="w-10 h-10 rounded-full flex items-center justify-center flex-shrink-0 font-black text-base" style="background:<%= bg %>; color:<%= color %>;">
                        <%= nombre.charAt(0) %>
                    </div>
                    <div>
                        <p class="text-sm font-black text-gray-900"><%= nombre %></p>
                        <p class="text-xs text-gray-400 font-medium"><%= rol %></p>
                    </div>
                </div>
            </div>
            <% }); %>
        </div>
    </div>
</section>

<!-- ===== GALERÍA CARRUSEL ===== -->
<section class="py-24 bg-white border-t border-gray-100">

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mb-14 text-center" data-aos="fade-up">
        <span class="text-xs font-black uppercase tracking-widest text-gray-400 mb-3 block"><%= settings.text_vol_galeria_badge || 'Momentos' %></span>
        <h3 class="text-3xl md:text-4xl font-black text-gray-900"><%= settings.text_vol_galeria_title || 'Galería de Voluntariado' %></h3>
        <p class="text-gray-500 mt-3 text-lg"><%= settings.text_vol_galeria_desc || 'Momentos inolvidables de nuestro equipo.' %></p>
    </div>

    <%
        const volSliderKeys = Object.keys(settings).filter(k => k.startsWith('vol_slider_') && settings[k]).sort();
        const volFallback = [
            'https://images.unsplash.com/photo-1529156069898-49953e39b3ac?auto=format&fit=crop&q=80',
            'https://images.unsplash.com/photo-1511632765486-a01980e01a18?auto=format&fit=crop&q=80',
            'https://images.unsplash.com/photo-1577962917302-cd874c4e3169?auto=format&fit=crop&q=80'
        ];
        const volImages = volSliderKeys.length > 0 ? volSliderKeys.map(k => settings[k]) : volFallback;
    %>

    <div class="relative w-full overflow-hidden">
        <!-- Fades laterales -->
        <div class="absolute left-0 top-0 bottom-0 w-24 z-10 pointer-events-none" style="background: linear-gradient(to right, white, transparent);"></div>
        <div class="absolute right-0 top-0 bottom-0 w-24 z-10 pointer-events-none" style="background: linear-gradient(to left, white, transparent);"></div>

        <div style="display:flex; width:100%; overflow:hidden; padding: 8px 0;">
            <div class="flex animate-scroll gap-5" id="vol-gallery-container" style="will-change: transform;">
                <% for (let i = 0; i < 2; i++) { %>
                    <% for (const imgSrc of volImages) { %>
                    <div class="flex-shrink-0 overflow-hidden rounded-2xl shadow-sm relative group cursor-zoom-in" style="min-width:256px;"
                         onclick="openVolLightbox('<%= imgSrc %>', event)">
                        <img src="<%= imgSrc %>"
                             onerror="this.src='https://images.unsplash.com/photo-1523240795612-9a054b0db644?w=400&h=400&fit=crop'"
                             class="w-64 h-64 object-cover hover:scale-105 transition-transform duration-500"
                             alt="Galería Voluntarios">

                    </div>
                    <% } %>
                <% } %>
            </div>
        </div>
    </div>
</section>

<%- include('./partials/footer') %>

<!-- Lightbox -->
<!-- Lightbox con flechas — igual al de autoridades -->
<div id="lightbox" class="fixed inset-0 z-[200] bg-black/90 hidden flex items-center justify-center p-4 backdrop-blur-sm" onclick="closeLightbox()">
    <button class="absolute top-5 right-5 text-white/70 hover:text-white p-2 rounded-full hover:bg-white/10 transition z-50" onclick="closeLightbox()">
        <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
    </button>
    <button id="lightbox-prev" class="absolute left-2 md:left-4 text-white/70 hover:text-white p-2 md:p-3 rounded-full bg-black/20 hover:bg-white/20 transition z-50 flex items-center justify-center">
        <svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
    </button>
    <img id="lightbox-img" src="" class="max-w-full max-h-[90vh] rounded-xl shadow-2xl transform transition-transform duration-300 scale-95" alt="Full screen">
    <button id="lightbox-next" class="absolute right-2 md:right-4 text-white/70 hover:text-white p-2 md:p-3 rounded-full bg-black/20 hover:bg-white/20 transition z-50 flex items-center justify-center">
        <svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
    </button>
</div>

<script src="https://unpkg.com/aos@2.3.1/dist/aos.js"></script>
<script>
    AOS.init({ once: true, offset: 50, duration: 700, easing: 'ease-out-quart' });

    const lightbox    = document.getElementById('lightbox');
    const lightboxImg = document.getElementById('lightbox-img');

    // Tomamos solo la primera mitad del carrusel (está duplicado para el loop infinito)
    const allCarouselImgs = Array.from(document.querySelectorAll('#vol-gallery-container img'));
    const uniqueVolImgs   = allCarouselImgs.slice(0, Math.ceil(allCarouselImgs.length / 2));
    let currentVolIdx = 0;

    function openVolLightbox(src, e) {
        if (e) e.stopPropagation();
        const idx = uniqueVolImgs.findIndex(img => img.src === src || img.getAttribute('src') === src);
        currentVolIdx = idx >= 0 ? idx : 0;
        lightboxImg.src = uniqueVolImgs[currentVolIdx].src;
        lightbox.classList.remove('hidden');
        document.body.style.overflow = 'hidden';
        setTimeout(() => lightboxImg.classList.replace('scale-95', 'scale-100'), 10);
    }

    function openLightbox(src) { openVolLightbox(src, null); }

    function closeLightbox() {
        lightboxImg.classList.replace('scale-100', 'scale-95');
        // Restaurar flechas para el carrusel
        document.getElementById('lightbox-prev').style.display = '';
        document.getElementById('lightbox-next').style.display = '';
        setTimeout(() => { lightbox.classList.add('hidden'); document.body.style.overflow = 'auto'; }, 200);
    }

    function nextVolImage(e) {
        if (e) e.stopPropagation();
        currentVolIdx = (currentVolIdx + 1) % uniqueVolImgs.length;
        lightboxImg.src = uniqueVolImgs[currentVolIdx].src;
    }

    function prevVolImage(e) {
        if (e) e.stopPropagation();
        currentVolIdx = (currentVolIdx - 1 + uniqueVolImgs.length) % uniqueVolImgs.length;
        lightboxImg.src = uniqueVolImgs[currentVolIdx].src;
    }

    function openDirectLightbox(src) {
        lightboxImg.src = src;
        lightbox.classList.remove('hidden');
        document.body.style.overflow = 'hidden';
        // Ocultar flechas — esta foto no es del carrusel
        document.getElementById('lightbox-prev').style.display = 'none';
        document.getElementById('lightbox-next').style.display = 'none';
        setTimeout(() => lightboxImg.classList.replace('scale-95', 'scale-100'), 10);
    }

    document.getElementById('lightbox-next')?.addEventListener('click', nextVolImage);
    document.getElementById('lightbox-prev')?.addEventListener('click', prevVolImage);
    document.addEventListener('keydown', e => {
        if (!lightbox.classList.contains('hidden')) {
            if (e.key === 'Escape')     closeLightbox();
            if (e.key === 'ArrowRight') nextVolImage();
            if (e.key === 'ArrowLeft')  prevVolImage();
        }
    });
</script>

</body>
</html>
