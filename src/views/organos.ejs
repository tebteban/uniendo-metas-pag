<!DOCTYPE html>
<html lang="es" class="scroll-smooth">
<%- include('./partials/head') %>

<body class="bg-gray-50 text-gray-600 antialiased overflow-x-hidden font-sans">

    <%- include('./partials/navbar') %>

    <section class="relative pt-32 pb-12 bg-white overflow-hidden">
        <div class="absolute inset-0 overflow-hidden pointer-events-none">
            <div class="absolute top-0 right-1/4 w-96 h-96 bg-red-50 rounded-full mix-blend-multiply filter blur-3xl opacity-70"></div>
            <div class="absolute bottom-0 left-1/4 w-96 h-96 bg-blue-50 rounded-full mix-blend-multiply filter blur-3xl opacity-70"></div>
        </div>

        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10 text-center">
            <h1 class="text-4xl md:text-6xl font-black text-gray-900 mb-4">
                Órganos y <span class="text-transparent bg-clip-text bg-gradient-to-r from-brand-red to-brand-orange">Tópicos</span>
            </h1>
            <p class="text-xl text-gray-500 max-w-2xl mx-auto font-medium">
                Conocé los espacios de debate y descargá el material de preparación.
            </p>
        </div>
    </section>

    <section class="py-12 bg-gray-50 relative min-h-screen">
        <div class="absolute inset-0 bg-[radial-gradient(#e5e7eb_1px,transparent_1px)] [background-size:16px_16px] opacity-50 pointer-events-none"></div>

        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">

            <div class="flex flex-wrap justify-center gap-8">
                
                <% if (organos && organos.length > 0) { %>
                    <% organos.forEach(organ => { %>
                        <div class="w-full md:w-[calc(50%-1rem)] lg:w-[calc(33.333%-1.5rem)] group relative bg-white rounded-[2.5rem] p-8 shadow-xl shadow-gray-200/50 hover:shadow-2xl transition-all duration-500 hover:-translate-y-2 border border-gray-100 overflow-hidden flex flex-col"
                             style="--organ-color: <%= organ.color %>;">

                            <div class="absolute -top-20 -right-20 w-60 h-60 rounded-full mix-blend-multiply filter blur-3xl opacity-0 group-hover:opacity-10 transition-opacity duration-700"
                                 style="background-color: var(--organ-color);"></div>

                            <div class="mb-6 relative z-10">
                                <div class="w-16 h-16 rounded-2xl text-white flex items-center justify-center text-3xl font-black shadow-lg transform group-hover:scale-110 group-hover:rotate-3 transition-all duration-500 mb-6"
                                     style="background-color: var(--organ-color); box-shadow: 0 10px 15px -3px var(--organ-color);">
                                    <%= organ.name.charAt(0) %>
                                </div>

                                <h3 class="text-3xl font-black text-gray-900 mb-3 leading-tight transition-colors group-hover:text-[var(--organ-color)]">
                                    <%= organ.name %>
                                </h3>

                                <p class="text-sm md:text-base text-gray-600 mb-6 leading-relaxed">
                                    <%- organ.description %>
                                </p>
                            </div>

                            <div class="mt-auto relative z-10">
                                <div class="bg-gray-50 border-l-4 p-4 rounded-r-xl mb-6 bg-opacity-10"
                                     style="border-color: var(--organ-color); background-color: var(--organ-color);">
                                    <span class="text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1 block">Tópico</span>
                                    <p class="text-gray-900 font-bold text-sm leading-snug">
                                        <%= organ.topic || 'A definir' %>
                                    </p>
                                </div>

                                <div class="flex flex-col gap-3">
                                    <% 
                                        // Helper para forzar descarga en Cloudinary (fl_attachment)
                                        const getDownloadUrl = (url) => {
                                            if (!url) return '#';
                                            if (url.includes('cloudinary.com') && url.includes('/upload/')) {
                                                // Insertar fl_attachment justo después de /upload/
                                                return url.replace('/upload/', '/upload/fl_attachment/');
                                            }
                                            return url;
                                        };
                                    %>
                                    
                                                                <% if (organ.link_reglamento) { 
                                // Limpiar URL de Cloudinary - remover fl_attachment y cambiar resource_type
                                let reglamentoUrl = organ.link_reglamento;
                                if (reglamentoUrl.includes('cloudinary.com')) {
                                    // Remover /fl_attachment/ (puede estar en cualquier posición)
                                    reglamentoUrl = reglamentoUrl.replace(/\/fl_attachment\/?/g, '');
                                    // Cambiar /raw/ por /image/ para forzar acceso público
                                    reglamentoUrl = reglamentoUrl.replace('/raw/', '/image/');
                                }
                            %>
                                <a href="<%= reglamentoUrl %>" 
                                   target="_blank"
                                   download
                                   class="inline-flex items-center gap-2 px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition-colors">
                                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                                    </svg>
                                    Descargar Reglamento
                                </a>
                            <% } %>

                                    <% if (organ.link_dinamicas) { %>
                                        <a href="<%= getDownloadUrl(organ.link_dinamicas) %>" download class="inline-flex items-center justify-between w-full px-6 py-3 bg-white border-2 rounded-2xl font-bold text-sm hover:text-white transition-all duration-300 group/btn"
                                           style="border-color: var(--organ-color); color: var(--organ-color);"
                                           onmouseover="this.style.backgroundColor='<%= organ.color %>'; this.style.color='white'"
                                           onmouseout="this.style.backgroundColor='white'; this.style.color='<%= organ.color %>'">
                                            <span>Ver Dinámicas</span>
                                            <svg class="w-5 h-5 transform group-hover/btn:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" /></svg>
                                        </a>
                                    <% } %>

                                                                <% if (organ.link_topico) { 
                                let topicoUrl = organ.link_topico;
                                if (topicoUrl.includes('cloudinary.com')) {
                                    topicoUrl = topicoUrl.replace(/\/fl_attachment\/?/g, '');
                                    topicoUrl = topicoUrl.replace('/raw/', '/image/');
                                }
                            %>
                                <a href="<%= topicoUrl %>" 
                                   target="_blank"
                                   download
                                   class="inline-flex items-center gap-2 px-4 py-2 bg-purple-600 text-white rounded-lg hover:bg-purple-700 transition-colors">
                                    <svg class="w-5 h-5" fill="none" stroke="currentGraph" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                                    </svg>
                                    Descargar Tópico
                                </a>
                            <% } %>
                                </div>
                            </div>
                        </div>
                    <% }); %>
                <% } else { %>
                    <div class="w-full text-center py-20">
                        <p class="text-gray-400 text-lg">Próximamente se publicarán los órganos.</p>
                    </div>
                <% } %>
            </div>
        </div>
    </section>

    <%- include('./partials/footer') %>

</body>
</html>