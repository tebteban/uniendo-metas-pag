<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
    <style>body { font-family: 'Montserrat', sans-serif; }</style>
</head>

<body class="bg-slate-50">
    <%- include('../partials/navbar') %>

    <div class="pt-20 flex min-h-screen">
        <%- include('../partials/sidebar') %>

        <main class="flex-1 md:ml-64 p-8">
            <div class="max-w-2xl mx-auto">
                <div class="flex items-center gap-4 mb-8">
                    <a href="/admin/organos" class="text-gray-400 hover:text-slate-700 transition">
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" /></svg>
                    </a>
                    <h2 class="text-3xl font-black text-slate-800">Editar Órgano</h2>
                </div>

                <div class="bg-white p-8 rounded-2xl shadow-sm border border-gray-200">
                    <form action="/admin/organos/update/<%= organ.id %>" method="POST" class="space-y-6" enctype="multipart/form-data">

                        <div class="grid grid-cols-3 gap-6">
                            <div class="col-span-2">
                                <label for="name" class="block text-sm font-bold text-gray-700 mb-2">Nombre del Órgano</label>
                                <input type="text" id="name" name="name" value="<%= organ.name %>" required class="w-full px-4 py-3 rounded-xl border border-gray-300 focus:outline-none focus:border-blue-500 focus:ring-2 focus:ring-blue-100 transition-all">
                            </div>
                            <div>
                                <label class="block text-sm font-bold text-gray-700 mb-2">Color del Órgano</label>
                                <div class="flex flex-wrap gap-4 mt-2">
                                    <label class="cursor-pointer group relative">
                                        <input type="radio" name="color" value="#A02140" required <%=organ.color.toUpperCase()==='#A02140' ? 'checked' : '' %> class="peer sr-only">
                                        <div class="w-10 h-10 rounded-full border-2 border-transparent peer-checked:ring-4 peer-checked:ring-offset-2 peer-checked:ring-[#A02140] hover:scale-110 transition-all shadow-sm" style="background-color: #A02140;"></div>
                                        <span class="absolute -bottom-6 left-1/2 -translate-x-1/2 text-[10px] font-bold text-gray-500 opacity-0 group-hover:opacity-100 transition-opacity">Rojo</span>
                                    </label>
                                    <label class="cursor-pointer group relative">
                                        <input type="radio" name="color" value="#73A950" <%=organ.color.toUpperCase()==='#73A950' ? 'checked' : '' %> class="peer sr-only">
                                        <div class="w-10 h-10 rounded-full border-2 border-transparent peer-checked:ring-4 peer-checked:ring-offset-2 peer-checked:ring-[#73A950] hover:scale-110 transition-all shadow-sm" style="background-color: #73A950;"></div>
                                        <span class="absolute -bottom-6 left-1/2 -translate-x-1/2 text-[10px] font-bold text-gray-500 opacity-0 group-hover:opacity-100 transition-opacity">Verde</span>
                                    </label>
                                    <label class="cursor-pointer group relative">
                                        <input type="radio" name="color" value="#E15829" <%=organ.color.toUpperCase()==='#E15829' ? 'checked' : '' %> class="peer sr-only">
                                        <div class="w-10 h-10 rounded-full border-2 border-transparent peer-checked:ring-4 peer-checked:ring-offset-2 peer-checked:ring-[#E15829] hover:scale-110 transition-all shadow-sm" style="background-color: #E15829;"></div>
                                        <span class="absolute -bottom-6 left-1/2 -translate-x-1/2 text-[10px] font-bold text-gray-500 opacity-0 group-hover:opacity-100 transition-opacity">Naranja</span>
                                    </label>
                                    <label class="cursor-pointer group relative">
                                        <input type="radio" name="color" value="#FFB819" <%=organ.color.toUpperCase()==='#FFB819' ? 'checked' : '' %> class="peer sr-only">
                                        <div class="w-10 h-10 rounded-full border-2 border-transparent peer-checked:ring-4 peer-checked:ring-offset-2 peer-checked:ring-[#FFB819] hover:scale-110 transition-all shadow-sm" style="background-color: #FFB819;"></div>
                                        <span class="absolute -bottom-6 left-1/2 -translate-x-1/2 text-[10px] font-bold text-gray-500 opacity-0 group-hover:opacity-100 transition-opacity">Amarillo</span>
                                    </label>
                                    <label class="cursor-pointer group relative">
                                        <input type="radio" name="color" value="#61B4E4" <%=organ.color.toUpperCase()==='#61B4E4' ? 'checked' : '' %> class="peer sr-only">
                                        <div class="w-10 h-10 rounded-full border-2 border-transparent peer-checked:ring-4 peer-checked:ring-offset-2 peer-checked:ring-[#61B4E4] hover:scale-110 transition-all shadow-sm" style="background-color: #61B4E4;"></div>
                                        <span class="absolute -bottom-6 left-1/2 -translate-x-1/2 text-[10px] font-bold text-gray-500 opacity-0 group-hover:opacity-100 transition-opacity">Azul</span>
                                    </label>
                                </div>
                            </div>
                        </div>

                        <div>
                            <label for="topic" class="block text-sm font-bold text-gray-700 mb-2">Tópico</label>
                            <input type="text" id="topic" name="topic" value="<%= organ.topic %>" class="w-full px-4 py-3 rounded-xl border border-gray-300 focus:outline-none focus:border-blue-500 focus:ring-2 focus:ring-blue-100 transition-all">
                        </div>

                        <div>
                            <label for="description" class="block text-sm font-bold text-gray-700 mb-2">Descripción</label>
                            <textarea id="description" name="description" rows="4" class="w-full px-4 py-3 rounded-xl border border-gray-300 focus:outline-none focus:border-blue-500 focus:ring-2 focus:ring-blue-100 transition-all"><%= organ.description %></textarea>
                        </div>

                        <div>
                            <label for="reglamento" class="block text-sm font-bold text-gray-700 mb-2">Archivo de Reglamento (PDF)</label>
                            <% if (organ.link_reglamento) { %>
                                <div class="mb-2 p-3 bg-blue-50 rounded-lg flex items-center justify-between text-sm">
                                    <div class="flex items-center gap-2 text-blue-700 truncate">
                                        <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" /></svg>
                                        <span class="truncate">Archivo actual: ...<%= organ.link_reglamento.split('/').pop() %></span>
                                    </div>
                                    <a href="<%= organ.link_reglamento %>" target="_blank" class="text-xs font-bold text-blue-600 hover:text-blue-800 underline">Ver</a>
                                </div>
                            <% } %>
                            <input type="file" id="reglamento" name="reglamento" accept=".pdf,.doc,.docx" class="w-full px-4 py-3 rounded-xl border border-gray-300 focus:outline-none focus:border-blue-500 focus:ring-2 focus:ring-blue-100 transition-all file:mr-4 file:py-2 file:px-4 file:rounded-full file:border-0 file:text-sm file:font-semibold file:bg-blue-50 file:text-blue-700 hover:file:bg-blue-100">
                            <p class="mt-1 text-xs text-gray-500">Deja este campo vacío si no quieres cambiar el archivo actual.</p>
                        </div>

                        <div>
                            <label for="archivo_dinamicas" class="block text-sm font-bold text-gray-700 mb-2">Archivo de Dinámicas</label>
                            <% if (organ.link_dinamicas) { %>
                                <div class="mb-2 p-3 bg-purple-50 rounded-lg flex items-center justify-between text-sm">
                                    <div class="flex items-center gap-2 text-purple-700 truncate">
                                        <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" /></svg>
                                        <span class="truncate">Dinámicas: ...<%= organ.link_dinamicas.split('/').pop() %></span>
                                    </div>
                                    <a href="<%= organ.link_dinamicas %>" target="_blank" class="text-xs font-bold text-purple-600 hover:text-purple-800 underline">Ver</a>
                                </div>
                            <% } %>
                            <input type="file" id="archivo_dinamicas" name="archivo_dinamicas" accept=".pdf,.doc,.docx" class="w-full px-4 py-3 rounded-xl border border-gray-300 focus:outline-none focus:border-blue-500 focus:ring-2 focus:ring-blue-100 transition-all file:mr-4 file:py-2 file:px-4 file:rounded-full file:border-0 file:text-sm file:font-semibold file:bg-blue-50 file:text-blue-700 hover:file:bg-blue-100">
                        </div>

                        <div>
                            <label for="archivo_topico" class="block text-sm font-bold text-gray-700 mb-2">Archivo de Tópico</label>
                            <% if (organ.link_topico) { %>
                                <div class="mb-2 p-3 bg-orange-50 rounded-lg flex items-center justify-between text-sm">
                                    <div class="flex items-center gap-2 text-orange-700 truncate">
                                        <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" /></svg>
                                        <span class="truncate">Tópico: ...<%= organ.link_topico.split('/').pop() %></span>
                                    </div>
                                    <a href="<%= organ.link_topico %>" target="_blank" class="text-xs font-bold text-orange-600 hover:text-orange-800 underline">Ver</a>
                                </div>
                            <% } %>
                            <input type="file" id="archivo_topico" name="archivo_topico" accept=".pdf,.doc,.docx" class="w-full px-4 py-3 rounded-xl border border-gray-300 focus:outline-none focus:border-blue-500 focus:ring-2 focus:ring-blue-100 transition-all file:mr-4 file:py-2 file:px-4 file:rounded-full file:border-0 file:text-sm file:font-semibold file:bg-blue-50 file:text-blue-700 hover:file:bg-blue-100">
                        </div>

                        <div class="pt-4 flex justify-end gap-4">
                            <a href="/admin/organos" class="px-6 py-3 rounded-xl text-gray-600 font-bold hover:bg-gray-100 transition">Cancelar</a>
                            <button type="submit" class="px-8 py-3 rounded-xl bg-blue-600 text-white font-bold hover:bg-blue-700 transition shadow-lg shadow-blue-200">Actualizar Órgano</button>
                        </div>

                    </form>
                </div>
            </div>
        </main>
    </div>
</body>
</html>