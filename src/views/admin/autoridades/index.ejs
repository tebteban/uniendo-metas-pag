<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> — Admin</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Montserrat', sans-serif; }
        input:focus, textarea:focus, select:focus {
            outline: none;
            border-color: #61B4E4;
            box-shadow: 0 0 0 3px rgba(97,180,228,0.15);
        }
    </style>
</head>
<body class="bg-slate-50">

<%- include('../partials/navbar') %>

<div class="pt-20 flex min-h-screen">
    <%- include('../partials/sidebar') %>

    <main class="flex-1 md:ml-64 p-8">
        <div class="max-w-6xl mx-auto">

            <!-- Flash messages -->
            <% const msg = typeof query !== 'undefined' ? query.msg : (locals.query ? locals.query.msg : null); %>
            <% const flashMsg = {
                created:   { type: 'success', icon: 'M5 13l4 4L19 7', text: '¡Miembro agregado correctamente!' },
                updated:   { type: 'success', icon: 'M5 13l4 4L19 7', text: 'Miembro actualizado correctamente.' },
                published: { type: 'success', icon: 'M5 13l4 4L19 7', text: '¡Equipo completo publicado! Ya es visible en la página pública.' },
                toggled:   { type: 'info',    icon: 'M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z', text: 'Estado del miembro actualizado.' },
            }[msg]; %>
            <% if (flashMsg) { %>
            <div id="flash-msg"
                 class="mb-6 flex items-center gap-3 px-5 py-4 rounded-2xl border <%= flashMsg.type === 'success' ? 'bg-emerald-50 border-emerald-100 text-emerald-800' : 'bg-blue-50 border-blue-100 text-blue-800' %>">
                <div class="w-8 h-8 rounded-xl <%= flashMsg.type === 'success' ? 'bg-emerald-100' : 'bg-blue-100' %> flex items-center justify-center flex-shrink-0">
                    <svg class="w-4 h-4 <%= flashMsg.type === 'success' ? 'text-emerald-600' : 'text-blue-600' %>" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="<%= flashMsg.icon %>"/>
                    </svg>
                </div>
                <p class="text-sm font-bold flex-1"><%= flashMsg.text %></p>
                <button onclick="document.getElementById('flash-msg').remove()" class="text-current opacity-40 hover:opacity-70 transition">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M6 18L18 6M6 6l12 12"/>
                    </svg>
                </button>
            </div>
            <script>setTimeout(() => { const f = document.getElementById('flash-msg'); if(f){ f.style.transition='opacity 0.4s'; f.style.opacity='0'; setTimeout(()=>f.remove(),400); } }, 4000);</script>
            <% } %>

            <!-- Header -->
            <div class="flex flex-col md:flex-row md:items-center justify-between gap-4 mb-8">
                <div>
                    <div class="flex items-center gap-3 mb-1">
                        <div class="w-8 h-8 rounded-lg bg-indigo-50 flex items-center justify-center">
                            <svg class="w-4 h-4 text-indigo-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/>
                            </svg>
                        </div>
                        <span class="text-xs font-black text-slate-400 uppercase tracking-widest">Gestión</span>
                    </div>
                    <h1 class="text-3xl font-black text-slate-900">Equipo de Organización</h1>
                    <p class="text-sm text-gray-400 mt-1">Gestioná los integrantes y fotos del equipo — <span class="font-bold text-slate-500"><%= authorities.length %> miembro<%= authorities.length !== 1 ? 's' : '' %></span></p>
                </div>
                <div class="flex flex-col items-end gap-2">
                    <div class="flex items-center gap-3">
                        <a href="/admin/equipodevoluntarios/crear"
                           class="bg-indigo-600 text-white font-bold px-5 py-2.5 rounded-xl hover:bg-indigo-700 transition shadow-lg shadow-indigo-200 flex items-center gap-2 text-sm">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 4v16m8-8H4"/>
                            </svg>
                            Nuevo Miembro
                        </a>
                        <form action="/admin/equipodevoluntarios/importar" method="POST" enctype="multipart/form-data">
                            <label for="excel-upload"
                                   class="cursor-pointer bg-emerald-600 text-white font-bold px-5 py-2.5 rounded-xl hover:bg-emerald-700 transition shadow-lg shadow-emerald-200 flex items-center gap-2 text-sm">
                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/>
                                </svg>
                                Importar Excel
                            </label>
                            <input id="excel-upload" type="file" name="file" accept=".xlsx,.xls" class="hidden" onchange="this.form.submit()">
                        </form>
                    </div>
                    <p class="text-xs text-gray-400">
                        Descargá el
                        <a href="/admin/ejemplos/equipo" class="text-emerald-600 font-bold hover:underline">formato de ejemplo</a>
                        antes de importar.
                    </p>
                </div>
            </div>

            <!-- Tabla -->
            <div class="bg-white rounded-2xl border border-gray-100 shadow-sm overflow-hidden">
                <% if (authorities.length === 0) { %>
                <div class="py-20 text-center">
                    <div class="w-16 h-16 bg-gray-100 rounded-2xl flex items-center justify-center mx-auto mb-4">
                        <svg class="w-8 h-8 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/>
                        </svg>
                    </div>
                    <p class="text-sm font-bold text-gray-400">No hay miembros registrados todavía.</p>
                    <a href="/admin/equipodevoluntarios/crear" class="mt-4 inline-block text-indigo-600 font-bold text-sm hover:underline">+ Agregar el primero</a>
                </div>
                <% } else { %>
                <div class="overflow-x-auto">
                    <table class="w-full text-left">
                        <thead>
                            <tr class="bg-gray-50 border-b border-gray-100 text-[11px] font-black text-gray-400 uppercase tracking-widest">
                                <th class="px-6 py-4">Orden / Perfil</th>
                                <th class="px-6 py-4">Área</th>
                                <th class="px-6 py-4">Rol</th>
                                <th class="px-6 py-4">Estado</th>
                                <th class="px-6 py-4 hidden lg:table-cell">Bio</th>
                                <th class="px-6 py-4 text-right">Acciones</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-gray-50">
                            <% let currentGroup = ''; authorities.forEach(auth => {
                                if (auth.group !== currentGroup) {
                                    currentGroup = auth.group; %>
                            <tr class="bg-slate-50/80">
                                <td colspan="6" class="px-6 py-2.5">
                                    <span class="text-[10px] font-black text-slate-400 uppercase tracking-widest"><%= currentGroup || 'General' %></span>
                                </td>
                            </tr>
                            <% } %>
                            <tr class="hover:bg-slate-50/50 transition-colors group">
                                <td class="px-6 py-4">
                                    <div class="flex items-center gap-4">
                                        <span class="text-xs font-black text-gray-300 w-5 text-center tabular-nums"><%= auth.order %></span>
                                        <div class="w-9 h-9 rounded-full bg-gray-100 overflow-hidden flex-shrink-0 border-2 border-white shadow-sm">
                                            <% if (auth.image) { %>
                                            <img src="/img/Voluntarios/<%= auth.image %>" class="w-full h-full object-cover">
                                            <% } else { %>
                                            <div class="w-full h-full flex items-center justify-center bg-indigo-50">
                                                <span class="text-xs font-black text-indigo-400"><%= auth.name.charAt(0) %></span>
                                            </div>
                                            <% } %>
                                        </div>
                                        <span class="font-bold text-sm text-slate-800"><%= auth.name %></span>
                                    </div>
                                </td>
                                <td class="px-6 py-4 text-sm text-gray-500 font-medium"><%= auth.group %></td>
                                <td class="px-6 py-4">
                                    <span class="bg-indigo-50 text-indigo-700 px-2.5 py-1 rounded-full text-[11px] font-bold whitespace-nowrap">
                                        <%= auth.role %>
                                    </span>
                                </td>
                                <td class="px-6 py-4">
                                    <form action="/admin/equipodevoluntarios/toggle/<%= auth.id %>" method="POST">
                                        <button type="submit"
                                                class="<%= auth.active ? 'bg-emerald-50 text-emerald-700 border-emerald-100' : 'bg-gray-100 text-gray-400 border-gray-200' %> px-2.5 py-1 rounded-full text-[11px] font-bold whitespace-nowrap hover:opacity-75 transition border">
                                            <%= auth.active ? '● Publicado' : '○ Oculto' %>
                                        </button>
                                    </form>
                                </td>
                                <td class="px-6 py-4 text-xs text-gray-400 max-w-xs truncate hidden lg:table-cell">
                                    <%= auth.description || '—' %>
                                </td>
                                <td class="px-6 py-4 text-right whitespace-nowrap">
                                    <a href="/admin/equipodevoluntarios/editar/<%= auth.id %>"
                                       class="text-indigo-600 hover:text-indigo-900 font-bold text-xs mr-3 transition">Editar</a>
                                    <a href="/admin/equipodevoluntarios/eliminar/<%= auth.id %>"
                                       onclick="return confirm('¿Eliminar a <%= auth.name %>?')"
                                       class="text-red-400 hover:text-red-600 font-bold text-xs transition">Eliminar</a>
                                </td>
                            </tr>
                            <% }); %>
                        </tbody>
                    </table>
                </div>
                <% } %>
            </div>

            <!-- Footer actions -->
            <div class="mt-6 flex justify-between items-center gap-4">
                <form action="/admin/equipodevoluntarios/vaciar" method="POST"
                      onsubmit="return confirm('⚠️ PELIGRO: ¿Estás seguro de que querés VACIAR toda la lista? Esta acción eliminará a TODOS los miembros y NO se puede deshacer.');">
                    <button type="submit"
                            class="bg-white text-red-500 font-bold px-5 py-2.5 rounded-xl hover:bg-red-50 transition border border-red-100 flex items-center gap-2 text-sm">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
                        </svg>
                        Vaciar Lista
                    </button>
                </form>
                <form action="/admin/equipodevoluntarios/publicar-todos" method="POST"
                      onsubmit="return confirm('¿Estás seguro? Esto hará visible a TODO el equipo en la página pública.');">
                    <button type="submit"
                            class="bg-emerald-600 text-white font-bold px-6 py-2.5 rounded-xl hover:bg-emerald-700 transition shadow-lg shadow-emerald-200 flex items-center gap-2 text-sm">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/>
                        </svg>
                        Publicar Equipo Completo
                    </button>
                </form>
            </div>

        </div>
    </main>
</div>

</body>
</html>
