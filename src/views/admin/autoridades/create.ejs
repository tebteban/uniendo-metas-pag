<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> — Admin</title>
    
    <!-- Favicon -->
    <link rel="icon" type="image/png" href="/img/descarga.png">
    <link rel="shortcut icon" type="image/png" href="/img/descarga.png">
    <link rel="apple-touch-icon" href="/img/descarga.png">

    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Montserrat', sans-serif; }
        input:focus, textarea:focus, select:focus {
            outline: none;
            border-color: #61B4E4;
            box-shadow: 0 0 0 3px rgba(97,180,228,0.15);
        }
        input[type="file"] { cursor: pointer; }
    </style>
</head>
<body class="bg-slate-50">

<%- include('../partials/navbar') %>

<div class="pt-20 flex min-h-screen">
    <%- include('../partials/sidebar') %>

    <main class="flex-1 md:ml-64 p-8">
        <div class="max-w-3xl mx-auto">

            <!-- Header -->
            <div class="flex items-center gap-4 mb-8">
                <a href="/admin/equipodevoluntarios"
                   class="w-9 h-9 rounded-xl bg-white border border-gray-200 flex items-center justify-center text-gray-400 hover:text-slate-700 hover:border-gray-300 transition shadow-sm">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/>
                    </svg>
                </a>
                <div>
                    <p class="text-xs font-black text-slate-400 uppercase tracking-widest mb-0.5">Equipo Staff</p>
                    <h1 class="text-2xl font-black text-slate-900">Nuevo Miembro</h1>
                </div>
            </div>

            <form action="/admin/equipodevoluntarios/store" method="POST" enctype="multipart/form-data" class="space-y-5">

                <!-- Datos Personales -->
                <div class="bg-white rounded-2xl border border-gray-100 shadow-sm overflow-hidden">
                    <div class="px-6 py-4 border-b border-gray-100 flex items-center gap-3">
                        <div class="w-7 h-7 rounded-lg bg-indigo-50 flex items-center justify-center">
                            <svg class="w-3.5 h-3.5 text-indigo-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
                            </svg>
                        </div>
                        <h2 class="text-sm font-black text-slate-700">Datos Personales</h2>
                    </div>
                    <div class="p-6 grid grid-cols-1 md:grid-cols-2 gap-5">
                        <div>
                            <label class="text-[11px] font-black text-slate-600 uppercase tracking-wider block mb-2">Nombre Completo *</label>
                            <input type="text" name="name" required
                                   class="w-full px-4 py-3 rounded-xl border border-gray-200 bg-gray-50 text-sm font-medium text-slate-700 transition-all">
                        </div>
                        <div>
                            <label class="text-[11px] font-black text-slate-600 uppercase tracking-wider block mb-2">Foto de Perfil</label>
                            <input type="file" name="image" accept="image/*"
                                   class="w-full text-sm text-gray-400 file:mr-3 file:py-2 file:px-4 file:rounded-lg file:border-0 file:text-xs file:font-bold file:bg-indigo-50 file:text-indigo-600 hover:file:bg-indigo-100 transition-all border border-gray-200 bg-gray-50 rounded-xl px-2 py-2">
                        </div>
                    </div>
                </div>

                <!-- Rol y Área -->
                <div class="bg-white rounded-2xl border border-gray-100 shadow-sm overflow-hidden">
                    <div class="px-6 py-4 border-b border-gray-100 flex items-center gap-3">
                        <div class="w-7 h-7 rounded-lg bg-blue-50 flex items-center justify-center">
                            <svg class="w-3.5 h-3.5 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5"/>
                            </svg>
                        </div>
                        <h2 class="text-sm font-black text-slate-700">Rol y Área</h2>
                    </div>
                    <div class="p-6 grid grid-cols-1 md:grid-cols-2 gap-5">
                        <div>
                            <label class="text-[11px] font-black text-slate-600 uppercase tracking-wider block mb-2">Área / Grupo *</label>
                            <select name="group"
                                    class="w-full px-4 py-3 rounded-xl border border-gray-200 bg-gray-50 text-sm font-medium text-slate-700 transition-all">
                                <option value="Coordinación General">Coordinación General</option>
                                <option value="Asamblea General">Asamblea General</option>
                                <option value="Consejo de Seguridad">Consejo de Seguridad</option>
                                <option value="ECOSOC">ECOSOC</option>
                                <option value="Sala de Tratados">Sala de Tratados</option>
                                <option value="Derechos Humanos">Derechos Humanos</option>
                                <option value="Prensa y Comunicación">Prensa y Comunicación</option>
                                <option value="Logística">Logística / Ujieres</option>
                                <option value="Capacitación">Capacitación</option>
                            </select>
                        </div>
                        <div>
                            <label class="text-[11px] font-black text-slate-600 uppercase tracking-wider block mb-2">Rol Específico *</label>
                            <input type="text" name="role" required placeholder="ej: Presidente, Secretario..."
                                   class="w-full px-4 py-3 rounded-xl border border-gray-200 bg-gray-50 text-sm font-medium text-slate-700 transition-all">
                        </div>
                    </div>
                </div>

                <!-- Extra -->
                <div class="bg-white rounded-2xl border border-gray-100 shadow-sm overflow-hidden">
                    <div class="px-6 py-4 border-b border-gray-100 flex items-center gap-3">
                        <div class="w-7 h-7 rounded-lg bg-amber-50 flex items-center justify-center">
                            <svg class="w-3.5 h-3.5 text-amber-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4"/>
                            </svg>
                        </div>
                        <h2 class="text-sm font-black text-slate-700">Opcionales</h2>
                    </div>
                    <div class="p-6 grid grid-cols-3 gap-5">
                        <div>
                            <label class="text-[11px] font-black text-slate-600 uppercase tracking-wider block mb-2">Orden</label>
                            <input type="number" name="order" value="0"
                                   class="w-full px-4 py-3 rounded-xl border border-gray-200 bg-gray-50 text-sm font-medium text-slate-700 transition-all">
                            <p class="text-[10px] text-gray-400 mt-1.5">Mayor número → aparece después</p>
                        </div>
                        <div class="col-span-2">
                            <label class="text-[11px] font-black text-slate-600 uppercase tracking-wider block mb-2">Bio Breve</label>
                            <textarea name="description" rows="2" placeholder="Una línea sobre el miembro..."
                                      class="w-full px-4 py-3 rounded-xl border border-gray-200 bg-gray-50 text-sm font-medium text-slate-700 resize-none transition-all"></textarea>
                        </div>
                    </div>
                </div>

                <!-- Botones -->
                <div class="flex justify-end gap-3 pt-2">
                    <a href="/admin/equipodevoluntarios"
                       class="px-6 py-3 rounded-xl text-gray-500 font-bold hover:bg-gray-100 transition text-sm">Cancelar</a>
                    <button type="submit"
                            class="px-8 py-3 rounded-xl bg-indigo-600 text-white font-bold hover:bg-indigo-700 transition shadow-lg shadow-indigo-200 text-sm">
                        Guardar Integrante
                    </button>
                </div>

            </form>
        </div>
    </main>
</div>

</body>
</html>
