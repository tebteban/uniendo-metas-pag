<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> — Admin</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Montserrat', sans-serif; }
        input:focus, select:focus, textarea:focus {
            outline: none;
            border-color: #61B4E4;
            box-shadow: 0 0 0 3px rgba(97,180,228,0.15);
        }
        .sortable { cursor: pointer; user-select: none; }
        .sortable:hover { color: #1e293b; }
        .sort-asc::after  { content: ' ↑'; }
        .sort-desc::after { content: ' ↓'; }
        #addPanel { transition: max-height 0.3s ease, opacity 0.25s ease; overflow: hidden; }
        #addPanel.closed { max-height: 0 !important; opacity: 0; }
    </style>
</head>
<body class="bg-slate-50">

<%- include('../partials/navbar') %>

<div class="pt-20 flex min-h-screen">
    <%- include('../partials/sidebar') %>

    <main class="flex-1 md:ml-64 p-8">
        <div class="max-w-7xl mx-auto space-y-6">

            <!-- ── Flash ── -->
            <% const flashMap = {
                created:  { type: 'success', icon: 'M5 13l4 4L19 7', text: '¡Inscripción agregada correctamente!' },
                edited:   { type: 'success', icon: 'M5 13l4 4L19 7', text: 'Inscripción actualizada correctamente.' },
                imported: { type: 'success', icon: 'M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12', text: '¡Lista importada correctamente desde Excel!' },
                cleared:  { type: 'warning', icon: 'M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16', text: 'Lista vaciada. Todos los registros fueron eliminados.' },
                error:    { type: 'error',   icon: 'M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z', text: 'No se pudo completar la acción. Verificá el archivo.' },
            }; %>
            <% const flashMsg = query && query.msg ? flashMap[query.msg] : null; %>
            <% if (flashMsg) { %>
            <div id="flash-msg" class="flex items-center gap-3 px-5 py-4 rounded-2xl border
                <%= flashMsg.type === 'success' ? 'bg-emerald-50 border-emerald-100 text-emerald-800' :
                    flashMsg.type === 'warning' ? 'bg-amber-50 border-amber-100 text-amber-800' :
                    'bg-red-50 border-red-100 text-red-800' %>">
                <div class="w-8 h-8 rounded-xl flex items-center justify-center flex-shrink-0
                    <%= flashMsg.type === 'success' ? 'bg-emerald-100' : flashMsg.type === 'warning' ? 'bg-amber-100' : 'bg-red-100' %>">
                    <svg class="w-4 h-4 <%= flashMsg.type === 'success' ? 'text-emerald-600' : flashMsg.type === 'warning' ? 'text-amber-600' : 'text-red-500' %>"
                         fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="<%= flashMsg.icon %>"/>
                    </svg>
                </div>
                <p class="text-sm font-bold flex-1"><%= flashMsg.text %></p>
                <button onclick="document.getElementById('flash-msg').remove()"
                        class="opacity-40 hover:opacity-70 transition text-current">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M6 18L18 6M6 6l12 12"/>
                    </svg>
                </button>
            </div>
            <script>setTimeout(()=>{const f=document.getElementById('flash-msg');if(f){f.style.transition='opacity 0.4s';f.style.opacity='0';setTimeout(()=>f.remove(),400);}},4500);</script>
            <% } %>

            <!-- ── Header ── -->
            <div class="flex flex-col md:flex-row md:items-center justify-between gap-4">
                <div>
                    <div class="flex items-center gap-2 mb-1">
                        <span class="text-[11px] font-black text-slate-400 uppercase tracking-widest">Inscripciones</span>
                        <span class="text-slate-200">/</span>
                        <span class="text-[11px] font-black uppercase tracking-widest" style="color:
                            <%= type==='voluntario' ? '#73A950' : type==='autoridad' ? '#A02140' : type==='delegado' ? '#61B4E4' : '#E15829' %>">
                            <%= type === 'voluntario' ? 'Voluntarios' : type === 'autoridad' ? 'Autoridades' : type === 'delegado' ? 'Delegados' : 'Colegios' %>
                        </span>
                    </div>
                    <h1 class="text-3xl font-black text-slate-900"><%= title %></h1>
                    <p class="text-sm text-gray-400 mt-1">
                        <span id="visibleCount" class="font-bold text-slate-600"><%= inscriptions.length %></span>
                        de <span class="font-bold"><%= inscriptions.length %></span> registros
                    </p>
                </div>
                <div class="flex items-center gap-3">
                    <button onclick="toggleAddPanel()"
                            class="flex items-center gap-2 px-5 py-2.5 rounded-xl bg-indigo-600 text-white text-sm font-bold hover:bg-indigo-700 transition shadow-lg shadow-indigo-200">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 4v16m8-8H4"/>
                        </svg>
                        Agregar manual
                    </button>
                    <form action="/admin/inscripciones/<%= type %>/eliminar-todo" method="POST"
                          onsubmit="return confirm('⚠️ PELIGRO: Esto borrará TODOS los registros de esta categoría. ¿Confirmar?')">
                        <button type="submit"
                                class="flex items-center gap-2 px-5 py-2.5 rounded-xl bg-white border border-red-100 text-red-500 text-sm font-bold hover:bg-red-50 transition">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
                            </svg>
                            Vaciar Lista
                        </button>
                    </form>
                </div>
            </div>

            <!-- ── Panel agregar manual ── -->
            <div id="addPanel" class="closed" style="max-height: 0;">
                <div class="bg-white rounded-2xl border border-indigo-100 shadow-sm p-6">
                    <div class="flex items-center gap-3 mb-5">
                        <div class="w-7 h-7 rounded-lg bg-indigo-50 flex items-center justify-center">
                            <svg class="w-3.5 h-3.5 text-indigo-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
                            </svg>
                        </div>
                        <h2 class="text-sm font-black text-slate-700">Agregar inscripción manualmente</h2>
                    </div>
                    <form action="/admin/inscripciones/<%= type %>/upload-manual" method="POST" class="grid grid-cols-1 md:grid-cols-3 gap-4">
                        <div>
                            <label class="text-[11px] font-black text-slate-600 uppercase tracking-wider block mb-2">Nombre completo *</label>
                            <input type="text" name="name" required
                                   class="w-full px-4 py-3 rounded-xl border border-gray-200 bg-gray-50 text-sm font-medium text-slate-700 transition-all">
                        </div>
                        <div>
                            <label class="text-[11px] font-black text-slate-600 uppercase tracking-wider block mb-2">Email</label>
                            <input type="email" name="email"
                                   class="w-full px-4 py-3 rounded-xl border border-gray-200 bg-gray-50 text-sm font-medium text-slate-700 transition-all">
                        </div>
                        <div>
                            <label class="text-[11px] font-black text-slate-600 uppercase tracking-wider block mb-2">Teléfono / WhatsApp</label>
                            <input type="text" name="telefono" placeholder="ej: 3855123456"
                                   class="w-full px-4 py-3 rounded-xl border border-gray-200 bg-gray-50 text-sm font-medium text-slate-700 transition-all">
                        </div>
                        <% if (type === 'voluntario') { %>
                        <div>
                            <label class="text-[11px] font-black text-slate-600 uppercase tracking-wider block mb-2">Interés / Área</label>
                            <input type="text" name="interes" placeholder="ej: Logística, Prensa..."
                                   class="w-full px-4 py-3 rounded-xl border border-gray-200 bg-gray-50 text-sm font-medium text-slate-700 transition-all">
                        </div>
                        <% } %>
                        <% if (type === 'autoridad') { %>
                        <div>
                            <label class="text-[11px] font-black text-slate-600 uppercase tracking-wider block mb-2">Rol / Cargo</label>
                            <input type="text" name="rol" placeholder="ej: Presidencia, Ujier..."
                                   class="w-full px-4 py-3 rounded-xl border border-gray-200 bg-gray-50 text-sm font-medium text-slate-700 transition-all">
                        </div>
                        <% } %>
                        <% if (type === 'escuela') { %>
                        <div>
                            <label class="text-[11px] font-black text-slate-600 uppercase tracking-wider block mb-2">Docente responsable</label>
                            <input type="text" name="docente"
                                   class="w-full px-4 py-3 rounded-xl border border-gray-200 bg-gray-50 text-sm font-medium text-slate-700 transition-all">
                        </div>
                        <% } %>
                        <div class="md:col-span-3 flex justify-end gap-3 pt-2">
                            <button type="button" onclick="toggleAddPanel()"
                                    class="px-6 py-2.5 rounded-xl text-gray-500 font-bold hover:bg-gray-100 transition text-sm">Cancelar</button>
                            <button type="submit"
                                    class="px-8 py-2.5 rounded-xl bg-indigo-600 text-white font-bold hover:bg-indigo-700 transition shadow-lg shadow-indigo-200 text-sm">
                                Guardar inscripción
                            </button>
                        </div>
                    </form>
                </div>
            </div>

            <!-- ── Barra de herramientas ── -->
            <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-5">
                <div class="flex flex-col lg:flex-row gap-4 items-center justify-between">

                    <!-- Importar Excel -->
                    <form action="/admin/inscripciones/<%= type %>/upload" method="POST" enctype="multipart/form-data"
                          class="flex items-center gap-2 bg-slate-50 px-3 py-2 rounded-xl border border-gray-200">
                        <input type="file" name="file" accept=".xlsx,.csv" required
                               class="text-xs text-gray-400 file:mr-2 file:py-1.5 file:px-3 file:rounded-lg file:border-0 file:text-xs file:font-bold file:bg-blue-50 file:text-blue-600 hover:file:bg-blue-100">
                        <button type="submit"
                                class="flex items-center gap-1.5 px-4 py-2 bg-blue-600 text-white text-xs font-bold rounded-lg hover:bg-blue-700 transition shadow-sm shadow-blue-200">
                            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12"/>
                            </svg>
                            Importar
                        </button>
                        <a href="/admin/ejemplos/<%= type %>" class="text-[11px] font-bold text-blue-500 hover:underline whitespace-nowrap">ver ejemplo</a>
                    </form>

                    <!-- Filtros -->
                    <div class="flex flex-wrap gap-3 items-center">
                        <!-- Búsqueda -->
                        <div class="relative">
                            <svg class="w-4 h-4 text-gray-400 absolute left-3 top-1/2 -translate-y-1/2 pointer-events-none" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
                            </svg>
                            <input type="text" id="searchInput" oninput="applyFilters()" placeholder="Buscar..."
                                   class="pl-9 pr-4 py-2.5 rounded-xl border border-gray-200 bg-gray-50 text-sm font-medium text-slate-700 w-52 transition-all">
                        </div>

                        <!-- Ordenar por -->
                        <select id="sortSelect" onchange="applyFilters()"
                                class="px-4 py-2.5 rounded-xl border border-gray-200 bg-gray-50 text-sm font-bold text-slate-600 transition-all">
                            <option value="">Ordenar por...</option>
                            <option value="name-asc">Nombre A→Z</option>
                            <option value="name-desc">Nombre Z→A</option>
                            <option value="date-asc">Fecha ↑</option>
                            <option value="date-desc">Fecha ↓ (recientes)</option>
                            <% if (type === 'voluntario') { %>
                            <option value="interes-asc">Interés A→Z</option>
                            <% } %>
                            <% if (type === 'autoridad') { %>
                            <option value="rol-asc">Rol A→Z</option>
                            <% } %>
                        </select>

                        <!-- Contador -->
                        <span class="text-[11px] font-black text-gray-400 uppercase tracking-wider whitespace-nowrap">
                            <span id="countBadge" class="bg-slate-100 text-slate-600 px-2.5 py-1 rounded-full"><%= inscriptions.length %></span>
                        </span>
                    </div>
                </div>
            </div>

            <!-- ── Tabla ── -->
            <div class="bg-white rounded-2xl border border-gray-100 shadow-sm overflow-hidden">
                <% if (inscriptions.length === 0) { %>
                <div class="py-20 text-center">
                    <div class="w-14 h-14 bg-gray-100 rounded-2xl flex items-center justify-center mx-auto mb-4">
                        <svg class="w-7 h-7 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
                        </svg>
                    </div>
                    <p class="text-sm font-bold text-gray-400">No hay inscripciones todavía.</p>
                    <p class="text-xs text-gray-300 mt-1">Importá un Excel o agregá una manualmente.</p>
                </div>
                <% } else { %>
                <div class="overflow-x-auto">
                    <table class="w-full text-left" id="inscriptionsTable">
                        <thead class="bg-gray-50 border-b border-gray-100">
                            <tr class="text-[11px] font-black text-gray-400 uppercase tracking-widest">
                                <th class="px-6 py-4 sortable" onclick="sortBy('name')">
                                    <%= type === 'escuela' ? 'Institución' : 'Nombre' %>
                                </th>
                                <% if (type !== 'delegado') { %>
                                <th class="px-6 py-4">WhatsApp</th>
                                <% } %>
                                <th class="px-6 py-4 sortable" onclick="sortBy('email')">Email</th>
                                <% if (type === 'voluntario') { %>
                                <th class="px-6 py-4 sortable" onclick="sortBy('interes')">Interés</th>
                                <% } %>
                                <% if (type === 'autoridad') { %>
                                <th class="px-6 py-4 sortable" onclick="sortBy('rol')">Rol</th>
                                <% } %>
                                <% if (type === 'escuela') { %>
                                <th class="px-6 py-4">Docente</th>
                                <% } %>
                                <% if (type === 'delegado') { %>
                                <th class="px-6 py-4">Colegio</th>
                                <th class="px-6 py-4">Órgano</th>
                                <% } %>
                                <th class="px-6 py-4 sortable" onclick="sortBy('date')">Fecha</th>
                                <th class="px-6 py-4 text-right">Acciones</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-gray-50" id="tableBody">
                            <% inscriptions.forEach((item, i) => {
                                let rawPhone = '';
                                if (item.data) {
                                    rawPhone = item.data.normalized_phone || item.data.telefono || item.data.celular || item.data.phone || item.data.whatsapp || item.data.contacto || '';
                                }
                                let cleanNum = rawPhone.toString().replace(/\D/g, '');
                                if (cleanNum.startsWith('0')) cleanNum = cleanNum.substring(1);
                                let wppLink = cleanNum;
                                if (cleanNum.length > 0 && !cleanNum.startsWith('54')) wppLink = '549' + cleanNum;
                                let mensaje = 'Hola ' + item.name + ', te hablo desde Uniendo Metas Santiago del Estero.';

                                let interes = item.data ? (item.data.interes || item.data['área'] || item.data.area || item.data.interés || '') : '';
                                let rol = item.data ? (item.data.normalized_role || item.data.rol || item.data.cargo || '') : '';
                                let docente = item.data ? (item.data.normalized_teacher || item.data.docente || item.data.profesor || '') : '';
                                let colegio = item.data ? (item.data.colegio || item.data.escuela || item.data.institución || item.data.institucion || '') : '';
                                let organo = item.data ? (item.data.organo || item.data.órgano || item.data['órgano'] || item.data.comision || '') : '';
                            %>
                            <tr class="hover:bg-slate-50/50 transition inscription-row"
                                data-name="<%= item.name.toLowerCase() %>"
                                data-email="<%= (item.email || '').toLowerCase() %>"
                                data-interes="<%= interes.toLowerCase() %>"
                                data-rol="<%= rol.toLowerCase() %>"
                                data-date="<%= new Date(item.createdAt).getTime() %>">

                                <!-- Nombre -->
                                <td class="px-6 py-4">
                                    <div class="flex items-center gap-3">
                                        <div class="w-8 h-8 rounded-xl flex items-center justify-center flex-shrink-0 font-black text-xs"
                                             style="background: <%= type==='voluntario' ? '#EDF5E8' : type==='autoridad' ? '#F9E8EC' : type==='delegado' ? '#E8F5FB' : '#FCEEE9' %>;
                                                    color: <%= type==='voluntario' ? '#73A950' : type==='autoridad' ? '#A02140' : type==='delegado' ? '#61B4E4' : '#E15829' %>;">
                                            <%= item.name.charAt(0).toUpperCase() %>
                                        </div>
                                        <div>
                                            <p class="text-sm font-bold text-slate-800"><%= item.name %></p>
                                        </div>
                                    </div>
                                </td>

                                <!-- WhatsApp -->
                                <% if (type !== 'delegado') { %>
                                <td class="px-6 py-4">
                                    <% if (cleanNum.length > 6) { %>
                                    <a href="https://wa.me/<%= wppLink %>?text=<%= encodeURIComponent(mensaje) %>" target="_blank"
                                       class="inline-flex items-center gap-1.5 px-3 py-1.5 bg-emerald-50 text-emerald-700 rounded-xl hover:bg-emerald-600 hover:text-white transition-all font-bold text-xs border border-emerald-100">
                                        <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24">
                                            <path d="M.057 24l1.687-6.163c-1.041-1.804-1.588-3.849-1.587-5.946.003-6.556 5.338-11.891 11.893-11.891 3.181.001 6.167 1.24 8.413 3.488 2.245 2.248 3.481 5.236 3.48 8.414-.003 6.557-5.338 11.892-11.893 11.892-1.99-.001-3.951-.5-5.688-1.448l-6.305 1.654zm6.597-3.807c1.676.995 3.276 1.591 5.392 1.592 5.448 0 9.886-4.434 9.889-9.885.002-5.462-4.415-9.89-9.881-9.892-5.452 0-9.887 4.434-9.889 9.884-.001 2.225.651 3.891 1.746 5.634l-.999 3.648 3.742-.981zm11.387-5.464c-.074-.124-.272-.198-.57-.347-.297-.149-1.758-.868-2.031-.967-.272-.099-.47-.149-.669.149-.198.297-.768.967-.941 1.165-.173.198-.347.223-.644.074-.297-.149-1.255-.462-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.297-.347.446-.521.151-.172.2-.296.3-.495.099-.198.05-.372-.025-.521-.075-.148-.669-1.611-.916-2.206-.242-.579-.487-.501-.669-.51l-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.017-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.095 3.2 5.076 4.487.709.306 1.263.489 1.694.626.712.226 1.36.194 1.872.118.571-.085 1.758-.719 2.006-1.413.248-.695.248-1.29.173-1.414z"/>
                                        </svg>
                                        <%= rawPhone || 'Chat' %>
                                    </a>
                                    <% } else { %>
                                    <span class="text-xs text-gray-300 font-medium">Sin número</span>
                                    <% } %>
                                </td>
                                <% } %>

                                <!-- Email -->
                                <td class="px-6 py-4">
                                    <% if (item.email && item.email !== 'Sin Email') { %>
                                    <a href="mailto:<%= item.email %>" class="text-xs text-blue-500 hover:text-blue-700 font-medium transition"><%= item.email %></a>
                                    <% } else { %>
                                    <span class="text-xs text-gray-300 font-medium">—</span>
                                    <% } %>
                                </td>

                                <!-- Interés (voluntario) -->
                                <% if (type === 'voluntario') { %>
                                <td class="px-6 py-4">
                                    <% if (interes) { %>
                                    <span class="px-2.5 py-1 rounded-full text-[11px] font-bold bg-green-50 text-green-700"><%= interes %></span>
                                    <% } else { %>
                                    <span class="text-xs text-gray-300">—</span>
                                    <% } %>
                                </td>
                                <% } %>

                                <!-- Rol (autoridad) -->
                                <% if (type === 'autoridad') { %>
                                <td class="px-6 py-4">
                                    <% if (rol) { %>
                                    <span class="px-2.5 py-1 rounded-full text-[11px] font-bold bg-rose-50 text-rose-700"><%= rol %></span>
                                    <% } else { %>
                                    <span class="text-xs text-gray-300">—</span>
                                    <% } %>
                                </td>
                                <% } %>

                                <!-- Docente (escuela) -->
                                <% if (type === 'escuela') { %>
                                <td class="px-6 py-4">
                                    <p class="text-sm font-bold text-slate-700"><%= docente || '—' %></p>
                                </td>
                                <% } %>

                                <!-- Delegado: colegio + órgano -->
                                <% if (type === 'delegado') { %>
                                <td class="px-6 py-4">
                                    <span class="text-sm text-slate-700 font-medium"><%= colegio || '—' %></span>
                                </td>
                                <td class="px-6 py-4">
                                    <% if (organo) { %>
                                    <span class="px-2.5 py-1 rounded-full text-[11px] font-bold bg-blue-50 text-blue-700"><%= organo %></span>
                                    <% } else { %>
                                    <span class="text-xs text-gray-300">—</span>
                                    <% } %>
                                </td>
                                <% } %>

                                <!-- Fecha -->
                                <td class="px-6 py-4">
                                    <span class="text-xs font-bold text-gray-400">
                                        <%= new Date(item.createdAt).toLocaleDateString('es-AR', { day: '2-digit', month: 'short', year: '2-digit' }) %>
                                    </span>
                                </td>

                                <!-- Acciones -->
                                <td class="px-6 py-4 text-right">
                                    <div class="flex items-center justify-end gap-1">
                                        <textarea id="json-<%= item.id %>" class="hidden"><%= JSON.stringify(item.data) %></textarea>
                                        <button onclick="showDetails('json-<%= item.id %>')"
                                                class="w-8 h-8 rounded-xl flex items-center justify-center text-gray-400 hover:text-blue-600 hover:bg-blue-50 transition"
                                                title="Ver todos los campos">
                                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>
                                            </svg>
                                        </button>
                                        <button onclick="openEditById(<%= item.id %>)"
                                                class="w-8 h-8 rounded-xl flex items-center justify-center text-gray-400 hover:text-indigo-600 hover:bg-indigo-50 transition edit-btn"
                                                title="Editar"
                                                data-id="<%= item.id %>"
                                                data-name="<%= (item.name||'').replace(/"/g, '&quot;') %>"
                                                data-email="<%= (item.email||'').replace(/"/g, '&quot;') %>"
                                                data-phone="<%= rawPhone.toString().replace(/"/g, '&quot;') %>"
                                                data-interes="<%= interes.replace(/"/g, '&quot;') %>"
                                                data-rol="<%= rol.replace(/"/g, '&quot;') %>"
                                                data-docente="<%= docente.replace(/"/g, '&quot;') %>">
                                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
                                            </svg>
                                        </button>
                                        <a href="/admin/inscripciones/eliminar/<%= item.id %>"
                                           onclick="return confirm('¿Eliminar este registro?')"
                                           class="w-8 h-8 rounded-xl flex items-center justify-center text-gray-400 hover:text-red-600 hover:bg-red-50 transition"
                                           title="Eliminar">
                                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
                                            </svg>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                            <% }); %>
                        </tbody>
                    </table>
                </div>
                <% } %>
            </div>

        </div>
    </main>
</div>

<!-- ── Modal detalles ── -->
<div id="modal" class="fixed inset-0 z-50 hidden">
    <div class="fixed inset-0 bg-slate-900/50 backdrop-blur-sm" onclick="closeModal()"></div>
    <div class="fixed inset-0 z-10 overflow-y-auto flex items-center justify-center p-4">
        <div class="bg-white rounded-2xl shadow-2xl w-full max-w-lg border border-gray-100">
            <div class="flex items-center justify-between px-6 py-5 border-b border-gray-100">
                <div>
                    <p class="text-[11px] font-black text-gray-400 uppercase tracking-widest">Detalles completos</p>
                    <h3 class="text-lg font-black text-slate-900 mt-0.5" id="modalTitle">—</h3>
                </div>
                <button onclick="closeModal()" class="w-8 h-8 rounded-xl flex items-center justify-center text-gray-400 hover:bg-gray-100 hover:text-slate-700 transition">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M6 18L18 6M6 6l12 12"/>
                    </svg>
                </button>
            </div>
            <div class="px-6 py-5 max-h-[65vh] overflow-y-auto" id="modalContent"></div>
        </div>
    </div>
</div>

<!-- ── Modal edición ── -->
<div id="editModal" class="fixed inset-0 z-50 hidden">
    <div class="fixed inset-0 bg-slate-900/50 backdrop-blur-sm" onclick="closeEditModal()"></div>
    <div class="fixed inset-0 z-10 overflow-y-auto flex items-center justify-center p-4">
        <div class="bg-white rounded-2xl shadow-2xl w-full max-w-lg border border-gray-100">
            <div class="flex items-center justify-between px-6 py-5 border-b border-gray-100">
                <div>
                    <p class="text-[11px] font-black text-gray-400 uppercase tracking-widest">Editar inscripción</p>
                    <h3 class="text-lg font-black text-slate-900 mt-0.5" id="editModalTitle">—</h3>
                </div>
                <button onclick="closeEditModal()" class="w-8 h-8 rounded-xl flex items-center justify-center text-gray-400 hover:bg-gray-100 hover:text-slate-700 transition">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M6 18L18 6M6 6l12 12"/>
                    </svg>
                </button>
            </div>
            <form id="editForm" method="POST" class="px-6 py-5 space-y-4">
                <input type="hidden" name="_method" value="PUT">
                <div>
                    <label class="text-[11px] font-black text-slate-600 uppercase tracking-wider block mb-2">Nombre completo</label>
                    <input type="text" name="name" id="editName"
                           class="w-full px-4 py-3 rounded-xl border border-gray-200 bg-gray-50 text-sm font-medium text-slate-700 transition-all focus:outline-none focus:border-blue-400 focus:ring-2 focus:ring-blue-100">
                </div>
                <div class="grid grid-cols-2 gap-4">
                    <div>
                        <label class="text-[11px] font-black text-slate-600 uppercase tracking-wider block mb-2">Email</label>
                        <input type="email" name="email" id="editEmail"
                               class="w-full px-4 py-3 rounded-xl border border-gray-200 bg-gray-50 text-sm font-medium text-slate-700 transition-all focus:outline-none focus:border-blue-400 focus:ring-2 focus:ring-blue-100">
                    </div>
                    <div>
                        <label class="text-[11px] font-black text-slate-600 uppercase tracking-wider block mb-2">Teléfono / WhatsApp</label>
                        <input type="text" name="telefono" id="editPhone"
                               class="w-full px-4 py-3 rounded-xl border border-gray-200 bg-gray-50 text-sm font-medium text-slate-700 transition-all focus:outline-none focus:border-blue-400 focus:ring-2 focus:ring-blue-100">
                    </div>
                </div>
                <div id="editExtraFields"></div>
                <div class="flex justify-end gap-3 pt-2 border-t border-gray-50">
                    <button type="button" onclick="closeEditModal()"
                            class="px-6 py-2.5 rounded-xl text-gray-500 font-bold hover:bg-gray-100 transition text-sm">Cancelar</button>
                    <button type="submit"
                            class="px-8 py-2.5 rounded-xl bg-indigo-600 text-white font-bold hover:bg-indigo-700 transition shadow-lg shadow-indigo-200 text-sm">
                        Guardar cambios
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
    // ── Toggle panel agregar ──
    function toggleAddPanel() {
        const p = document.getElementById('addPanel');
        if (p.classList.contains('closed')) {
            p.classList.remove('closed');
            p.style.maxHeight = p.scrollHeight + 'px';
        } else {
            p.classList.add('closed');
            p.style.maxHeight = '0';
        }
    }

    // ── Modal ──
    function showDetails(id) {
        try {
            const el  = document.getElementById(id);
            const row = el.closest('tr');
            const name = row ? (row.dataset.name || '') : '';
            const data = JSON.parse(el.value);
            const skip = ['normalized_role','normalized_teacher','normalized_phone'];
            let html = '<div class="space-y-3">';
            for (const [k, v] of Object.entries(data)) {
                if (skip.includes(k) || v === null || v === undefined || v === '') continue;
                html += '<div class="flex flex-col pb-3 border-b border-gray-50 last:border-0">'
                      + '<span class="text-[10px] font-black text-gray-400 uppercase tracking-widest mb-1">' + k + '</span>'
                      + '<span class="text-sm font-medium text-slate-800 break-words">' + v + '</span>'
                      + '</div>';
            }
            html += '</div>';
            document.getElementById('modalTitle').textContent = name || 'Detalles';
            document.getElementById('modalContent').innerHTML = html;
            document.getElementById('modal').classList.remove('hidden');
            document.body.style.overflow = 'hidden';
        } catch(e) { alert('No se pudieron cargar los datos.'); }
    }
    function closeModal() {
        document.getElementById('modal').classList.add('hidden');
        document.body.style.overflow = '';
    }

    // ── Filtros y ordenamiento ──
    let currentSort = { field: 'date', dir: 'desc' };

    function applyFilters() {
        const search = document.getElementById('searchInput').value.toLowerCase().trim();
        const sortVal = document.getElementById('sortSelect').value;
        if (sortVal) {
            const [field, dir] = sortVal.split('-');
            currentSort = { field, dir };
        }

        const rows = Array.from(document.querySelectorAll('.inscription-row'));

        // Filtrar
        rows.forEach(row => {
            const text = row.textContent.toLowerCase();
            row.style.display = (!search || text.includes(search)) ? '' : 'none';
        });

        // Ordenar
        const visible = rows.filter(r => r.style.display !== 'none');
        visible.sort((a, b) => {
            let va = a.dataset[currentSort.field] || '';
            let vb = b.dataset[currentSort.field] || '';
            if (currentSort.field === 'date') {
                va = parseInt(va) || 0;
                vb = parseInt(vb) || 0;
                return currentSort.dir === 'asc' ? va - vb : vb - va;
            }
            return currentSort.dir === 'asc' ? va.localeCompare(vb) : vb.localeCompare(va);
        });

        const tbody = document.getElementById('tableBody');
        visible.forEach(r => tbody.appendChild(r));

        // Actualizar contador
        const count = visible.length;
        document.getElementById('visibleCount').textContent = count;
        document.getElementById('countBadge').textContent = count;
    }

    function sortBy(field) {
        if (currentSort.field === field) {
            currentSort.dir = currentSort.dir === 'asc' ? 'desc' : 'asc';
        } else {
            currentSort = { field, dir: 'asc' };
        }
        // Actualizar select
        const sel = document.getElementById('sortSelect');
        sel.value = field + '-' + currentSort.dir;
        applyFilters();
    }

    // Aplicar orden inicial por fecha desc
    document.getElementById('sortSelect').value = 'date-desc';
    applyFilters();

    // ── Modal edición ──
    const TYPE = '<%= type %>';

    function openEditById(id) {
        const btn = document.querySelector(`.edit-btn[data-id="${id}"]`);
        const name    = btn.dataset.name;
        const email   = btn.dataset.email;
        const phone   = btn.dataset.phone;
        const interes = btn.dataset.interes;
        const rol     = btn.dataset.rol;
        const docente = btn.dataset.docente;

        document.getElementById('editModalTitle').textContent = name;
        document.getElementById('editForm').action = '/admin/inscripciones/editar/' + id;
        document.getElementById('editName').value  = name;
        document.getElementById('editEmail').value = email;
        document.getElementById('editPhone').value = phone;

        // Campos extra según tipo
        let extra = '';
        if (TYPE === 'voluntario') {
            extra = `<div>
                <label class="text-[11px] font-black text-slate-600 uppercase tracking-wider block mb-2">Interés / Área</label>
                <input type="text" name="interes" value="${interes}"
                       class="w-full px-4 py-3 rounded-xl border border-gray-200 bg-gray-50 text-sm font-medium text-slate-700 focus:outline-none focus:border-blue-400 focus:ring-2 focus:ring-blue-100">
            </div>`;
        } else if (TYPE === 'autoridad') {
            extra = `<div>
                <label class="text-[11px] font-black text-slate-600 uppercase tracking-wider block mb-2">Rol / Cargo</label>
                <input type="text" name="rol" value="${rol}"
                       class="w-full px-4 py-3 rounded-xl border border-gray-200 bg-gray-50 text-sm font-medium text-slate-700 focus:outline-none focus:border-blue-400 focus:ring-2 focus:ring-blue-100">
            </div>`;
        } else if (TYPE === 'escuela') {
            extra = `<div>
                <label class="text-[11px] font-black text-slate-600 uppercase tracking-wider block mb-2">Docente responsable</label>
                <input type="text" name="docente" value="${docente}"
                       class="w-full px-4 py-3 rounded-xl border border-gray-200 bg-gray-50 text-sm font-medium text-slate-700 focus:outline-none focus:border-blue-400 focus:ring-2 focus:ring-blue-100">
            </div>`;
        }
        document.getElementById('editExtraFields').innerHTML = extra;

        document.getElementById('editModal').classList.remove('hidden');
        document.body.style.overflow = 'hidden';
    }

    function closeEditModal() {
        document.getElementById('editModal').classList.add('hidden');
        document.body.style.overflow = '';
    }
</script>

</body>
</html>
