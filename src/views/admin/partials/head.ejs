<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title || 'Admin' %> | Uniendo Metas</title>
    
    <!-- Favicon -->
    <link rel="icon" type="image/png" href="/img/logo-um.png">
    <link rel="shortcut icon" type="image/png" href="/img/logo-um.png">
    <link rel="apple-touch-icon" href="/img/logo-um.png">
    
    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com"></script>
    
    <style>
        @keyframes fade-in {
            from { opacity: 0; transform: translateY(-10px); }
            to { opacity: 1; transform: translateY(0); }
        }
        .animate-fade-in {
            animation: fade-in 0.3s ease-out;
        }
    </style>
</head>