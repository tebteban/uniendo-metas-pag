<aside id="admin-sidebar"
    class="w-64 bg-white border-r border-gray-100 fixed h-full z-40 flex flex-col top-0 left-0 transform -translate-x-full md:translate-x-0 transition-transform duration-300 ease-in-out"
    style="padding-top:64px; box-shadow: 2px 0 20px rgba(0,0,0,0.03);">

    <div class="flex-1 overflow-y-auto py-5 px-3 space-y-5">

        <!-- PRINCIPAL -->
        <div>
            <p class="text-[9px] font-black text-gray-300 uppercase tracking-[0.22em] px-3 mb-2">Principal</p>
            <div class="space-y-0.5">

                <a href="/admin/dashboard"
                   class="flex items-center gap-3 px-3 py-2.5 rounded-xl transition-all duration-150 group
                          <%= (typeof title !== 'undefined' && title.includes('Panel')) ? 'font-bold' : 'text-gray-500 font-medium hover:bg-gray-50 hover:text-slate-800' %>"
                   <% if (typeof title !== 'undefined' && title.includes('Panel')) { %>
                   style="background:#EDF5E8; color:#3D7A26;"
                   <% } %>>
                    <svg style="width:18px;height:18px;flex-shrink:0;" fill="none" stroke="currentColor" viewBox="0 0 24 24"
                         class="<%= (typeof title !== 'undefined' && title.includes('Panel')) ? '' : 'text-gray-300 group-hover:text-gray-500' %>"
                         <% if (typeof title !== 'undefined' && title.includes('Panel')) { %> style="color:#73A950;" <% } %>>
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zM14 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z"/>
                    </svg>
                    <span class="text-sm">Dashboard</span>
                </a>

                <a href="/admin/configuracion"
                   class="flex items-center gap-3 px-3 py-2.5 rounded-xl transition-all duration-150 group
                          <%= (typeof title !== 'undefined' && title.includes('Configuración')) ? 'font-bold' : 'text-gray-500 font-medium hover:bg-gray-50 hover:text-slate-800' %>"
                   <% if (typeof title !== 'undefined' && title.includes('Configuración')) { %> style="background:#F9E8EC; color:#A02140;" <% } %>>
                    <svg style="width:18px;height:18px;flex-shrink:0;" fill="none" stroke="currentColor" viewBox="0 0 24 24"
                         class="<%= (typeof title !== 'undefined' && title.includes('Configuración')) ? '' : 'text-gray-300 group-hover:text-gray-500' %>"
                         <% if (typeof title !== 'undefined' && title.includes('Configuración')) { %> style="color:#A02140;" <% } %>>
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                    </svg>
                    <span class="text-sm">Configuración</span>
                </a>

                <a href="/admin/fotos"
                   class="flex items-center gap-3 px-3 py-2.5 rounded-xl transition-all duration-150 group
                          <%= (typeof title !== 'undefined' && title.includes('Fotos')) ? 'font-bold' : 'text-gray-500 font-medium hover:bg-gray-50 hover:text-slate-800' %>"
                   <% if (typeof title !== 'undefined' && title.includes('Fotos')) { %> style="background:#E8F5FB; color:#1D6FA4;" <% } %>>
                    <svg style="width:18px;height:18px;flex-shrink:0;" fill="none" stroke="currentColor" viewBox="0 0 24 24"
                         class="<%= (typeof title !== 'undefined' && title.includes('Fotos')) ? '' : 'text-gray-300 group-hover:text-gray-500' %>"
                         <% if (typeof title !== 'undefined' && title.includes('Fotos')) { %> style="color:#61B4E4;" <% } %>>
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                    </svg>
                    <span class="text-sm">Galería Fotos</span>
                </a>
            </div>
        </div>

        <!-- GESTIÓN WEB -->
        <div>
            <p class="text-[9px] font-black text-gray-300 uppercase tracking-[0.22em] px-3 mb-2">Gestión Web</p>
            <div class="space-y-0.5">

                <a href="/admin/equipodevoluntarios"
                   class="flex items-center gap-3 px-3 py-2.5 rounded-xl transition-all duration-150 group
                          <%= (typeof title !== 'undefined' && title.includes('Equipo')) ? 'font-bold' : 'text-gray-500 font-medium hover:bg-gray-50 hover:text-slate-800' %>"
                   <% if (typeof title !== 'undefined' && title.includes('Equipo')) { %> style="background:#EDF5E8; color:#3D7A26;" <% } %>>
                    <svg style="width:18px;height:18px;flex-shrink:0;" fill="none" stroke="currentColor" viewBox="0 0 24 24" class="text-gray-300 group-hover:text-gray-500">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"/>
                    </svg>
                    <span class="text-sm">Equipo Staff</span>
                </a>

                <a href="/admin/textos"
                   class="flex items-center gap-3 px-3 py-2.5 rounded-xl transition-all duration-150 group
                          <%= (typeof title !== 'undefined' && title.includes('Textos')) ? 'font-bold' : 'text-gray-500 font-medium hover:bg-gray-50 hover:text-slate-800' %>"
                   <% if (typeof title !== 'undefined' && title.includes('Textos')) { %> style="background:#E8F5FB; color:#1D6FA4;" <% } %>>
                    <svg style="width:18px;height:18px;flex-shrink:0;" fill="none" stroke="currentColor" viewBox="0 0 24 24" class="text-gray-300 group-hover:text-gray-500">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
                    </svg>
                    <span class="text-sm">Textos</span>
                </a>

                <a href="/admin/organos"
                   class="flex items-center gap-3 px-3 py-2.5 rounded-xl transition-all duration-150 group
                          <%= (typeof title !== 'undefined' && title.includes('Órganos')) ? 'font-bold' : 'text-gray-500 font-medium hover:bg-gray-50 hover:text-slate-800' %>"
                   <% if (typeof title !== 'undefined' && title.includes('Órganos')) { %> style="background:#FEF6E0; color:#B8860B;" <% } %>>
                    <svg style="width:18px;height:18px;flex-shrink:0;" fill="none" stroke="currentColor" viewBox="0 0 24 24" class="text-gray-300 group-hover:text-gray-500">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/>
                    </svg>
                    <span class="text-sm">Órganos</span>
                </a>

                <a href="/admin/cronograma"
                   class="flex items-center gap-3 px-3 py-2.5 rounded-xl transition-all duration-150 group
                          <%= (typeof title !== 'undefined' && title.includes('Cronograma')) ? 'font-bold' : 'text-gray-500 font-medium hover:bg-gray-50 hover:text-slate-800' %>"
                   <% if (typeof title !== 'undefined' && title.includes('Cronograma')) { %> style="background:#FCEEE9; color:#C04828;" <% } %>>
                    <svg style="width:18px;height:18px;flex-shrink:0;" fill="none" stroke="currentColor" viewBox="0 0 24 24" class="text-gray-300 group-hover:text-gray-500">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                    </svg>
                    <span class="text-sm">Cronograma</span>
                </a>
            </div>
        </div>

        <!-- INSCRIPCIONES -->
        <div>
            <p class="text-[9px] font-black text-gray-300 uppercase tracking-[0.22em] px-3 mb-2">Inscripciones</p>
            <div class="space-y-0.5">
                <% [
                    { href: '/admin/inscripciones/voluntario', label: 'Voluntarios',  match: 'Inscripciones: Voluntarios', color: '#73A950', bg: '#EDF5E8' },
                    { href: '/admin/inscripciones/escuela',    label: 'Colegios',     match: 'Inscripciones: Colegios',    color: '#E15829', bg: '#FCEEE9' },
                    { href: '/admin/inscripciones/autoridad',  label: 'Autoridades',  match: 'Inscripciones: Autoridades', color: '#A02140', bg: '#F9E8EC' },
                    { href: '/admin/inscripciones/delegado',   label: 'Delegados',    match: 'Inscripciones: Delegados',   color: '#61B4E4', bg: '#E8F5FB' },
                ].forEach(item => { %>
                <%
                    const isActive = typeof title !== 'undefined' && title.includes(item.match);
                %>
                <a href="<%= item.href %>"
                   class="flex items-center gap-3 px-3 py-2.5 rounded-xl transition-all duration-150 group
                          <%= isActive ? 'font-bold' : 'text-gray-500 font-medium hover:bg-gray-50 hover:text-slate-800' %>"
                   <% if (isActive) { %> style="background:<%= item.bg %>; color:<%= item.color %>;" <% } %>>
                    <span class="w-2 h-2 rounded-full ml-1 flex-shrink-0" style="background:<%= item.color %>; opacity:<%= isActive ? 1 : 0.3 %>;"></span>
                    <span class="text-sm"><%= item.label %></span>
                </a>
                <% }); %>
            </div>
        </div>

    </div>

    <!-- Footer -->
    <div class="p-3 border-t border-gray-100">
        <a href="/" target="_blank"
           class="flex items-center justify-center gap-2 px-4 py-2.5 rounded-xl text-xs font-bold text-gray-400 hover:text-slate-700 hover:bg-gray-50 transition-all">
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
            </svg>
            Ver sitio web
        </a>
    </div>
</aside>
