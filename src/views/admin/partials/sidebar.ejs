<!-- Overlay oscuro para mobile -->
<div id="sidebar-overlay" class="hidden fixed inset-0 bg-black/30 z-30 md:hidden"></div>

<aside id="admin-sidebar"
    class="w-64 bg-white border-r border-gray-100 fixed h-full z-40 flex flex-col top-0 left-0 transform -translate-x-full md:translate-x-0 transition-transform duration-300 ease-in-out"
    style="padding-top:64px; box-shadow: 2px 0 20px rgba(0,0,0,0.03);">

    <div class="flex-1 overflow-y-auto py-5 px-3 space-y-5">

        <!-- PRINCIPAL -->
        <div>
            <p class="text-[9px] font-black text-gray-300 uppercase tracking-[0.22em] px-3 mb-2">Principal</p>
            <div class="space-y-0.5">

                <a href="/admin/dashboard"
                   class="flex items-center gap-3 px-3 py-2.5 rounded-xl transition-all duration-150 group
                          <%= (typeof title !== 'undefined' && title.includes('Panel')) ? 'bg-gray-100 text-gray-900 font-bold' : 'text-gray-500 font-medium hover:bg-gray-50 hover:text-slate-800' %>">
                    <svg style="width:18px;height:18px;flex-shrink:0;" fill="none" stroke="currentColor" viewBox="0 0 24 24"
                         class="<%= (typeof title !== 'undefined' && title.includes('Panel')) ? 'text-gray-700' : 'text-gray-300 group-hover:text-gray-500' %>">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zM14 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z"/>
                    </svg>
                    <span class="text-sm">Dashboard</span>
                </a>
            </div>
        </div>

        <!-- GESTIÓN -->
        <div>
            <p class="text-[9px] font-black text-gray-300 uppercase tracking-[0.22em] px-3 mb-2">Gestión</p>
            <div class="space-y-0.5">

                <a href="/admin/equipodevoluntarios"
                   class="flex items-center gap-3 px-3 py-2.5 rounded-xl transition-all duration-150 group
                          <%= (typeof title !== 'undefined' && title.includes('Equipo')) ? 'bg-gray-100 text-gray-900 font-bold' : 'text-gray-500 font-medium hover:bg-gray-50 hover:text-slate-800' %>">
                    <svg style="width:18px;height:18px;flex-shrink:0;" fill="none" stroke="currentColor" viewBox="0 0 24 24"
                         class="<%= (typeof title !== 'undefined' && title.includes('Equipo')) ? 'text-gray-700' : 'text-gray-300 group-hover:text-gray-500' %>">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"/>
                    </svg>
                    <span class="text-sm">Equipo Staff</span>
                </a>

                <!-- CUENTAS - Solo visible para Administradores -->
                <% if (user && user.role === 'admin') { %>
                <a href="/admin/cuentas"
                   class="flex items-center gap-3 px-3 py-2.5 rounded-xl transition-all duration-150 group
                          <%= (typeof title !== 'undefined' && title.includes('Cuentas')) ? 'bg-gray-100 text-gray-900 font-bold' : 'text-gray-500 font-medium hover:bg-gray-50 hover:text-slate-800' %>">
                    <svg style="width:18px;height:18px;flex-shrink:0;" fill="none" stroke="currentColor" viewBox="0 0 24 24"
                         class="<%= (typeof title !== 'undefined' && title.includes('Cuentas')) ? 'text-gray-700' : 'text-gray-300 group-hover:text-gray-500' %>">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 7a2 2 0 012 2m4 0a6 6 0 01-7.743 5.743L11 17H9v2H7v2H4a1 1 0 01-1-1v-2.586a1 1 0 01.293-.707l5.964-5.964A6 6 0 1121 9z"/>
                    </svg>
                    <span class="text-sm">Cuentas</span>
                </a>
                <% } %>
            </div>
        </div>

        <!-- PÁGINAS DEL SITIO -->
        <div>
            <p class="text-[9px] font-black text-gray-300 uppercase tracking-[0.22em] px-3 mb-2">Páginas del Sitio</p>
            <div class="space-y-0.5">
                <% [
                    { 
                        href: '/admin/paginas/inicio', 
                        label: 'Inicio', 
                        match: 'Página de Inicio',
                        icon: 'M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6'
                    },
                    { 
                        href: '/admin/paginas/autoridades', 
                        label: 'Autoridades', 
                        match: 'Página de Autoridades',
                        icon: 'M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z'
                    },
                    { 
                        href: '/admin/paginas/voluntarios', 
                        label: 'Voluntarios', 
                        match: 'Página de Voluntarios',
                        icon: 'M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z'
                    },
                    { 
                        href: '/admin/paginas/cronograma', 
                        label: 'Cronograma', 
                        match: 'Página de Cronograma',
                        icon: 'M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z'
                    },
                    { 
                        href: '/admin/paginas/organos', 
                        label: 'Órganos', 
                        match: 'Página de Órganos',
                        icon: 'M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4'
                    },
                    { 
                        href: '/admin/paginas/participacion', 
                        label: 'Participación', 
                        match: 'Página de Participación',
                        icon: 'M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z'
                    },
                    { 
                        href: '/admin/paginas/global', 
                        label: 'Navbar & Footer', 
                        match: 'Navbar & Footer',
                        icon: 'M4 5a1 1 0 011-1h14a1 1 0 011 1v2a1 1 0 01-1 1H5a1 1 0 01-1-1V5zM4 13a1 1 0 011-1h6a1 1 0 011 1v6a1 1 0 01-1 1H5a1 1 0 01-1-1v-6zM16 13a1 1 0 011-1h2a1 1 0 011 1v6a1 1 0 01-1 1h-2a1 1 0 01-1-1v-6z'
                    },
                ].forEach(item => {
                    const isActive = typeof title !== 'undefined' && title.includes(item.match);
                %>
                <a href="<%= item.href %>"
                   class="flex items-center gap-3 px-3 py-2.5 rounded-xl transition-all duration-150 group
                          <%= isActive ? 'bg-gray-100 text-gray-900 font-bold' : 'text-gray-500 font-medium hover:bg-gray-50 hover:text-slate-800' %>">
                    <svg style="width:18px;height:18px;flex-shrink:0;" fill="none" stroke="currentColor" viewBox="0 0 24 24"
                         class="<%= isActive ? 'text-gray-700' : 'text-gray-300 group-hover:text-gray-500' %>">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="<%= item.icon %>"/>
                    </svg>
                    <span class="text-sm"><%= item.label %></span>
                </a>
                <% }); %>
            </div>
        </div>

        <!-- INSCRIPCIONES -->
        <div>
            <p class="text-[9px] font-black text-gray-300 uppercase tracking-[0.22em] px-3 mb-2">Inscripciones</p>
            <div class="space-y-0.5">
                <% [
                    { 
                        href: '/admin/inscripciones/voluntario', 
                        label: 'Voluntarios', 
                        match: 'Inscripciones: Voluntarios',
                        icon: 'M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z'
                    },
                    { 
                        href: '/admin/inscripciones/escuela', 
                        label: 'Colegios', 
                        match: 'Inscripciones: Colegios',
                        icon: 'M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4'
                    },
                    { 
                        href: '/admin/inscripciones/autoridad', 
                        label: 'Autoridades', 
                        match: 'Inscripciones: Autoridades',
                        icon: 'M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z'
                    },
                    { 
                        href: '/admin/inscripciones/delegado', 
                        label: 'Delegados', 
                        match: 'Inscripciones: Delegados',
                        icon: 'M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z'
                    },
                ].forEach(item => { %>
                <%
                    const isActive = typeof title !== 'undefined' && title.includes(item.match);
                %>
                <a href="<%= item.href %>"
                   class="flex items-center gap-3 px-3 py-2.5 rounded-xl transition-all duration-150 group
                          <%= isActive ? 'bg-gray-100 text-gray-900 font-bold' : 'text-gray-500 font-medium hover:bg-gray-50 hover:text-slate-800' %>">
                    <svg style="width:18px;height:18px;flex-shrink:0;" fill="none" stroke="currentColor" viewBox="0 0 24 24"
                         class="<%= isActive ? 'text-gray-700' : 'text-gray-300 group-hover:text-gray-500' %>">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="<%= item.icon %>"/>
                    </svg>
                    <span class="text-sm"><%= item.label %></span>
                </a>
                <% }); %>
            </div>
        </div>

    </div>

    <!-- Footer -->
    <div class="p-3 border-t border-gray-100">
        <a href="/" target="_blank"
           class="flex items-center justify-center gap-2 px-4 py-2.5 rounded-xl text-xs font-bold text-gray-400 hover:text-slate-700 hover:bg-gray-50 transition-all">
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
            </svg>
            Ver sitio web
        </a>
    </div>
</aside>
