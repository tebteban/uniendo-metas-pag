<script>
// Submit CRUD forms independently (bypassing the outer settings form to avoid siteUpload filter)
function submitCrudDiv(divId) {
    const div = document.getElementById(divId);
    if (!div) { console.error('CRUD div not found:', divId); return; }
    const action = div.dataset.action;

    // Validar campos requeridos
    const requiredMap = { 'crud-cron-form': ['day','date','time','activity'], 'crud-org-form': ['name'] };
    for (const fieldName of (requiredMap[divId] || [])) {
        const el = div.querySelector('[name="' + fieldName + '"]');
        if (el && !el.value.trim()) {
            el.focus();
            el.style.borderColor = '#ef4444';
            el.style.boxShadow = '0 0 0 3px rgba(239,68,68,0.15)';
            setTimeout(() => { el.style.borderColor = ''; el.style.boxShadow = ''; }, 2500);
            return;
        }
    }

    // Crear un form real fuera del DOM y hacer submit nativo
    // (evita problemas de forms anidados y de fetch con multipart)
    const tmpForm = document.createElement('form');
    tmpForm.method = 'POST';
    tmpForm.action = action;
    tmpForm.style.display = 'none';

    const hasFiles = div.querySelectorAll('input[type="file"]').length > 0;
    if (hasFiles) tmpForm.enctype = 'multipart/form-data';

    div.querySelectorAll('input, select, textarea').forEach(el => {
        if (!el.name) return;
        if (el.type === 'file') {
            // Para archivos: mover el input al form temporal
            // (clonar no funciona para files, hay que moverlo y reponerlo)
            const clone = el.cloneNode(true);
            // Transferir los archivos via DataTransfer si es posible
            if (el.files && el.files.length > 0 && typeof DataTransfer !== 'undefined') {
                const dt = new DataTransfer();
                Array.from(el.files).forEach(f => dt.items.add(f));
                clone.files = dt.files;
            }
            tmpForm.appendChild(clone);
        } else if (el.type === 'checkbox') {
            const hidden = document.createElement('input');
            hidden.type = 'hidden';
            hidden.name = el.name;
            hidden.value = el.checked ? 'true' : 'false';
            tmpForm.appendChild(hidden);
        } else {
            const hidden = document.createElement('input');
            hidden.type = 'hidden';
            hidden.name = el.name;
            hidden.value = el.value;
            tmpForm.appendChild(hidden);
        }
    });

    document.body.appendChild(tmpForm);
    tmpForm.submit();
}

// ═══════════════════════════════════════════════════════════════════
// QUILL.JS - WYSIWYG EDITOR INITIALIZATION
// ═══════════════════════════════════════════════════════════════════

const quillEditors = new Map();

function initQuillEditors() {
    // Find all textareas
    document.querySelectorAll('textarea').forEach(textarea => {
        // Skip if already initialized
        if (textarea.classList.contains('quill-hidden')) return;
        
        // Skip file input textareas or very small ones
        if (textarea.rows === 1 || textarea.classList.contains('no-quill')) return;
        
        // Create wrapper
        const wrapper = document.createElement('div');
        wrapper.className = 'quill-wrapper';
        
        // Create editor div
        const editorDiv = document.createElement('div');
        editorDiv.innerHTML = textarea.value || '';
        wrapper.appendChild(editorDiv);
        
        // Insert wrapper before textarea
        textarea.parentNode.insertBefore(wrapper, textarea);
        
        // Hide original textarea
        textarea.classList.add('quill-hidden');
        
        // Initialize Quill
        const quill = new Quill(editorDiv, {
            theme: 'snow',
            modules: {
                toolbar: [
                    ['bold', 'italic', 'underline', 'strike'],
                    ['blockquote', 'code-block'],
                    [{ 'header': 1 }, { 'header': 2 }],
                    [{ 'list': 'ordered'}, { 'list': 'bullet' }],
                    [{ 'indent': '-1'}, { 'indent': '+1' }],
                    [{ 'color': [] }, { 'background': [] }],
                    [{ 'align': [] }],
                    ['link'],
                    ['clean']
                ]
            },
            placeholder: textarea.placeholder || 'Escribí tu contenido aquí...'
        });
        
        // Store Quill instance
        quillEditors.set(textarea, quill);
        
        // Update data-original to match Quill's HTML format
        // This ensures markDirty() works correctly
        const initialHTML = quill.root.innerHTML;
        textarea.value = initialHTML;
        textarea.dataset.original = initialHTML;
        
        // Sync changes back to textarea
        quill.on('text-change', function() {
            const newValue = quill.root.innerHTML;
            textarea.value = newValue;
            
            // Find the wrapper with id and data-section
            const fieldWrapper = textarea.closest('[data-section]');
            if (fieldWrapper) {
                const fieldId = fieldWrapper.id;
                const sectionId = fieldWrapper.dataset.section;
                
                if (fieldId && sectionId && typeof markDirty === 'function') {
                    markDirty(fieldId, sectionId);
                }
            }
        });
        
        // Handle oninput if exists
        if (textarea.hasAttribute('oninput')) {
            quill.on('text-change', function() {
                const onInputAttr = textarea.getAttribute('oninput');
                try {
                    eval(onInputAttr);
                } catch (e) {
                    console.error('Error executing oninput:', e);
                }
            });
        }
    });
}
                } catch (e) {
                    console.error('Error executing oninput:', e);
                }
            });
        }
    });
}

// Initialize on page load
document.addEventListener('DOMContentLoaded', initQuillEditors);

// Re-initialize when dynamic content is added (for FAQ, sponsors, etc.)
const originalAddSponsor = window.addSponsor;
if (typeof originalAddSponsor === 'function') {
    window.addSponsor = function() {
        originalAddSponsor();
        setTimeout(initQuillEditors, 100);
    };
}

const originalAddExtraFaq = window.addExtraFaq;
if (typeof originalAddExtraFaq === 'function') {
    window.addExtraFaq = function() {
        originalAddExtraFaq();
        setTimeout(initQuillEditors, 100);
    };
}

</script>

