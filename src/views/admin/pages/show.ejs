}

function updateDynCount(sectionId) {
    const grid = document.getElementById('dyn-grid-' + sectionId);
    const count = grid ? grid.querySelectorAll('.dyn-img-card').length : 0;
    const el = document.getElementById('dyn-count-' + sectionId);
    if (el) el.textContent = count;
}

