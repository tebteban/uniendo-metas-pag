<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> — Admin</title>
    <link rel="icon" type="image/png" href="/img/descarga.png">
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Montserrat', sans-serif; }
        .scroll-list::-webkit-scrollbar { width: 4px; }
        .scroll-list::-webkit-scrollbar-track { background: transparent; }
        .scroll-list::-webkit-scrollbar-thumb { background: #e2e8f0; border-radius: 99px; }
        .scroll-list::-webkit-scrollbar-thumb:hover { background: #cbd5e1; }
    </style>
</head>
<body class="bg-slate-50 text-slate-800 overflow-x-hidden">

<%- include('../partials/navbar') %>

<div class="pt-20 flex min-h-screen">
    <%- include('../partials/sidebar') %>

    <main class="flex-1 md:ml-64 px-4 py-6 md:p-8">
        <div class="max-w-5xl mx-auto space-y-8">

            <!-- Header -->
            <div class="flex items-start justify-between">
                <div>
                    <span class="text-[11px] font-black text-slate-400 uppercase tracking-widest">Herramientas</span>
                    <h1 class="text-2xl md:text-3xl font-black text-slate-900 tracking-tight mt-1">Certificados</h1>
                    <p class="text-sm text-gray-400 font-medium mt-1">
                        Generá, descargá y enviá los certificados de participación por mail.
                    </p>
                </div>
                <div class="hidden md:flex items-center justify-center w-12 h-12 rounded-2xl bg-slate-100 flex-shrink-0">
                    <svg class="w-6 h-6 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                            d="M9 12l2 2 4-4M7 4H5a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2V6a2 2 0 00-2-2h-2M9 4h6a1 1 0 010 2H9a1 1 0 010-2z"/>
                    </svg>
                </div>
            </div>

            <!-- Flash message -->
            <% if (locals.flash) { %>
            <div class="px-4 py-3 rounded-xl text-sm font-semibold flex items-center gap-2
              <%= flash.type === 'warning' ? 'bg-yellow-50 text-yellow-700 border border-yellow-200' : 'bg-emerald-50 text-emerald-700 border border-emerald-200' %>">
                <svg class="w-4 h-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                </svg>
                <%= flash.msg %>
            </div>
            <% } %>

            <!-- Toast global -->
            <div id="toast" class="fixed bottom-6 right-6 z-50 hidden max-w-xs">
                <div id="toast-inner" class="flex items-center gap-3 px-4 py-3 rounded-xl shadow-xl text-sm font-semibold text-white">
                    <svg id="toast-icon" class="w-4 h-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"></svg>
                    <span id="toast-text"></span>
                </div>
            </div>

            <%
            const cfg = {
                delegado: {
                    label: 'Delegados',
                    sublabel: 'Participantes del modelo',
                    accent: '#3b82f6',
                    barClass: 'bg-blue-500',
                    btnDl: 'bg-blue-600 hover:bg-blue-700',
                    btnMail: 'border-blue-200 text-blue-600 hover:bg-blue-50',
                    countBg: 'bg-blue-50 text-blue-700',
                    iconPath: 'M12 14l9-5-9-5-9 5 9 5z M12 14l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14z',
                },
                autoridad: {
                    label: 'Autoridades',
                    sublabel: 'Mesa directiva y presidencia',
                    accent: '#dc2626',
                    barClass: 'bg-red-600',
                    btnDl: 'bg-red-700 hover:bg-red-800',
                    btnMail: 'border-red-200 text-red-600 hover:bg-red-50',
                    countBg: 'bg-red-50 text-red-700',
                    iconPath: 'M3 6l3 1m0 0l-3 9a5.002 5.002 0 006.001 0M6 7l3 9M6 7l6-2m6 2l3-1m-3 1l-3 9a5.002 5.002 0 006.001 0M18 7l3 9m-3-9l-6-2m0-2v2m0 16V5m0 16H9m3 0h3',
                },
                voluntario: {
                    label: 'Voluntarios',
                    sublabel: 'Equipo organizador',
                    accent: '#16a34a',
                    barClass: 'bg-green-600',
                    btnDl: 'bg-green-600 hover:bg-green-700',
                    btnMail: 'border-green-200 text-green-600 hover:bg-green-50',
                    countBg: 'bg-green-50 text-green-700',
                    iconPath: 'M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z',
                },
            };
            %>

            <!-- Panel subtítulo -->
            <div class="bg-white rounded-2xl border border-slate-100 shadow-sm overflow-hidden">
                <div class="flex items-center gap-3 px-6 py-4 border-b border-slate-100">
                    <div class="w-9 h-9 rounded-xl bg-violet-50 flex items-center justify-center flex-shrink-0">
                        <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" style="width:18px;height:18px;color:#7c3aed;">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
                        </svg>
                    </div>
                    <div>
                        <h3 class="text-sm font-black text-slate-900">Texto del certificado</h3>
                        <p class="text-[11px] text-slate-400 font-medium">Aparece debajo del nombre. El rol se agrega automáticamente al final en negrita.</p>
                    </div>
                </div>
                <div class="px-6 py-5">
                    <textarea id="subtitulo-input" rows="3"
                        class="w-full px-4 py-3 rounded-xl border border-slate-200 bg-slate-50 text-sm text-slate-700 font-medium resize-none focus:outline-none focus:border-violet-400 focus:ring-2 focus:ring-violet-100 transition"
                    ><%= subtitulo %></textarea>
                    <div class="flex items-center justify-end mt-3">
                        <button onclick="guardarSubtitulo(this)"
                            class="flex items-center gap-2 px-4 py-2 rounded-xl text-white text-xs font-black transition shadow-sm"
                            style="background:#7c3aed;">
                            <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/>
                            </svg>
                            Guardar texto
                        </button>
                    </div>
                </div>
            </div>

            <!-- Panel imagen base -->
            <div class="bg-white rounded-2xl border border-slate-100 shadow-sm overflow-hidden">
                <div class="flex items-center gap-3 px-6 py-4 border-b border-slate-100">
                    <div class="w-9 h-9 rounded-xl bg-amber-50 flex items-center justify-center flex-shrink-0">
                        <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" style="width:18px;height:18px;color:#d97706;">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                        </svg>
                    </div>
                    <div>
                        <h3 class="text-sm font-black text-slate-900">Imagen base del certificado</h3>
                        <p class="text-[11px] text-slate-400 font-medium">Se aplica a todos los tipos (delegado, autoridad, voluntario). Reemplaza a las imágenes locales.</p>
                    </div>
                </div>
                <div class="px-6 py-5">
                    <div class="flex flex-col sm:flex-row gap-4 items-start">
                        <!-- Preview imagen actual -->
                        <div id="img-preview-wrap" class="flex-shrink-0 w-full sm:w-48">
                            <% const imagenEsUrl = locals.imagenBase && (imagenBase.startsWith('http://') || imagenBase.startsWith('https://')); %>
                            <% if (imagenEsUrl) { %>
                                <img id="img-preview" src="<%= imagenBase %>" alt="Imagen base actual"
                                    class="w-full h-28 object-cover rounded-xl border border-slate-200">
                            <% } else if (locals.imagenBase) { %>
                                <!-- Ruta local: la imagen está configurada pero no se puede previsualizar en el browser -->
                                <div class="w-full h-28 rounded-xl border border-amber-200 bg-amber-50 flex flex-col items-center justify-center gap-1">
                                    <svg class="w-6 h-6 text-amber-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                                            d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                                    </svg>
                                    <span class="text-[10px] text-amber-600 font-bold text-center px-2">Imagen configurada<br>(local)</span>
                                </div>
                            <% } else { %>
                                <div id="img-preview-placeholder"
                                    class="w-full h-28 rounded-xl border-2 border-dashed border-slate-200 flex flex-col items-center justify-center gap-1 bg-slate-50">
                                    <svg class="w-6 h-6 text-slate-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                                            d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                                    </svg>
                                    <span class="text-[10px] text-slate-400 font-medium">Sin imagen subida</span>
                                </div>
                            <% } %>
                        </div>
                        <!-- Input y botón -->
                        <div class="flex-1 flex flex-col gap-3">
                            <label class="flex flex-col gap-1">
                                <span class="text-xs font-bold text-slate-600">Subir nueva imagen</span>
                                <input type="file" id="imagen-input" accept="image/*"
                                    class="text-xs text-slate-500 file:mr-3 file:py-1.5 file:px-3 file:rounded-lg file:border-0 file:text-xs file:font-bold file:bg-amber-50 file:text-amber-700 hover:file:bg-amber-100 cursor-pointer">
                                <span class="text-[10px] text-slate-400">JPG o PNG. Recomendado: 1123 × 794 px (horizontal).</span>
                            </label>
                            <div class="flex items-center justify-end">
                                <button onclick="guardarImagenBase(this)"
                                    class="flex items-center gap-2 px-4 py-2 rounded-xl text-white text-xs font-black transition shadow-sm"
                                    style="background:#d97706;">
                                    <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5"
                                            d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/>
                                    </svg>
                                    Subir imagen
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Cards -->
            <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
                <% tipos.forEach(tipo => {
                    const c = cfg[tipo];
                %>
                <div class="bg-white rounded-2xl border border-slate-100 shadow-sm overflow-hidden flex flex-col">

                    <div class="h-1 <%= c.barClass %>"></div>

                    <div class="p-5 flex flex-col flex-1 gap-4">

                        <!-- Header card -->
                        <div class="flex items-center gap-3">
                            <div class="w-10 h-10 rounded-xl flex items-center justify-center flex-shrink-0"
                                 style="background-color: <%= c.accent %>18;">
                                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"
                                     style="color: <%= c.accent %>;">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.75"
                                        d="<%= c.iconPath %>"/>
                                </svg>
                            </div>
                            <div class="flex-1 min-w-0">
                                <h2 class="text-sm font-black text-slate-900 leading-tight"><%= c.label %></h2>
                                <p class="text-[11px] text-slate-400 font-medium truncate"><%= c.sublabel %></p>
                            </div>
                            <span class="text-xs font-black px-2.5 py-1 rounded-lg flex-shrink-0 <%= c.countBg %>">
                                <%= counts[tipo] %>
                            </span>
                        </div>

                        <% if (counts[tipo] === 0) { %>
                            <div class="flex flex-col items-center justify-center py-8 gap-2 flex-1">
                                <div class="w-10 h-10 rounded-full bg-slate-100 flex items-center justify-center">
                                    <svg class="w-5 h-5 text-slate-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                                            d="M20 13V6a2 2 0 00-2-2H6a2 2 0 00-2 2v7m16 0v5a2 2 0 01-2 2H6a2 2 0 01-2-2v-5m16 0h-2.586a1 1 0 00-.707.293l-2.414 2.414a1 1 0 01-.707.293h-3.172a1 1 0 01-.707-.293l-2.414-2.414A1 1 0 006.586 13H4"/>
                                    </svg>
                                </div>
                                <p class="text-xs text-slate-400 font-medium">Sin inscriptos cargados</p>
                            </div>
                        <% } else { %>

                            <div class="border-t border-slate-100"></div>

                            <!-- Acciones bulk -->
                            <div class="flex flex-col gap-2">
                                <a href="/admin/certificados/descargar-todos/<%= tipo %>"
                                   class="flex items-center justify-center gap-2 w-full py-2.5 rounded-xl text-white font-bold text-xs tracking-wide transition shadow-sm <%= c.btnDl %>">
                                    <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5"
                                            d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/>
                                    </svg>
                                    Descargar todos (.zip)
                                </a>

                                <button onclick="enviarTodos('<%= tipo %>', this)"
                                    class="flex items-center justify-center gap-2 w-full py-2.5 rounded-xl border font-bold text-xs tracking-wide transition <%= c.btnMail %>">
                                    <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5"
                                            d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                                    </svg>
                                    Enviar todos por mail
                                </button>
                            </div>

                            <!-- Lista individual -->
                            <div class="flex flex-col gap-2">
                                <p class="text-[10px] font-black uppercase tracking-[0.18em] text-slate-400">Individual</p>
                                <div class="max-h-64 overflow-y-auto scroll-list space-y-1" id="lista-<%= tipo %>">
                                    <% for(let i=0; i<3; i++) { %>
                                    <div class="h-10 rounded-xl bg-slate-100 animate-pulse"></div>
                                    <% } %>
                                </div>
                            </div>

                        <% } %>
                    </div>
                </div>
                <% }); %>
            </div>

        </div>
    </main>
</div>

<script>
// ─── TOAST ────────────────────────────────────────────────────────────────────
function mostrarToast(msg, tipo) {
    const toast = document.getElementById('toast');
    const inner = document.getElementById('toast-inner');
    const icon  = document.getElementById('toast-icon');
    const text  = document.getElementById('toast-text');
    text.textContent = msg;
    if (tipo === 'ok') {
        inner.className = 'flex items-center gap-3 px-4 py-3 rounded-xl shadow-xl text-sm font-semibold text-white bg-slate-800';
        icon.innerHTML  = '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/>';
    } else {
        inner.className = 'flex items-center gap-3 px-4 py-3 rounded-xl shadow-xl text-sm font-semibold text-white bg-red-600';
        icon.innerHTML  = '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M6 18L18 6M6 6l12 12"/>';
    }
    toast.classList.remove('hidden');
    clearTimeout(window._tt);
    window._tt = setTimeout(() => toast.classList.add('hidden'), 4500);
}

// ─── LISTA ────────────────────────────────────────────────────────────────────
async function cargarLista(tipo) {
    const container = document.getElementById(`lista-${tipo}`);
    if (!container) return;
    try {
        const res  = await fetch(`/admin/certificados/lista/${tipo}`);
        const data = await res.json();
        if (!data.length) {
            container.innerHTML = '<p class="text-xs text-slate-400 text-center py-4">Sin inscriptos</p>';
            return;
        }
        container.innerHTML = data.map(p => `
            <div class="flex items-center gap-2 rounded-xl px-3 py-2 border border-slate-100 hover:border-slate-200 hover:bg-slate-50 transition-all group">
                <div class="w-7 h-7 rounded-lg bg-slate-100 flex items-center justify-center flex-shrink-0">
                    <span class="text-[11px] font-black text-slate-400">${(p.name||'?').charAt(0).toUpperCase()}</span>
                </div>
                <div class="flex-1 min-w-0">
                    <p class="text-xs font-bold text-slate-800 truncate leading-tight">${p.name || '—'}</p>
                    <p class="text-[10px] truncate leading-tight ${p.email ? 'text-slate-400' : 'text-red-400 font-semibold'}">
                        ${p.email || 'sin email'}
                    </p>
                </div>
                <div class="flex gap-1 flex-shrink-0 items-center opacity-60 group-hover:opacity-100 transition-opacity">
                    <a href="/admin/certificados/preview/${p.id}" target="_blank" title="Vista previa"
                       class="w-7 h-7 flex items-center justify-center rounded-lg text-slate-500 hover:text-slate-900 hover:bg-slate-100 transition">
                        <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                d="M15 12a3 3 0 11-6 0 3 3 0 016 0zM2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>
                        </svg>
                    </a>
                    <a href="/admin/certificados/descargar/${p.id}" title="Descargar PDF"
                       class="w-7 h-7 flex items-center justify-center rounded-lg text-slate-500 hover:text-slate-900 hover:bg-slate-100 transition">
                        <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/>
                        </svg>
                    </a>
                    ${p.email
                        ? `<button onclick="enviarUno(${p.id}, '${(p.name||'').replace(/'/g,"\\'")}', this)"
                                title="Enviar por mail"
                                class="w-7 h-7 flex items-center justify-center rounded-lg text-indigo-500 hover:text-white hover:bg-indigo-500 border border-indigo-200 hover:border-transparent transition">
                                <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                        d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                                </svg>
                           </button>`
                        : `<span class="w-7 h-7 flex items-center justify-center rounded-lg text-slate-300 border border-slate-200 cursor-not-allowed" title="Sin email">
                               <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                   <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                       d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                               </svg>
                           </span>`
                    }
                </div>
            </div>
        `).join('');
    } catch (e) {
        container.innerHTML = `
            <div class="flex items-center gap-2 px-3 py-2 rounded-xl bg-red-50 border border-red-100">
                <svg class="w-4 h-4 text-red-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                </svg>
                <p class="text-xs text-red-500 font-medium">Error cargando lista</p>
            </div>`;
    }
}

// ─── ENVIAR UNO ───────────────────────────────────────────────────────────────
const SPINNER = `<svg class="w-3.5 h-3.5 animate-spin" fill="none" viewBox="0 0 24 24">
    <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
    <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v8z"></path></svg>`;

async function enviarUno(id, nombre, btn) {
    const orig = btn.innerHTML;
    btn.innerHTML = SPINNER;
    btn.disabled = true;
    try {
        const res  = await fetch(`/admin/certificados/mail/${id}`, { method: 'POST' });
        const data = await res.json();
        if (data.ok) {
            mostrarToast(data.msg, 'ok');
            btn.innerHTML = `<svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>`;
            setTimeout(() => { btn.innerHTML = orig; btn.disabled = false; }, 3000);
        } else {
            mostrarToast(data.msg, 'error');
            btn.innerHTML = orig; btn.disabled = false;
        }
    } catch {
        mostrarToast('Error de red', 'error');
        btn.innerHTML = orig; btn.disabled = false;
    }
}

// ─── ENVIAR TODOS ─────────────────────────────────────────────────────────────
async function enviarTodos(tipo, btn) {
    if (!confirm(`¿Enviar certificados por mail a todos los ${tipo}s con email cargado?`)) return;
    const orig = btn.innerHTML;
    btn.innerHTML = `${SPINNER} <span class="ml-1">Enviando...</span>`;
    btn.disabled = true;
    try {
        const res  = await fetch(`/admin/certificados/mail-todos/${tipo}`, { method: 'POST' });
        const data = await res.json();
        mostrarToast(data.msg, data.ok ? 'ok' : 'error');
    } catch {
        mostrarToast('Error de red', 'error');
    }
    btn.innerHTML = orig;
    btn.disabled = false;
}

// ─── GUARDAR IMAGEN BASE ──────────────────────────────────────────────────────
async function guardarImagenBase(btn) {
    const input = document.getElementById('imagen-input');
    if (!input.files || !input.files[0]) return mostrarToast('Seleccioná una imagen primero', 'error');
    const orig = btn.innerHTML;
    btn.innerHTML = `${SPINNER} <span class="ml-1">Subiendo...</span>`;
    btn.disabled = true;
    try {
        const formData = new FormData();
        formData.append('imagen', input.files[0]);
        const res  = await fetch('/admin/certificados/imagen-base', { method: 'POST', body: formData });
        const data = await res.json();
        if (data.ok) {
            mostrarToast('Imagen actualizada correctamente', 'ok');
            const wrap = document.getElementById('img-preview-wrap');
            if (data.url) {
                // Producción: mostrar imagen desde Cloudinary
                wrap.innerHTML = `<img id="img-preview" src="${data.url}" alt="Imagen base"
                    class="w-full h-28 object-cover rounded-xl border border-slate-200">`;
            } else {
                // Local: mostrar badge "Imagen configurada"
                wrap.innerHTML = `<div class="w-full h-28 rounded-xl border border-amber-200 bg-amber-50 flex flex-col items-center justify-center gap-1">
                    <svg class="w-6 h-6 text-amber-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                            d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                    </svg>
                    <span class="text-[10px] text-amber-600 font-bold text-center px-2">Imagen configurada<br>(local)</span>
                </div>`;
            }
            input.value = '';
        } else {
            mostrarToast(data.msg || 'Error al subir', 'error');
        }
    } catch {
        mostrarToast('Error de red', 'error');
    }
    btn.innerHTML = orig;
    btn.disabled = false;
}

// ─── GUARDAR SUBTÍTULO ────────────────────────────────────────────────────────
async function guardarSubtitulo(btn) {
    const texto = document.getElementById('subtitulo-input').value.trim();
    if (!texto) return mostrarToast('El texto no puede estar vacío', 'error');
    const orig = btn.innerHTML;
    btn.innerHTML = `${SPINNER} <span class="ml-1">Guardando...</span>`;
    btn.disabled = true;
    try {
        const res  = await fetch('/admin/certificados/subtitulo', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ subtitulo: texto }),
        });
        const data = await res.json();
        mostrarToast(data.ok ? '✓ Texto guardado' : data.msg, data.ok ? 'ok' : 'error');
    } catch {
        mostrarToast('Error de red', 'error');
    }
    btn.innerHTML = orig;
    btn.disabled = false;
}

// ─── INIT ─────────────────────────────────────────────────────────────────────
document.addEventListener('DOMContentLoaded', () => {
    ['delegado', 'autoridad', 'voluntario'].forEach(cargarLista);
});
</script>

