<!DOCTYPE html>
<html lang="es" class="scroll-smooth">
<%- include('./partials/head') %>

<style>
    @keyframes scroll {
        0%   { transform: translateX(0); }
        100% { transform: translateX(-50%); }
    }
    .animate-scroll-infinite {
        animation: scroll 45s linear infinite;
    }
    .animate-scroll-infinite:hover {
        animation-play-state: paused;
    }
    #lightbox { transition: opacity 0.3s ease; }
    #lightbox.hidden { opacity: 0; pointer-events: none; }
    #lightbox:not(.hidden) { opacity: 1; pointer-events: auto; }
</style>

<body class="bg-white text-gray-600 antialiased font-sans">

<%- include('./partials/navbar') %>

<!-- ===== HERO ===== -->
<section class="relative pt-36 pb-24 bg-white overflow-hidden">

    <div class="absolute inset-0 pointer-events-none overflow-hidden">
        <div class="absolute top-0 left-1/4 w-[500px] h-[500px] rounded-full opacity-50 blur-[120px]" style="background:#61B4E415;"></div>
        <div class="absolute top-0 right-1/4 w-[500px] h-[500px] rounded-full opacity-50 blur-[100px]" style="background:#A0214010;"></div>
        <div class="absolute bottom-0 left-1/3 w-[400px] h-[400px] rounded-full opacity-40 blur-[80px]" style="background:#FFB81915;"></div>
        <div class="absolute inset-0 opacity-[0.025]" style="background-image: linear-gradient(#000 1px, transparent 1px), linear-gradient(90deg, #000 1px, transparent 1px); background-size: 60px 60px;"></div>
    </div>

    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10 text-center">

        <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-white border border-gray-200 shadow-sm mb-8 cursor-default hover:shadow-md transition-all" data-aos="fade-down">
            <span class="flex h-2 w-2 relative">
                <span class="animate-ping absolute inline-flex h-full w-full rounded-full opacity-75" style="background:#73A950;"></span>
                <span class="relative inline-flex rounded-full h-2 w-2" style="background:#73A950;"></span>
            </span>
            <span class="text-xs font-black tracking-widest text-gray-500 uppercase"><%= settings.text_aut_hero_badge || 'Sumate a la familia' %></span>
        </div>

        <h1 class="text-5xl md:text-6xl lg:text-7xl font-black text-gray-900 mb-6 tracking-tight leading-[1.05]" data-aos="fade-up">
            <%- settings.text_aut_hero_title || 'Viví el modelo<br>' %>
            <span class="text-transparent bg-clip-text bg-gradient-to-r from-brand-blue via-brand-green to-brand-yellow">
                <%= settings.text_aut_hero_highlight || 'desde el corazón.' %>
            </span>
        </h1>

        <p class="text-lg md:text-xl text-gray-500 max-w-2xl mx-auto font-medium leading-relaxed mb-10" data-aos="fade-up" data-aos-delay="100">
            <%= settings.text_aut_hero_desc || 'Ser autoridad es mucho más que moderar un debate. Es hacer amigos, compartir mates en los recreos y ser parte del equipo que hace magia para que todo salga bien.' %>
        </p>

        <div class="flex flex-col sm:flex-row justify-center gap-4" data-aos="fade-up" data-aos-delay="200">
            <a href="<%= settings.link_autoridades_sumarme || '#' %>" target="_blank"
               class="px-9 py-4 text-white font-bold rounded-full hover:-translate-y-1 transition-all duration-300 text-center text-base"
               style="background:#A02140; box-shadow: 0 12px 30px -6px #A0214050;">
                Quiero sumarme
            </a>
            <a href="<%= settings.link_autoridades_fotos || '#legado' %>"
               class="px-9 py-4 bg-white border-2 border-gray-200 text-gray-600 font-bold rounded-full hover:border-gray-300 hover:shadow-md transition-all duration-300 text-center text-base">
                Ver fotos anteriores
            </a>
        </div>
    </div>
</section>

<!-- ===== EXPERIENCIA ===== -->
<section id="experiencia" class="py-24 bg-gray-50 border-t border-gray-100">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">

            <!-- Fotos mosaico -->
            <div class="grid grid-cols-2 gap-4" data-aos="fade-right">
                <div class="space-y-4 mt-10">
                    <div class="overflow-hidden rounded-2xl shadow-md">
                        <img src="<%= settings.auth_hero_1 || 'https://images.unsplash.com/photo-1529156069898-49953e39b3ac?q=80&w=800&fit=crop' %>"
                             class="lightbox-trigger w-full h-56 object-cover hover:scale-105 transition-transform duration-500 cursor-zoom-in"
                             alt="Amigos en el modelo">
                    </div>
                </div>
                <div class="space-y-4">
                    <div class="overflow-hidden rounded-2xl shadow-md">
                        <img src="<%= settings.auth_hero_2 || 'https://images.unsplash.com/photo-1511632765486-a01980e01a18?q=80&w=800&fit=crop' %>"
                             class="lightbox-trigger w-full h-72 object-cover hover:scale-105 transition-transform duration-500 cursor-zoom-in"
                             alt="Staff del modelo">
                    </div>
                </div>
            </div>

            <!-- Texto -->
            <div data-aos="fade-left">
                <span class="inline-block text-xs font-black uppercase tracking-widest mb-4 px-3 py-1.5 rounded-full" style="background:#EDF5E8; color:#73A950;"><%= settings.text_aut_exp_badge || 'La experiencia' %></span>
                <h2 class="text-3xl md:text-5xl font-black text-gray-900 mb-6 leading-tight">
                    <%- settings.text_aut_exp_title || 'Un grupo de amigos<br>' %>
                    <span style="color:#73A950;"><%= settings.text_aut_exp_highlight || 'trabajando juntos.' %></span>
                </h2>
                <p class="text-gray-500 text-lg mb-5 leading-relaxed">
                    <%= settings.text_aut_exp_p1 || 'Olvidate de la presión. Acá venimos a pasarla bien. El staff de autoridades es famoso por ser el grupo más unido del modelo.' %>
                </p>
                <p class="text-gray-500 text-lg mb-8 leading-relaxed">
                    <%= settings.text_aut_exp_p2 || 'No importa si te toca ser Presidente, Ujier o Secretario — lo importante son las anécdotas que te llevás, las risas en las capacitaciones y la satisfacción de ayudar a que los delegados brillen.' %>
                </p>

                <%
                const autExpColors = ['#73A950','#61B4E4','#FFB819'];
                const autExpBgs    = ['#EDF5E8','#E8F5FB','#FEF6E0'];
                const autExpIconPaths = {
                    shield:   'M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z',
                    users:    'M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z',
                    star:     'M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z',
                    heart:    'M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z',
                    mic:      'M19 11a7 7 0 01-7 7m0 0a7 7 0 01-7-7m7 7v4m0 0H8m4 0h4m-4-8a3 3 0 01-3-3V5a3 3 0 116 0v6a3 3 0 01-3 3z',
                    chat:     'M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z',
                    academic: 'M12 14l9-5-9-5-9 5 9 5z M12 14l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0112 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14z',
                    flag:     'M3 21v-4m0 0V5a2 2 0 012-2h6.5l1 1H21l-3 6 3 6h-8.5l-1-1H5a2 2 0 00-2 2zm9-13.5V9',
                    lightbulb:'M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z',
                };
                const autCheckDefs = ['Sin competencia, pura colaboración.','Conocés gente de todos los colegios.','Una experiencia que recordás toda la vida.'];
                const autCheckIconDefs = ['shield','users','star'];
                const autCheckKeys = ['aut_check_1','aut_check_2','aut_check_3'];
                %>
                <div class="space-y-3">
                    <% autCheckKeys.forEach((key, i) => {
                        const text     = settings[key] || autCheckDefs[i];
                        const iconKey  = settings[key + '_icon'] || autCheckIconDefs[i];
                        const iconPath = autExpIconPaths[iconKey] || autExpIconPaths['star'];
                        if (!text) return;
                    %>
                    <div class="flex items-center gap-3">
                        <div class="w-9 h-9 rounded-xl flex items-center justify-center flex-shrink-0" style="background:<%= autExpBgs[i] %>;">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" style="color:<%= autExpColors[i] %>;">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="<%= iconPath %>"/>
                            </svg>
                        </div>
                        <span class="text-gray-700 font-semibold text-base"><%= text %></span>
                    </div>
                    <% }); %>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- ===== GALERÍA / LEGADO ===== -->
<section id="legado" class="py-24 bg-white border-t border-gray-100 overflow-hidden">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mb-14 text-center" data-aos="fade-up">
        <span class="text-xs font-black uppercase tracking-widest" style="color:#61B4E4;"><%= settings.text_aut_legado_badge || 'Nuestra Historia' %></span>
        <h2 class="text-3xl md:text-4xl font-black text-gray-900 mt-3 mb-4"><%= settings.text_aut_legado_title || 'El Legado del Equipo' %></h2>
        <p class="text-gray-500 max-w-xl mx-auto text-lg"><%= settings.text_aut_legado_desc || 'Miles de historias, un solo espíritu. Así disfrutaron las camadas anteriores.' %></p>
    </div>

    <div class="relative w-full">
        <!-- Fades laterales -->
        <div class="absolute left-0 top-0 bottom-0 w-24 z-10 pointer-events-none" style="background: linear-gradient(to right, white, transparent);"></div>
        <div class="absolute right-0 top-0 bottom-0 w-24 z-10 pointer-events-none" style="background: linear-gradient(to left, white, transparent);"></div>

        <div class="flex overflow-hidden w-full">
            <div class="flex animate-scroll-infinite gap-5" id="gallery-container">
                <%
                    const legacyKeys = Object.keys(settings).filter(k => k.startsWith('auth_legacy_') && settings[k]).sort();
                    const fallbackLegacy = ['/img/autoridades/foto1.jpg','/img/autoridades/foto2.jpg','/img/autoridades/foto3.jpg','/img/autoridades/foto4.jpg','/img/autoridades/foto5.jpg'];
                    const legacyImages = legacyKeys.length > 0 ? legacyKeys.map(k => settings[k]) : fallbackLegacy;
                %>
                <% for (let i = 0; i < 2; i++) { %>
                    <% for (const imgSrc of legacyImages) { %>
                    <div class="flex-shrink-0 overflow-hidden rounded-2xl shadow-sm">
                        <img src="<%= imgSrc %>"
                             onerror="this.src='https://images.unsplash.com/photo-1523240795612-9a054b0db644?w=400&h=400&fit=crop'"
                             class="lightbox-trigger w-64 h-64 object-cover hover:scale-105 transition-transform duration-500 cursor-zoom-in"
                             alt="Legado">
                    </div>
                    <% } %>
                <% } %>
            </div>
        </div>
    </div>
</section>

<!-- ===== ROLES ===== -->
<section id="roles" class="py-24 bg-gray-50 border-t border-gray-100">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

        <div class="text-center mb-16" data-aos="fade-up">
            <span class="text-xs font-black uppercase tracking-widest text-gray-400 mb-3 block"><%= settings.text_aut_roles_badge || 'Tu lugar en el equipo' %></span>
            <h2 class="text-3xl md:text-4xl font-black text-gray-900 mb-4"><%= settings.text_aut_roles_title || '¿Desde dónde te gustaría participar?' %></h2>
            <p class="text-gray-500 max-w-2xl mx-auto text-lg"><%= settings.text_aut_roles_desc || 'Todos estos roles forman parte del mismo equipo. En las capacitaciones veremos juntos cuál es el ideal para vos.' %></p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-5">

            <%
            const rolIconPaths = {
                mic:      'M19 11a7 7 0 01-7 7m0 0a7 7 0 01-7-7m7 7v4m0 0H8m4 0h4m-4-8a3 3 0 01-3-3V5a3 3 0 116 0v6a3 3 0 01-3 3z',
                lightbulb:'M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z',
                users:    'M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z',
                globe:    'M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z',
                star:     'M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z',
                heart:    'M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z',
                academic: 'M12 14l9-5-9-5-9 5 9 5z M12 14l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0112 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14z',
                chart:    'M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z',
                shield:   'M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z',
                chat:     'M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z',
                pencil:   'M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z',
                flag:     'M3 21v-4m0 0V5a2 2 0 012-2h6.5l1 1H21l-3 6 3 6h-8.5l-1-1H5a2 2 0 00-2 2zm9-13.5V9',
                building: 'M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4',
                send:     'M12 19l9 2-9-18-9 18 9-2zm0 0v-8',
            };
            %>
            <%
            const rolDefs = [
                { tKey:'aut_rol_1_title', dKey:'aut_rol_1_desc', iKey:'aut_rol_1_icon',
                  defT:'Secretaría General', defD:'El corazón del modelo. Coordinan que todo funcione, apoyan a las demás autoridades y garantizan que todos la pasen bien.', defI:'building',
                  color:'#A02140', bg:'#F9E8EC' },
                { tKey:'aut_rol_2_title', dKey:'aut_rol_2_desc', iKey:'aut_rol_2_icon',
                  defT:'Presidencia', defD:'Quienes guían el debate. Se aseguran de que todos hablen, se respeten los turnos y el intercambio fluya con buena onda.', defI:'chat',
                  color:'#61B4E4', bg:'#E8F5FB' },
                { tKey:'aut_rol_3_title', dKey:'aut_rol_3_desc', iKey:'aut_rol_3_icon',
                  defT:'Consejeros', defD:'Fundamentales en el Consejo de Seguridad. Ayudan a redactar las ideas y dan soporte técnico a los delegados.', defI:'pencil',
                  color:'#E15829', bg:'#FCEEE9' },
                { tKey:'aut_rol_4_title', dKey:'aut_rol_4_desc', iKey:'aut_rol_4_icon',
                  defT:'Ujieres', defD:'El alma de la sala. Llevan los mensajes y ayudan con la organización del espacio.', defI:'send',
                  color:'#73A950', bg:'#EDF5E8' },
            ];
            rolDefs.forEach((rol, i) => {
                rol.title    = settings[rol.tKey] || rol.defT;
                rol.desc     = settings[rol.dKey] || rol.defD;
                rol.iconKey  = settings[rol.iKey] || rol.defI;
                rol.iconPath = rolIconPaths[rol.iconKey] || rolIconPaths['star'];
            });
            %>
            <% rolDefs.forEach((rol, i) => { %>
            <div class="relative bg-white rounded-3xl p-8 border border-gray-100 hover:shadow-xl hover:-translate-y-2 transition-all duration-300 group overflow-hidden" data-aos="fade-up" data-aos-delay="<%= i * 80 %>">
                <% if (rol.badge) { %>
                <div class="absolute top-0 right-0 text-[10px] font-black uppercase tracking-wider px-3 py-1.5 rounded-bl-2xl" style="background:<%= rol.bg %>; color:<%= rol.color %>;">
                    <%= rol.badge %>
                </div>
                <% } %>
                <div class="w-12 h-12 rounded-2xl flex items-center justify-center mb-5 group-hover:scale-110 transition-transform duration-300" style="background:<%= rol.bg %>;">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" style="color:<%= rol.color %>;">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="<%= rol.iconPath %>"/>
                    </svg>
                </div>
                <h3 class="text-lg font-black text-gray-900 mb-3"><%= rol.title %></h3>
                <p class="text-sm text-gray-500 leading-relaxed"><%= rol.desc %></p>
            </div>
            <% }); %>

        </div>
    </div>
</section>

<!-- ===== CAPACITACIÓN ===== -->
<section class="py-24 bg-white border-t border-gray-100">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

        <div class="text-center mb-16 max-w-3xl mx-auto" data-aos="fade-up">
            <span class="inline-block px-4 py-1.5 rounded-full font-bold tracking-widest uppercase text-xs mb-5 border" style="background:#E8F5FB; color:#61B4E4; border-color:#61B4E430;">
                <%= settings.text_aut_cap_badge || 'Formación y Metodología' %>
            </span>
            <h2 class="text-3xl md:text-4xl font-black text-gray-900 mb-5 leading-tight">
                <%- settings.text_aut_cap_title || 'Aprendemos juntos,<br>a tu ritmo.' %>
            </h2>
            <p class="text-gray-500 text-lg leading-relaxed">
                <%= settings.text_aut_cap_desc || 'Nuestro sistema de capacitación está diseñado para que disfrutes aprendiendo. No importa si es tu primera vez — te acompañamos hasta que te sentís listo.' %>
            </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-16">
            <%
            const capDefs = [
                { tKey:'aut_cap_1_title', dKey:'aut_cap_1_desc', defT:'Encuentros Virtuales',  defD:'Clases teóricas por Zoom. Ideales para entender los conceptos básicos desde tu casa.', color:'#61B4E4', bg:'#E8F5FB', icon:'M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z' },
                { tKey:'aut_cap_2_title', dKey:'aut_cap_2_desc', defT:'Prácticas Presenciales', defD:'Simulacros de debate. El momento de perder la vergüenza y conocer al equipo.', color:'#E15829', bg:'#FCEEE9', icon:'M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z' },
                { tKey:'aut_cap_3_title', dKey:'aut_cap_3_desc', defT:'Instancia Final',       defD:'Un pequeño examen para validar lo aprendido. Si participaste activamente, lo pasás seguro.', color:'#73A950', bg:'#EDF5E8', icon:'M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4' },
            ];
            %>
            <% capDefs.forEach((item, i) => {
                item.title = settings[item.tKey] || item.defT;
                item.desc  = settings[item.dKey] || item.defD;
            %>
            <div class="bg-white rounded-2xl p-7 text-center border border-gray-100 shadow-sm hover:shadow-lg transition-all duration-300 group" data-aos="fade-up" data-aos-delay="<%= i * 80 %>">
                <div class="w-14 h-14 mx-auto rounded-2xl flex items-center justify-center mb-5 group-hover:scale-110 transition-transform" style="background:<%= item.bg %>;">
                    <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24" style="color:<%= item.color %>;">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="<%= item.icon %>"/>
                    </svg>
                </div>
                <h3 class="font-black text-lg text-gray-900 mb-2"><%= item.title %></h3>
                <p class="text-sm text-gray-500 leading-relaxed"><%= item.desc %></p>
            </div>
            <% }); %>
        </div>

        <!-- Biblioteca Digital -->
        <%
        const bibItems = [];
        for (let bi = 1; bi <= 6; bi++) {
            const bName = settings['bib_' + bi + '_name'];
            const bFile = settings['bib_' + bi + '_file'];
            const bDesc = settings['bib_' + bi + '_desc'] || '';
            const bIcon = settings['bib_' + bi + '_icon'] || 'academic';
            if (bName && bFile) bibItems.push({ n: bi, name: bName, file: bFile, desc: bDesc, icon: bIcon });
        }
        const bibColors = ['#61B4E4','#73A950','#A02140','#E15829','#FFB819','#8A8A8D'];
        %>
        <% if (bibItems.length > 0) { %>
        <div class="max-w-4xl mx-auto" data-aos="fade-up">
            <div class="flex items-center gap-4 mb-8">
                <div class="flex-1 h-px bg-gray-100"></div>
                <span class="text-sm font-black uppercase tracking-widest text-gray-300">Biblioteca Digital</span>
                <div class="flex-1 h-px bg-gray-100"></div>
            </div>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
                <% bibItems.forEach((item, idx) => {
                    const bColor = bibColors[idx % bibColors.length];
                    const bIconPath = rolIconPaths[item.icon] || rolIconPaths['academic'];
                %>
                <a href="<%= item.file %>" download
                   class="group flex items-center gap-5 p-6 rounded-2xl bg-gray-50 border border-gray-100 hover:bg-white hover:shadow-xl transition-all duration-300">
                    <div class="w-14 h-14 rounded-xl bg-white border border-gray-100 flex-shrink-0 flex items-center justify-center shadow-sm group-hover:scale-110 transition-transform" style="color:<%= bColor %>;">
                        <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="<%= bIconPath %>"/>
                        </svg>
                    </div>
                    <div>
                        <h4 class="text-base font-black text-gray-900 mb-1 transition-colors"><%= item.name %></h4>
                        <% if (item.desc) { %>
                        <p class="text-sm text-gray-400"><%= item.desc %></p>
                        <% } %>
                        <span class="inline-flex items-center gap-1 mt-2 text-xs font-bold uppercase tracking-wide" style="color:<%= bColor %>;">
                            Descargar
                            <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"/></svg>
                        </span>
                    </div>
                </a>
                <% }); %>
            </div>
        </div>
        <% } %>
    </div>
</section>

<!-- ===== FAQ ===== -->
<section class="py-24 bg-gray-50 border-t border-gray-100">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">

        <div class="text-center mb-14" data-aos="fade-up">
            <span class="text-xs font-black uppercase tracking-widest text-gray-400 mb-3 block">Ayuda</span>
            <h2 class="text-3xl md:text-4xl font-black text-gray-900 mb-3">Preguntas Frecuentes</h2>
            <p class="text-gray-500 text-lg">Todo lo que necesitás saber antes de inscribirte.</p>
        </div>

        <div class="space-y-3" data-aos="fade-up">
            <%
            const autFaqDefs = [
                { q:'¿Tengo que saber mucho para inscribirme?', a:'¡Para nada! Lo único que necesitás son ganas y compromiso. Nosotros te enseñamos todo en las capacitaciones.' },
                { q:'Si soy de 1er o 2do año, ¿puedo participar?', a:'¡Sí! El rol de Ujier está pensado especialmente para los primeros años.' },
                { q:'¿Me ocupa mucho tiempo ser autoridad?', a:'Las capacitaciones son pocas — usualmente 3 o 4 encuentros — y tratamos de hacerlas en horarios que no interrumpan tus clases.' },
                { q:'¿Me anoto solo o con amigos?', a:'La inscripción es individual, ¡pero invitá a tus amigos! Van a compartir todas las capacitaciones juntos.' },
                { q:'¿Cómo tengo que ir vestido?', a:'Durante el Modelo la vestimenta es formal. Para capacitaciones previas podés ir con ropa casual.' },
                { q:'¿Recibo algún certificado?', a:'¡Sí! Se entrega un diploma oficial certificado por Asociación Conciencia y Uniendo Metas.' },
            ];
            const autFaqItems = autFaqDefs.map((def, i) => ({
                q: settings['aut_faq_' + (i+1) + '_q'] || def.q,
                a: settings['aut_faq_' + (i+1) + '_a'] || def.a,
            })).filter(item => item.q);
            %>
            <% autFaqItems.forEach((item, i) => { %>
            <div class="bg-white rounded-2xl border border-gray-100 overflow-hidden shadow-sm hover:shadow-md transition-shadow duration-200">
                <button class="w-full px-6 py-5 text-left flex justify-between items-center gap-4 hover:bg-gray-50/50 transition-colors"
                        onclick="toggleFaq('afaq<%= i %>')">
                    <span class="font-bold text-gray-800 text-base leading-snug"><%= item.q %></span>
                    <svg id="icon-afaq<%= i %>" class="w-4 h-4 flex-shrink-0 transform transition-transform duration-300" style="color:#A02140;"
                         fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7"/>
                    </svg>
                </button>
                <div id="afaq<%= i %>" class="hidden px-6 pb-5 text-gray-500 text-sm leading-relaxed border-t border-gray-50 pt-4">
                    <%= item.a %>
                </div>
            </div>
            <% }); %>
            <!-- Preguntas extra -->
            <% for (let ei = 1; ei <= 5; ei++) {
                const eq = settings['aut_faq_extra' + ei + '_q'];
                const ea = settings['aut_faq_extra' + ei + '_a'];
                if (!eq || !eq.trim()) continue;
            %>
            <div class="bg-white rounded-2xl border border-gray-100 overflow-hidden shadow-sm hover:shadow-md transition-shadow duration-200">
                <button class="w-full px-6 py-5 text-left flex justify-between items-center gap-4 hover:bg-gray-50/50 transition-colors"
                        onclick="toggleFaq('afaqex<%= ei %>')">
                    <span class="font-bold text-gray-800 text-base leading-snug"><%= eq %></span>
                    <svg id="icon-afaqex<%= ei %>" class="w-4 h-4 flex-shrink-0 transform transition-transform duration-300" style="color:#A02140;"
                         fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7"/>
                    </svg>
                </button>
                <div id="afaqex<%= ei %>" class="hidden px-6 pb-5 text-gray-500 text-sm leading-relaxed border-t border-gray-50 pt-4">
                    <%= ea || '' %>
                </div>
            </div>
            <% } %>
        </div>

        <!-- CTA final -->
        <div class="mt-14 text-center" data-aos="fade-up">
            <p class="text-gray-500 mb-5 text-lg">¿Listo para sumarte?</p>
            <a href="<%= settings.link_autoridades_sumarme || '#' %>" target="_blank"
               class="inline-flex items-center gap-3 px-9 py-4 text-white font-bold rounded-full hover:scale-105 hover:brightness-110 transition-all duration-300 text-base"
               style="background:#A02140; box-shadow: 0 8px 24px -4px #A0214050;">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18 9v3m0 0v3m0-3h3m-3 0h-3m-2-5a4 4 0 11-8 0 4 4 0 018 0zM3 20a6 6 0 0112 0v1H3v-1z"/>
                </svg>
                Quiero ser autoridad
            </a>
        </div>

    </div>
</section>

<%- include('./partials/footer') %>

<!-- Lightbox -->
<div id="lightbox" class="fixed inset-0 z-[200] bg-black/90 hidden flex items-center justify-center p-4 backdrop-blur-sm" onclick="closeLightbox()">
    <button class="absolute top-5 right-5 text-white/70 hover:text-white p-2 rounded-full hover:bg-white/10 transition z-50" onclick="closeLightbox()">
        <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
    </button>
    <button id="lightbox-prev" class="absolute left-2 md:left-4 text-white/70 hover:text-white p-2 md:p-3 rounded-full bg-black/20 hover:bg-white/20 transition z-50 flex items-center justify-center">
        <svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
    </button>
    <img id="lightbox-img" src="" class="max-w-full max-h-[90vh] rounded-xl shadow-2xl transform transition-transform duration-300 scale-95" alt="Full screen">
    <button id="lightbox-next" class="absolute right-2 md:right-4 text-white/70 hover:text-white p-2 md:p-3 rounded-full bg-black/20 hover:bg-white/20 transition z-50 flex items-center justify-center">
        <svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
    </button>
</div>

<script src="https://unpkg.com/aos@2.3.1/dist/aos.js"></script>
<script>
    AOS.init({ once: true, offset: 50, duration: 700, easing: 'ease-out-quart' });

    // Lightbox
    const lightbox     = document.getElementById('lightbox');
    const lightboxImg  = document.getElementById('lightbox-img');
    const allImgs      = Array.from(document.querySelectorAll('.lightbox-trigger'));
    let currentIndex   = 0;

    allImgs.forEach((img, index) => {
        img.addEventListener('click', e => {
            e.stopPropagation();
            currentIndex = index;
            lightboxImg.src = allImgs[currentIndex].src;
            lightbox.classList.remove('hidden');
            setTimeout(() => lightboxImg.classList.replace('scale-95', 'scale-100'), 10);
        });
    });

    function closeLightbox() {
        lightboxImg.classList.replace('scale-100', 'scale-95');
        setTimeout(() => lightbox.classList.add('hidden'), 200);
    }

    function nextImage(e) { if (e) e.stopPropagation(); currentIndex = (currentIndex + 1) % allImgs.length; lightboxImg.src = allImgs[currentIndex].src; }
    function prevImage(e) { if (e) e.stopPropagation(); currentIndex = (currentIndex - 1 + allImgs.length) % allImgs.length; lightboxImg.src = allImgs[currentIndex].src; }

    document.getElementById('lightbox-next')?.addEventListener('click', nextImage);
    document.getElementById('lightbox-prev')?.addEventListener('click', prevImage);
    document.addEventListener('keydown', e => {
        if (!lightbox.classList.contains('hidden')) {
            if (e.key === 'Escape')     closeLightbox();
            if (e.key === 'ArrowRight') nextImage();
            if (e.key === 'ArrowLeft')  prevImage();
        }
    });

    // FAQ
    function toggleFaq(id) {
        const content = document.getElementById(id);
        const icon    = document.getElementById('icon-' + id);
        if (!content) return;
        const isHidden = content.classList.contains('hidden');
        document.querySelectorAll('[id^="afaq"]').forEach(el => el.classList.add('hidden'));
        document.querySelectorAll('[id^="icon-afaq"]').forEach(el => el.classList.remove('rotate-180'));
        if (isHidden) { content.classList.remove('hidden'); icon.classList.add('rotate-180'); }
    }
</script>

</body>
</html>
