<!DOCTYPE html>
<html lang="es" class="scroll-smooth">
<%- include('./partials/head') %>

<style>
    @keyframes scroll {
        0%   { transform: translateX(0); }
        100% { transform: translateX(-50%); }
    }
    .animate-scroll-infinite {
        animation: scroll 45s linear infinite;
    }
    .animate-scroll-infinite:hover {
        animation-play-state: paused;
    }
    #lightbox { transition: opacity 0.3s ease; }
    #lightbox.hidden { opacity: 0; pointer-events: none; }
    #lightbox:not(.hidden) { opacity: 1; pointer-events: auto; }
</style>

<body class="bg-white text-gray-600 antialiased font-sans">

<%- include('./partials/navbar') %>

<!-- ===== HERO ===== -->
<section class="relative pt-36 pb-24 bg-white overflow-hidden">

    <div class="absolute inset-0 pointer-events-none overflow-hidden">
        <div class="absolute top-0 left-1/4 w-[500px] h-[500px] rounded-full opacity-50 blur-[120px]" style="background:#61B4E415;"></div>
        <div class="absolute top-0 right-1/4 w-[500px] h-[500px] rounded-full opacity-50 blur-[100px]" style="background:#A0214010;"></div>
        <div class="absolute bottom-0 left-1/3 w-[400px] h-[400px] rounded-full opacity-40 blur-[80px]" style="background:#FFB81915;"></div>
        <div class="absolute inset-0 opacity-[0.025]" style="background-image: linear-gradient(#000 1px, transparent 1px), linear-gradient(90deg, #000 1px, transparent 1px); background-size: 60px 60px;"></div>
    </div>

    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10 text-center">

        <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-white border border-gray-200 shadow-sm mb-8 cursor-default hover:shadow-md transition-all" data-aos="fade-down">
            <span class="flex h-2 w-2 relative">
                <span class="animate-ping absolute inline-flex h-full w-full rounded-full opacity-75" style="background:#73A950;"></span>
                <span class="relative inline-flex rounded-full h-2 w-2" style="background:#73A950;"></span>
            </span>
            <span class="text-xs font-black tracking-widest text-gray-500 uppercase">Sumate a la familia</span>
        </div>

        <h1 class="text-5xl md:text-6xl lg:text-7xl font-black text-gray-900 mb-6 tracking-tight leading-[1.05]" data-aos="fade-up">
            Viví el modelo<br>
            <span class="text-transparent bg-clip-text bg-gradient-to-r from-brand-blue via-brand-green to-brand-yellow">
                desde el corazón.
            </span>
        </h1>

        <p class="text-lg md:text-xl text-gray-500 max-w-2xl mx-auto font-medium leading-relaxed mb-10" data-aos="fade-up" data-aos-delay="100">
            Ser autoridad es mucho más que moderar un debate. Es hacer amigos, compartir mates en los recreos y ser parte del equipo que hace magia para que todo salga bien.
        </p>

        <div class="flex flex-col sm:flex-row justify-center gap-4" data-aos="fade-up" data-aos-delay="200">
            <a href="<%= settings.link_autoridades_sumarme || '#' %>" target="_blank"
               class="px-9 py-4 text-white font-bold rounded-full hover:-translate-y-1 transition-all duration-300 text-center text-base"
               style="background:#A02140; box-shadow: 0 12px 30px -6px #A0214050;">
                Quiero sumarme
            </a>
            <a href="<%= settings.link_autoridades_fotos || '#legado' %>"
               class="px-9 py-4 bg-white border-2 border-gray-200 text-gray-600 font-bold rounded-full hover:border-gray-300 hover:shadow-md transition-all duration-300 text-center text-base">
                Ver fotos anteriores
            </a>
        </div>
    </div>
</section>

<!-- ===== EXPERIENCIA ===== -->
<section id="experiencia" class="py-24 bg-gray-50 border-t border-gray-100">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">

            <!-- Fotos mosaico -->
            <div class="grid grid-cols-2 gap-4" data-aos="fade-right">
                <div class="space-y-4 mt-10">
                    <div class="overflow-hidden rounded-2xl shadow-md">
                        <img src="<%= settings.auth_hero_1 || 'https://images.unsplash.com/photo-1529156069898-49953e39b3ac?q=80&w=800&fit=crop' %>"
                             class="lightbox-trigger w-full h-56 object-cover hover:scale-105 transition-transform duration-500 cursor-zoom-in"
                             alt="Amigos en el modelo">
                    </div>
                </div>
                <div class="space-y-4">
                    <div class="overflow-hidden rounded-2xl shadow-md">
                        <img src="<%= settings.auth_hero_2 || 'https://images.unsplash.com/photo-1511632765486-a01980e01a18?q=80&w=800&fit=crop' %>"
                             class="lightbox-trigger w-full h-72 object-cover hover:scale-105 transition-transform duration-500 cursor-zoom-in"
                             alt="Staff del modelo">
                    </div>
                </div>
            </div>

            <!-- Texto -->
            <div data-aos="fade-left">
                <span class="inline-block text-xs font-black uppercase tracking-widest mb-4 px-3 py-1.5 rounded-full" style="background:#EDF5E8; color:#73A950;">La experiencia</span>
                <h2 class="text-3xl md:text-5xl font-black text-gray-900 mb-6 leading-tight">
                    Un grupo de amigos<br>
                    <span style="color:#73A950;">trabajando juntos.</span>
                </h2>
                <p class="text-gray-500 text-lg mb-5 leading-relaxed">
                    Olvidate de la presión. Acá venimos a pasarla bien. El staff de autoridades es famoso por ser el grupo más unido del modelo.
                </p>
                <p class="text-gray-500 text-lg mb-8 leading-relaxed">
                    No importa si te toca ser Presidente, Ujier o Secretario — lo importante son las anécdotas que te llevás, las risas en las capacitaciones y la satisfacción de ayudar a que los delegados brillen.
                </p>

                <div class="space-y-3">
                    <% [
                        { icon: 'M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z', color: '#73A950', bg: '#EDF5E8', text: 'Sin competencia, pura colaboración.' },
                        { icon: 'M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z', color: '#61B4E4', bg: '#E8F5FB', text: 'Conocés gente de todos los colegios.' },
                        { icon: 'M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z', color: '#FFB819', bg: '#FEF6E0', text: 'Una experiencia que recordás toda la vida.' },
                    ].forEach(item => { %>
                    <div class="flex items-center gap-3">
                        <div class="w-9 h-9 rounded-xl flex items-center justify-center flex-shrink-0" style="background:<%= item.bg %>;">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" style="color:<%= item.color %>;">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="<%= item.icon %>"/>
                            </svg>
                        </div>
                        <span class="text-gray-700 font-semibold text-base"><%= item.text %></span>
                    </div>
                    <% }); %>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- ===== GALERÍA / LEGADO ===== -->
<section id="legado" class="py-24 bg-white border-t border-gray-100 overflow-hidden">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mb-14 text-center" data-aos="fade-up">
        <span class="text-xs font-black uppercase tracking-widest" style="color:#61B4E4;">Nuestra Historia</span>
        <h2 class="text-3xl md:text-4xl font-black text-gray-900 mt-3 mb-4">El Legado del Equipo</h2>
        <p class="text-gray-500 max-w-xl mx-auto text-lg">Miles de historias, un solo espíritu. Así disfrutaron las camadas anteriores.</p>
    </div>

    <div class="relative w-full">
        <!-- Fades laterales -->
        <div class="absolute left-0 top-0 bottom-0 w-24 z-10 pointer-events-none" style="background: linear-gradient(to right, white, transparent);"></div>
        <div class="absolute right-0 top-0 bottom-0 w-24 z-10 pointer-events-none" style="background: linear-gradient(to left, white, transparent);"></div>

        <div class="flex overflow-hidden w-full">
            <div class="flex animate-scroll-infinite gap-5" id="gallery-container">
                <%
                    const legacyKeys = Object.keys(settings).filter(k => k.startsWith('auth_legacy_') && settings[k]).sort();
                    const fallbackLegacy = [
                        '/img/autoridades/foto1.jpg',
                        '/img/autoridades/foto2.jpg',
                        '/img/autoridades/foto3.jpg',
                        '/img/autoridades/foto4.jpg',
                        '/img/autoridades/foto5.jpg'
                    ];
                    const legacyImages = legacyKeys.length > 0 ? legacyKeys.map(k => settings[k]) : fallbackLegacy;
                %>
                <% for (let i = 0; i < 2; i++) { %>
                    <% for (const imgSrc of legacyImages) { %>
                    <div class="flex-shrink-0 overflow-hidden rounded-2xl shadow-sm">
                        <img src="<%= imgSrc %>"
                             onerror="this.src='https://images.unsplash.com/photo-1523240795612-9a054b0db644?w=400&h=400&fit=crop'"
                             class="lightbox-trigger w-64 h-64 object-cover hover:scale-105 transition-transform duration-500 cursor-zoom-in"
                             alt="Legado">
                    </div>
                    <% } %>
                <% } %>
            </div>
        </div>
    </div>
</section>

<!-- ===== ROLES ===== -->
<section id="roles" class="py-24 bg-gray-50 border-t border-gray-100">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

        <div class="text-center mb-16" data-aos="fade-up">
            <span class="text-xs font-black uppercase tracking-widest text-gray-400 mb-3 block">Tu lugar en el equipo</span>
            <h2 class="text-3xl md:text-4xl font-black text-gray-900 mb-4">¿Desde dónde te gustaría participar?</h2>
            <p class="text-gray-500 max-w-2xl mx-auto text-lg">Todos estos roles forman parte del mismo equipo. En las capacitaciones veremos juntos cuál es el ideal para vos.</p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-5">

            <% [
                {
                    color: '#A02140', bg: '#F9E8EC',
                    title: 'Secretaría General',
                    desc: 'El corazón del modelo. Coordinan que todo funcione, apoyan a las demás autoridades y garantizan que todos la pasen bien.',
                    icon: 'M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4',
                    badge: null
                },
                {
                    color: '#61B4E4', bg: '#E8F5FB',
                    title: 'Presidencia',
                    desc: 'Quienes guían el debate. Se aseguran de que todos hablen, se respeten los turnos y el intercambio fluya con buena onda.',
                    icon: 'M3 6l3 1m0 0l-3 9a5.002 5.002 0 006.001 0M6 7l3 9M6 7l6-2m6 2l3-1m-3 1l-3 9a5.002 5.002 0 006.001 0M18 7l3 9m-3-9l-6-2m0-2v2m0 16V5m0 16H9m3 0h3',
                    badge: null
                },
                {
                    color: '#E15829', bg: '#FCEEE9',
                    title: 'Consejeros',
                    desc: 'Fundamentales en el Consejo de Seguridad. Ayudan a redactar las ideas y dan soporte técnico a los delegados.',
                    icon: 'M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z',
                    badge: null
                },
                {
                    color: '#73A950', bg: '#EDF5E8',
                    title: 'Ujieres',
                    desc: 'El alma de la sala. Llevan los mensajes y ayudan con la organización del espacio.',
                    icon: 'M12 19l9 2-9-18-9 18 9-2zm0 0v-8',
                    badge: 'Ideal para empezar'
                },
            ].forEach((rol, i) => { %>
            <div class="relative bg-white rounded-3xl p-8 border border-gray-100 hover:shadow-xl hover:-translate-y-2 transition-all duration-300 group overflow-hidden" data-aos="fade-up" data-aos-delay="<%= i * 80 %>">
                <% if (rol.badge) { %>
                <div class="absolute top-0 right-0 text-[10px] font-black uppercase tracking-wider px-3 py-1.5 rounded-bl-2xl" style="background:<%= rol.bg %>; color:<%= rol.color %>;">
                    <%= rol.badge %>
                </div>
                <% } %>
                <div class="w-12 h-12 rounded-2xl flex items-center justify-center mb-5 group-hover:scale-110 transition-transform duration-300" style="background:<%= rol.bg %>;">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" style="color:<%= rol.color %>;">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="<%= rol.icon %>"/>
                    </svg>
                </div>
                <h3 class="text-lg font-black text-gray-900 mb-3"><%= rol.title %></h3>
                <p class="text-sm text-gray-500 leading-relaxed"><%= rol.desc %></p>
                <% if (rol.title === 'Ujieres') { %>
                <div class="mt-5 p-3 rounded-xl border" style="background:<%= rol.bg %>20; border-color:<%= rol.color %>20;">
                    <p class="text-xs font-black" style="color:<%= rol.color %>;">¿Estás en 1º o 2º año?</p>
                    <p class="text-xs text-gray-400 mt-0.5">Podés participar aunque no estés en 3ro.</p>
                </div>
                <% } %>
            </div>
            <% }); %>

        </div>
    </div>
</section>

<!-- ===== CAPACITACIÓN ===== -->
<section class="py-24 bg-white border-t border-gray-100">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

        <div class="text-center mb-16 max-w-3xl mx-auto" data-aos="fade-up">
            <span class="inline-block px-4 py-1.5 rounded-full font-bold tracking-widest uppercase text-xs mb-5 border" style="background:#E8F5FB; color:#61B4E4; border-color:#61B4E430;">
                Formación y Metodología
            </span>
            <h2 class="text-3xl md:text-4xl font-black text-gray-900 mb-5 leading-tight">
                Aprendemos juntos,<br>a tu ritmo.
            </h2>
            <p class="text-gray-500 text-lg leading-relaxed">
                Nuestro sistema de capacitación está diseñado para que disfrutes aprendiendo. No importa si es tu primera vez — te acompañamos hasta que te sentís listo.
            </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-16">
            <% [
                { color: '#61B4E4', bg: '#E8F5FB', title: 'Encuentros Virtuales', desc: 'Clases teóricas por Zoom. Ideales para entender los conceptos básicos desde tu casa.', icon: 'M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z' },
                { color: '#E15829', bg: '#FCEEE9', title: 'Prácticas Presenciales', desc: 'Simulacros de debate. El momento de perder la vergüenza y conocer al equipo.', icon: 'M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z' },
                { color: '#73A950', bg: '#EDF5E8', title: 'Instancia Final', desc: 'Un pequeño examen para validar lo aprendido. Si participaste activamente, lo pasás seguro.', icon: 'M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4' },
            ].forEach((item, i) => { %>
            <div class="bg-white rounded-2xl p-7 text-center border border-gray-100 shadow-sm hover:shadow-lg transition-all duration-300 group" data-aos="fade-up" data-aos-delay="<%= i * 80 %>">
                <div class="w-14 h-14 mx-auto rounded-2xl flex items-center justify-center mb-5 group-hover:scale-110 transition-transform" style="background:<%= item.bg %>;">
                    <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24" style="color:<%= item.color %>;">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="<%= item.icon %>"/>
                    </svg>
                </div>
                <h3 class="font-black text-lg text-gray-900 mb-2"><%= item.title %></h3>
                <p class="text-sm text-gray-500 leading-relaxed"><%= item.desc %></p>
            </div>
            <% }); %>
        </div>

        <!-- Biblioteca Digital -->
        <div class="max-w-4xl mx-auto" data-aos="fade-up">
            <div class="flex items-center gap-4 mb-8">
                <div class="flex-1 h-px bg-gray-100"></div>
                <span class="text-sm font-black uppercase tracking-widest text-gray-300">Biblioteca Digital</span>
                <div class="flex-1 h-px bg-gray-100"></div>
            </div>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
                <a href="/documents/Capacitacion/Manual_Autoridades.pdf" download
                   class="group flex items-center gap-5 p-6 rounded-2xl bg-gray-50 border border-gray-100 hover:bg-white hover:shadow-xl transition-all duration-300" style="hover:border-color:#61B4E430;">
                    <div class="w-14 h-14 rounded-xl bg-white border border-gray-100 flex-shrink-0 flex items-center justify-center shadow-sm group-hover:scale-110 transition-transform" style="color:#61B4E4;">
                        <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/>
                        </svg>
                    </div>
                    <div>
                        <h4 class="text-base font-black text-gray-900 mb-1 group-hover:text-brand-blue transition-colors">Manual General</h4>
                        <p class="text-sm text-gray-400">Procedimiento parlamentario completo.</p>
                        <span class="inline-flex items-center gap-1 mt-2 text-xs font-bold uppercase tracking-wide" style="color:#61B4E4;">
                            Descargar
                            <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"/></svg>
                        </span>
                    </div>
                </a>
                <a href="/documents/Capacitacion/Protocolo_Ujieres.pdf" download
                   class="group flex items-center gap-5 p-6 rounded-2xl bg-gray-50 border border-gray-100 hover:bg-white hover:shadow-xl transition-all duration-300">
                    <div class="w-14 h-14 rounded-xl bg-white border border-gray-100 flex-shrink-0 flex items-center justify-center shadow-sm group-hover:scale-110 transition-transform" style="color:#73A950;">
                        <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
                        </svg>
                    </div>
                    <div>
                        <h4 class="text-base font-black text-gray-900 mb-1 group-hover:text-brand-green transition-colors">Guía de Logística</h4>
                        <p class="text-sm text-gray-400">Protocolo específico para Ujieres.</p>
                        <span class="inline-flex items-center gap-1 mt-2 text-xs font-bold uppercase tracking-wide" style="color:#73A950;">
                            Descargar
                            <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"/></svg>
                        </span>
                    </div>
                </a>
            </div>
        </div>
    </div>
</section>

<!-- ===== FAQ ===== -->
<section class="py-24 bg-gray-50 border-t border-gray-100">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">

        <div class="text-center mb-14" data-aos="fade-up">
            <span class="text-xs font-black uppercase tracking-widest text-gray-400 mb-3 block">Ayuda</span>
            <h2 class="text-3xl md:text-4xl font-black text-gray-900 mb-3">Preguntas Frecuentes</h2>
            <p class="text-gray-500 text-lg">Todo lo que necesitás saber antes de inscribirte.</p>
        </div>

        <div class="space-y-3" data-aos="fade-up">
            <% [
                { q: '¿Tengo que saber mucho para inscribirme?', a: '¡Para nada! Lo único que necesitás son ganas y compromiso. Nosotros te enseñamos todo el reglamento y los protocolos en las capacitaciones. Es un proceso de aprendizaje desde cero.' },
                { q: 'Si soy de 1er o 2do año, ¿puedo participar?', a: '¡Sí, por supuesto! El rol de Ujier está pensado especialmente para los primeros años. Es la mejor puerta de entrada para conocer el modelo desde adentro y prepararte para roles de presidencia en el futuro.' },
                { q: '¿Me ocupa mucho tiempo ser autoridad?', a: 'No te preocupes por el colegio. Las capacitaciones son pocas — usualmente 3 o 4 encuentros antes del modelo — y tratamos de hacerlas en horarios que no interrumpan tus clases. Eso sí, los días del Modelo son de asistencia completa.' },
                { q: '¿Me anoto solo o con amigos?', a: 'La inscripción al rol de autoridad es individual, ¡pero invitá a tus amigos! Aunque se anoten por separado, van a compartir todas las capacitaciones, los recreos y las fiestas juntos.' },
                { q: '¿Cómo tengo que ir vestido?', a: 'Durante el Modelo, la vestimenta es formal (traje, camisa, pantalón de vestir), igual que en las Naciones Unidas. Para las capacitaciones previas, podés ir con ropa casual o el uniforme del colegio.' },
                { q: '¿Recibo algún certificado?', a: '¡Sí! Al finalizar el modelo, se entrega un diploma oficial de participación certificado por Asociación Conciencia y Uniendo Metas, que sirve para tu currículum.' },
            ].forEach((item, i) => { %>
            <div class="bg-white rounded-2xl border border-gray-100 overflow-hidden shadow-sm hover:shadow-md transition-shadow duration-200">
                <button class="w-full px-6 py-5 text-left flex justify-between items-center gap-4 hover:bg-gray-50/50 transition-colors"
                        onclick="toggleFaq('afaq<%= i %>')">
                    <span class="font-bold text-gray-800 text-base leading-snug"><%= item.q %></span>
                    <svg id="icon-afaq<%= i %>" class="w-4 h-4 flex-shrink-0 transform transition-transform duration-300" style="color:#A02140;"
                         fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7"/>
                    </svg>
                </button>
                <div id="afaq<%= i %>" class="hidden px-6 pb-5 text-gray-500 text-sm leading-relaxed border-t border-gray-50 pt-4">
                    <%= item.a %>
                </div>
            </div>
            <% }); %>
        </div>

        <!-- CTA final -->
        <div class="mt-14 text-center" data-aos="fade-up">
            <p class="text-gray-500 mb-5 text-lg">¿Listo para sumarte?</p>
            <a href="<%= settings.link_autoridades_sumarme || '#' %>" target="_blank"
               class="inline-flex items-center gap-3 px-9 py-4 text-white font-bold rounded-full hover:scale-105 hover:brightness-110 transition-all duration-300 text-base"
               style="background:#A02140; box-shadow: 0 8px 24px -4px #A0214050;">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18 9v3m0 0v3m0-3h3m-3 0h-3m-2-5a4 4 0 11-8 0 4 4 0 018 0zM3 20a6 6 0 0112 0v1H3v-1z"/>
                </svg>
                Quiero ser autoridad
            </a>
        </div>

    </div>
</section>

<%- include('./partials/footer') %>

<!-- Lightbox -->
<div id="lightbox" class="fixed inset-0 z-[200] bg-black/90 hidden flex items-center justify-center p-4 backdrop-blur-sm" onclick="closeLightbox()">
    <button class="absolute top-5 right-5 text-white/70 hover:text-white p-2 rounded-full hover:bg-white/10 transition z-50" onclick="closeLightbox()">
        <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
    </button>
    <button id="lightbox-prev" class="absolute left-4 text-white/70 hover:text-white p-3 rounded-full hover:bg-white/10 transition z-50 hidden md:block">
        <svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
    </button>
    <img id="lightbox-img" src="" class="max-w-full max-h-[90vh] rounded-xl shadow-2xl transform transition-transform duration-300 scale-95" alt="Full screen">
    <button id="lightbox-next" class="absolute right-4 text-white/70 hover:text-white p-3 rounded-full hover:bg-white/10 transition z-50 hidden md:block">
        <svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
    </button>
</div>

<script src="https://unpkg.com/aos@2.3.1/dist/aos.js"></script>
<script>
    AOS.init({ once: true, offset: 50, duration: 700, easing: 'ease-out-quart' });

    // Lightbox
    const lightbox     = document.getElementById('lightbox');
    const lightboxImg  = document.getElementById('lightbox-img');
    const allImgs      = Array.from(document.querySelectorAll('.lightbox-trigger'));
    let currentIndex   = 0;

    allImgs.forEach((img, index) => {
        img.addEventListener('click', e => {
            e.stopPropagation();
            currentIndex = index;
            lightboxImg.src = allImgs[currentIndex].src;
            lightbox.classList.remove('hidden');
            setTimeout(() => lightboxImg.classList.replace('scale-95', 'scale-100'), 10);
        });
    });

    function closeLightbox() {
        lightboxImg.classList.replace('scale-100', 'scale-95');
        setTimeout(() => lightbox.classList.add('hidden'), 200);
    }

    function nextImage(e) { if (e) e.stopPropagation(); currentIndex = (currentIndex + 1) % allImgs.length; lightboxImg.src = allImgs[currentIndex].src; }
    function prevImage(e) { if (e) e.stopPropagation(); currentIndex = (currentIndex - 1 + allImgs.length) % allImgs.length; lightboxImg.src = allImgs[currentIndex].src; }

    document.getElementById('lightbox-next')?.addEventListener('click', nextImage);
    document.getElementById('lightbox-prev')?.addEventListener('click', prevImage);
    document.addEventListener('keydown', e => {
        if (!lightbox.classList.contains('hidden')) {
            if (e.key === 'Escape')     closeLightbox();
            if (e.key === 'ArrowRight') nextImage();
            if (e.key === 'ArrowLeft')  prevImage();
        }
    });

    // FAQ
    function toggleFaq(id) {
        const content = document.getElementById(id);
        const icon    = document.getElementById('icon-' + id);
        if (!content) return;
        const isHidden = content.classList.contains('hidden');
        document.querySelectorAll('[id^="afaq"]').forEach(el => el.classList.add('hidden'));
        document.querySelectorAll('[id^="icon-afaq"]').forEach(el => el.classList.remove('rotate-180'));
        if (isHidden) { content.classList.remove('hidden'); icon.classList.add('rotate-180'); }
    }
</script>

</body>
</html>
