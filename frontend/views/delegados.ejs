            </div>
            <% } else { %>
            <div class="text-center py-16 bg-white rounded-2xl border border-dashed border-gray-200">
                <svg class="w-10 h-10 text-gray-300 mx-auto mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                <p class="text-gray-400 font-semibold">Los videos de capacitación aparecerán aquí.</p>
                <p class="text-gray-400 text-sm mt-1">Se subiran proximamente.</p>
