<!DOCTYPE html>
<html lang="es" class="scroll-smooth">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Delegados | Uniendo Metas SDE</title>
    <%- include('./partials/head') %>
    <style>
        @keyframes scroll {
            0%   { transform: translateX(0); }
            100% { transform: translateX(-50%); }
        }
        .animate-scroll-infinite {
            animation: scroll 40s linear infinite;
        }
        .animate-scroll-infinite:hover {
            animation-play-state: paused;
        }
        #lightbox { transition: opacity 0.3s ease; }
        #lightbox.hidden { opacity: 0; pointer-events: none; }
        #lightbox:not(.hidden) { opacity: 1; pointer-events: auto; }

        /* Mapa interactivo */
        .world-map-container { position: relative; }
        .country-pin {
            position: absolute;
            width: 28px; height: 28px;
            border-radius: 50% 50% 50% 0;
            transform: rotate(-45deg) scale(0.9);
            cursor: pointer;
            transition: transform 0.2s ease, box-shadow 0.2s ease;
            box-shadow: 0 2px 8px rgba(0,0,0,0.2);
        }
        .country-pin:hover {
            transform: rotate(-45deg) scale(1.2);
            box-shadow: 0 6px 16px rgba(0,0,0,0.3);
        }
        .country-pin .flag-inner {
            position: absolute;
            inset: 4px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 11px;
            transform: rotate(45deg);
            background: white;
            overflow: hidden;
        }
        .map-tooltip {
            position: absolute;
            background: #1A365D;
            color: white;
            padding: 6px 12px;
            border-radius: 8px;
            font-size: 12px;
            font-weight: 700;
            white-space: nowrap;
            pointer-events: none;
            opacity: 0;
            transform: translateY(-4px);
            transition: opacity 0.2s ease, transform 0.2s ease;
            z-index: 100;
            bottom: 38px;
            left: 50%;
            transform: translateX(-50%) translateY(-4px);
        }
        .map-tooltip::after {
            content: '';
            position: absolute;
            top: 100%;
            left: 50%;
            transform: translateX(-50%);
            border: 5px solid transparent;
            border-top-color: #1A365D;
        }
        .country-pin:hover .map-tooltip {
            opacity: 1;
            transform: translateX(-50%) translateY(0);
        }

        /* Progreso habilidades */
        .skill-bar-fill {
            width: 0;
            transition: width 1.5s cubic-bezier(0.4, 0, 0.2, 1);
        }

        /* Recursos tab */
        .resource-tab.active { 
            background: #A02140; 
            color: white; 
            border-color: #A02140;
        }

        /* Strip colegios */
        @keyframes scroll-schools {
            0%   { transform: translateX(0); }
            100% { transform: translateX(-50%); }
        }
        .animate-schools {
            animation: scroll-schools 40s linear infinite;
        }
        .animate-schools:hover {
            animation-play-state: paused;
        }
    </style>
</head>

<%
const clean = (str) => {
    if (!str) return '';
    let cleaned = str.replace(/<\/p>\s*<p[^>]*>/gi, '<br><br>');
    cleaned = cleaned.replace(/<\/?p[^>]*>/gi, '');
    return cleaned;
};
%>

<body class="bg-white text-gray-600 antialiased font-sans overflow-x-hidden">

<%- include('./partials/navbar') %>

<!-- 1. Hero -->
<section class="relative pt-36 pb-24 bg-white overflow-hidden flex items-center">
    <div class="absolute inset-0 pointer-events-none overflow-hidden">
        <div class="absolute top-0 left-1/4 w-96 h-96 rounded-full opacity-50 blur-3xl" style="background:#61B4E415;"></div>
        <div class="absolute top-0 right-1/4 w-96 h-96 rounded-full opacity-40 blur-2xl" style="background:#1A365D10;"></div>
        <div class="absolute bottom-0 left-1/3 w-80 h-80 rounded-full opacity-40 blur-2xl" style="background:#FFB81915;"></div>
        <div class="absolute inset-0 opacity-[0.025]" style="background-image: linear-gradient(#000 1px, transparent 1px), linear-gradient(90deg, #000 1px, transparent 1px); background-size: 60px 60px;"></div>
    </div>

    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10 text-center mt-10">
        <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-white border border-gray-200 shadow-sm mb-8 cursor-default hover:shadow-md transition-all" data-aos="fade-down">
            <span class="flex h-2 w-2 relative">
                <span class="animate-ping absolute inline-flex h-full w-full rounded-full opacity-75" style="background:#61B4E4;"></span>
                <span class="relative inline-flex rounded-full h-2 w-2" style="background:#61B4E4;"></span>
            </span>
            <span class="text-xs font-black tracking-widest text-gray-500 uppercase"><%- clean(settings.text_del_badge || 'Programa Educativo') %></span>
        </div>

        <h1 class="text-5xl md:text-6xl lg:text-7xl font-black text-gray-900 mb-6 tracking-tight leading-[1.05]" data-aos="fade-up">
            <%- clean(settings.text_del_hero_title || 'Sé el protagonista<br>') %>
            <span class="text-transparent bg-clip-text bg-gradient-to-r from-brand-blue via-brand-green to-brand-yellow">
                <%- clean(settings.text_del_hero_highlight || 'de tu futuro.') %>
            </span>
        </h1>

        <p class="text-lg md:text-xl text-gray-500 max-w-2xl mx-auto font-medium leading-relaxed mb-10" data-aos="fade-up" data-aos-delay="100">
            <%- clean(settings.text_del_hero_desc || 'Participá como delegado en el Modelo de Naciones Unidas. Investigá, debatí y colaborá junto a jóvenes de toda la provincia en una experiencia que transforma.') %>
        </p>

        <div class="flex flex-col sm:flex-row justify-center gap-4" data-aos="fade-up" data-aos-delay="200">
            <a href="#que-es" class="px-9 py-4 bg-white border-2 border-gray-200 text-gray-600 font-bold rounded-full hover:border-gray-300 hover:shadow-md transition-all duration-300 text-center text-base">
                <%- clean(settings.text_del_cta_secondary || 'Conocé más') %>
            </a>
        </div>
    </div>
</section>

<!-- ═══════════════════════════════════════════════
     2. STRIP DE CONFIANZA — NUEVA SECCIÓN
     Logos de colegios / medios / instituciones aliadas
     ═══════════════════════════════════════════════ -->
<% if (settings.show_trust_strip !== 'false') { %>
<section class="py-10 bg-gray-50 border-y border-gray-100">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <p class="text-center text-xs font-black uppercase tracking-widest text-gray-300 mb-8">
            <%= settings.trust_strip_label || 'Colegios participantes' %>
        </p>
        <div class="relative w-full overflow-hidden">
            <div class="absolute left-0 top-0 bottom-0 w-16 z-10 pointer-events-none" style="background: linear-gradient(to right, #f9fafb, transparent);"></div>
            <div class="absolute right-0 top-0 bottom-0 w-16 z-10 pointer-events-none" style="background: linear-gradient(to left, #f9fafb, transparent);"></div>
            <div class="flex gap-12 animate-scroll-infinite items-center" id="trust-strip">
                <% const trustItems = [
                    settings.trust_1 || 'Colegio Nacional',
                    settings.trust_2 || 'Escuela Técnica',
                    settings.trust_3 || 'Instituto Superior',
                    settings.trust_4 || 'Colegio Privado',
                    settings.trust_5 || 'Bachillerato Municipal',
                    settings.trust_6 || 'Escuela Secundaria',
                ]; %>
                <% for (let j = 0; j < 2; j++) { %>
                    <% trustItems.forEach(t => { %>
                    <span class="text-sm font-black text-gray-300 tracking-wider uppercase whitespace-nowrap flex-shrink-0"><%= t %></span>
                    <% }); %>
                <% } %>
            </div>
        </div>
    </div>
</section>
<% } %>


<!-- 3. ¿Qué es un Delegado? -->
<section id="que-es" class="py-24 bg-white border-t border-gray-100">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-16" data-aos="fade-up">
            <span class="text-xs font-black uppercase tracking-widest text-gray-400 mb-3 block">El Rol</span>
            <h2 class="text-3xl md:text-4xl font-black text-gray-900 mb-4"><%- clean(settings.text_del_what_title || '¿Qué es un Delegado?') %></h2>
            <p class="text-gray-500 max-w-2xl mx-auto text-lg"><%- clean(settings.text_del_what_desc || 'Un delegado es un estudiante que asume el rol de un diplomático, representando los intereses, políticas y cultura de un país asignado ante los órganos de la ONU.') %></p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-5">
            <% const rolDefs = [
                { tKey: 'text_del_rol_1_title', dKey: 'text_del_rol_1_desc', defT: 'Representación', defD: 'Sos la voz de toda una nación. Investigás su historia, cultura e intereses para defenderlos en el debate.', color: '#61B4E4', icon: 'M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0110.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z' },
                { tKey: 'text_del_rol_2_title', dKey: 'text_del_rol_2_desc', defT: 'Oratoria', defD: 'Aprendés a expresarte con seguridad frente a otros. El 84% de los participantes se sintió más confiado para hablar en público.', color: '#E15829', icon: 'M19 11a7 7 0 01-7 7m0 0a7 7 0 01-7-7m7 7v4m0 0H8m4 0h4m-4-8a3 3 0 01-3-3V5a3 3 0 116 0v6a3 3 0 01-3 3z' },
                { tKey: 'text_del_rol_3_title', dKey: 'text_del_rol_3_desc', defT: 'Colaboración', defD: 'Trabajás junto a jóvenes de otras escuelas para construir propuestas colectivas. La diversidad de miradas enriquece el debate.', color: '#FFB819', icon: 'M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z' },
                { tKey: 'text_del_rol_4_title', dKey: 'text_del_rol_4_desc', defT: 'Pensamiento Crítico', defD: 'Analizás problemáticas globales reales desde distintas perspectivas, aprendiendo a buscar fuentes confiables y a argumentar con datos.', color: '#73A950', icon: 'M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z' }
            ]; %>

            <% rolDefs.forEach((rol, i) => {
                rol.title = settings[rol.tKey] || rol.defT;
                rol.desc = settings[rol.dKey] || rol.defD;
            %>
            <div class="relative bg-white rounded-3xl p-8 border border-gray-100 hover:shadow-xl hover:-translate-y-2 transition-all duration-300 group overflow-hidden" data-aos="fade-up" data-aos-delay="<%= i * 80 %>">
                <div class="w-12 h-12 rounded-2xl flex items-center justify-center mb-5 group-hover:scale-110 transition-transform duration-300" style="background:<%= rol.color %>15;">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" style="color:<%= rol.color %>;">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="<%= rol.icon %>"/>
                    </svg>
                </div>
                <h3 class="text-lg font-black text-gray-900 mb-3"><%- clean(rol.title) %></h3>
                <p class="text-sm text-gray-500 leading-relaxed"><%- clean(rol.desc) %></p>
            </div>
            <% }); %>
        </div>
    </div>
</section>

<!-- 4. Impacto real (stats del PDF Conciencia) -->
<section class="py-20 bg-gray-50 border-t border-gray-100">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-14" data-aos="fade-up">
            <span class="text-xs font-black uppercase tracking-widest mb-3 block" style="color:#1A365D;">Datos reales 2025</span>
            <h2 class="text-3xl md:text-4xl font-black text-gray-900 mb-3">Lo que dicen los que lo vivieron</h2>
            <p class="text-gray-500 max-w-xl mx-auto">Resultados del Informe 2025 elaborado por el Equipo de Investigación de Asociación Conciencia (EIAC).</p>
        </div>

        <div class="grid grid-cols-2 md:grid-cols-4 gap-5">
            <% const stats = [
                { num: '84%', label: 'Se sintió más confiado para hablar en público', color: '#61B4E4' },
                { num: '76,7%', label: 'Considera muy útil lo aprendido para su vida cotidiana', color: '#FFB819' },
                { num: '70%', label: 'Dice que UM los ayudó a definir su proyecto académico', color: '#E15829' },
                { num: '87,7%', label: 'Proyecta continuar estudios universitarios', color: '#73A950' }
            ]; %>
            <% stats.forEach((s, i) => { %>
            <div class="bg-white border border-gray-100 rounded-2xl p-7 text-center shadow-sm hover:shadow-md hover:-translate-y-1 transition-all duration-300" data-aos="fade-up" data-aos-delay="<%= i * 80 %>">
                <div class="text-4xl font-black mb-3" style="color:<%= s.color %>"><%= s.num %></div>
                <p class="text-gray-500 text-sm leading-snug"><%= s.label %></p>
            </div>
            <% }); %>
        </div>

        <p class="text-center text-gray-400 text-xs mt-8">Fuente: Encuesta a estudiantes 2025 — Asociación Conciencia (EIAC). N = 1.986 casos.</p>
    </div>
</section>

<!-- 5. Habilidades con barras de progreso -->
<section id="habilidades" class="py-24 bg-white border-t border-gray-100">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
            
            <div data-aos="fade-right">
                <span class="inline-block text-xs font-black uppercase tracking-widest mb-4 px-3 py-1.5 rounded-full" style="background:#E1582915; color:#E15829;"><%- clean(settings.text_del_skills_badge || 'Desarrollo Personal') %></span>
                <h2 class="text-3xl md:text-5xl font-black text-gray-900 mb-6 leading-tight">
                    <%- clean(settings.text_del_skills_title || 'Habilidades para<br>') %>
                    <span style="color:#E15829;"><%- clean(settings.text_del_skills_highlight || 'crear tu futuro.') %></span>
                </h2>
                <p class="text-gray-500 text-lg mb-8 leading-relaxed">
                    <%- clean(settings.text_del_skills_desc || 'Participar en Uniendo Metas es desarrollar herramientas que vas a usar en la universidad, en tu carrera profesional y en tu vida diaria. Son 2 días de experiencia que dejan huella.') %>
                </p>
                
                <!-- Barras de progreso animadas -->
                <div class="space-y-5" id="skill-bars">
                    <% const skillBars = [
                        { label: 'Oratoria y confianza para hablar en público', pct: 84, color: '#61B4E4' },
                        { label: 'Capacidad argumentativa', pct: 70, color: '#E15829' },
                        { label: 'Alfabetización mediática e informacional', pct: 71, color: '#FFB819' },
                        { label: 'Apertura a la diversidad de ideas', pct: 75, color: '#73A950' }
                    ]; %>
                    <% skillBars.forEach((bar, i) => { %>
                    <div data-aos="fade-up" data-aos-delay="<%= i * 60 %>">
                        <div class="flex justify-between mb-1.5">
                            <span class="text-sm font-bold text-gray-700"><%= bar.label %></span>
                            <span class="text-sm font-black" style="color:<%= bar.color %>"><%= bar.pct %>%</span>
                        </div>
                        <div class="w-full h-2.5 bg-gray-100 rounded-full overflow-hidden">
                            <div class="skill-bar-fill h-full rounded-full" style="background:<%= bar.color %>;" data-pct="<%= bar.pct %>"></div>
                        </div>
                    </div>
                    <% }); %>
                </div>
                <p class="text-xs text-gray-400 mt-4">Basado en encuesta de cierre 2025. Fuente: EIAC / Asociación Conciencia.</p>
            </div>

            <div class="grid grid-cols-2 gap-4" data-aos="fade-left">
                <div class="space-y-4 mt-10">
                    <div class="overflow-hidden rounded-2xl shadow-md border border-gray-100">
                        <img src="<%= settings.del_skills_img_1 || 'https://images.unsplash.com/photo-1544531586-fde5298cdd40?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80' %>" 
                             onerror="this.src='https://images.unsplash.com/photo-1544531586-fde5298cdd40?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80'"
                             class="lightbox-trigger w-full h-64 object-cover hover:scale-105 transition-transform duration-500 cursor-zoom-in" 
                             alt="Delegados debatiendo">
                    </div>
                    <!-- Badge stat -->
                    <div class="bg-gray-50 rounded-2xl p-5 border border-gray-100 text-center">
                        <div class="text-3xl font-black mb-1" style="color:#A02140;">2 días</div>
                        <p class="text-xs text-gray-500 font-semibold">De simulación intensa<br>en el encuentro local</p>
                    </div>
                </div>
                <div class="space-y-4">
                    <div class="overflow-hidden rounded-2xl shadow-md border border-gray-100">
                        <img src="<%= settings.del_skills_img_2 || 'https://images.unsplash.com/photo-1521737604893-d14cc237f11d?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80' %>" 
                             onerror="this.src='https://images.unsplash.com/photo-1521737604893-d14cc237f11d?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80'"
                             class="lightbox-trigger w-full h-80 object-cover hover:scale-105 transition-transform duration-500 cursor-zoom-in" 
                             alt="Negociación">
                    </div>
                    <div class="bg-gray-50 rounded-2xl p-5 border border-gray-100 text-center">
                        <div class="text-3xl font-black mb-1" style="color:#61B4E4;">532</div>
                        <p class="text-xs text-gray-500 font-semibold">Escuelas de todo el pais participaron<br>en la edición 2025</p>
                    </div>
                </div>
            </div>

        </div>
    </div>
</section>

<!-- ═══════════════════════════════════════════════
     5. TIMELINE MEJORADO — Camino del Delegado
     ═══════════════════════════════════════════════ -->
<section class="py-24 bg-white border-t border-gray-100">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-16 max-w-3xl mx-auto" data-aos="fade-up">
            <span class="inline-block px-4 py-1.5 rounded-full font-bold tracking-widest uppercase text-xs mb-5 border" style="background:#E8F5FB; color:#61B4E4; border-color:rgba(97, 180, 228, 0.3);">
                <%- clean(settings.text_del_path_badge || 'Metodología') %>
            </span>
            <h2 class="text-3xl md:text-4xl font-black text-gray-900 mb-5 leading-tight">
                <%- clean(settings.text_del_path_title || 'El camino<br>del Delegado') %>
            </h2>
            <p class="text-gray-500 text-lg leading-relaxed">
                <%- clean(settings.text_del_path_desc || 'Prepararse y participar en el modelo conlleva una serie de etapas secuenciales que te forman como un verdadero líder internacional.') %>
            </p>
        </div>

        <!-- Timeline vertical — NUEVO DISEÑO -->
        <div class="max-w-3xl mx-auto relative">
            <!-- Línea vertical -->
            <div class="absolute left-8 top-0 bottom-0 w-0.5 timeline-line hidden md:block" style="margin-left: -1px;"></div>

            <% const allSteps = [
                { num: '1', t: 'del_step_1_title', d: 'del_step_1_desc', deft: 'Investiga', defd: 'Aprende sobre la cultura, política y economía de la nación asignada para representarla fielmente.', color: '#61B4E4', icon: 'M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z' },
                { num: '2', t: 'del_step_2_title', d: 'del_step_2_desc', deft: 'Analiza', defd: 'Estudia profundamente los problemas globales a tratar en tu comisión, desde la perspectiva de tu país.', color: '#73A950', icon: 'M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z' },
                { num: '3', t: 'del_step_3_title', d: 'del_step_3_desc', deft: 'Redacta', defd: 'Elabora documentos de posición y colabora en proyectos de resolución con formalidad diplomática.', color: '#FFB819', icon: 'M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z' },
                { num: '4', t: 'del_step_4_title', d: 'del_step_4_desc', deft: 'Debate', defd: 'Utilizá la oratoria para exponer tus ideas, interpelar a otras delegaciones y defender tus posturas en el recinto.', color: '#E15829', icon: 'M19 11a7 7 0 01-7 7m0 0a7 7 0 01-7-7m7 7v4m0 0H8m4 0h4m-4-8a3 3 0 01-3-3V5a3 3 0 116 0v6a3 3 0 01-3 3z' },
                { num: '5', t: 'del_step_5_title', d: 'del_step_5_desc', deft: 'Consensa', defd: 'Negociá cediendo posiciones estratégicas para lograr soluciones integrales junto a otros bloques.', color: '#A02140', icon: 'M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z' }
            ]; %>

            <% allSteps.forEach((step, i) => {
                const title = settings[step.t] || step.deft;
                const desc = settings[step.d] || step.defd;
            %>
            <div class="flex gap-6 mb-8 relative" data-aos="fade-up" data-aos-delay="<%= i * 80 %>">
                <!-- Nodo -->
                <div class="flex-shrink-0 w-16 h-16 rounded-2xl flex items-center justify-center z-10 shadow-sm" style="background:<%= step.color %>15; border: 2px solid <%= step.color %>30;">
                    <svg class="w-6 h-6" fill="none" stroke="<%= step.color %>" viewBox="0 0 24 24" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="<%= step.icon %>"/>
                    </svg>
                </div>
                <!-- Contenido -->
                <div class="flex-1 bg-white rounded-2xl p-6 border border-gray-100 shadow-sm hover:shadow-md transition-shadow">
                    <div class="flex items-center gap-3 mb-2">
                        <span class="text-xs font-black uppercase tracking-widest" style="color:<%= step.color %>;">Paso <%= step.num %></span>
                    </div>
                    <h3 class="font-black text-xl text-gray-900 mb-2"><%- clean(title) %></h3>
                    <p class="text-sm text-gray-500 leading-relaxed"><%- clean(desc) %></p>
                </div>
            </div>
            <% }); %>
        </div>
    </div>
</section>


<!-- 7. CTA inscripción (Movido desde abajo) -->
<section class="py-24 bg-white border-t border-gray-100">
