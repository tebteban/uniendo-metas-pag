                            <svg class="w-3 h-3 group-hover:translate-x-0.5 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
                        </span>
                    </div>
                </a>
                <% }); %>
            </div>
            <% } else { %>
            <div class="text-center py-16 bg-white rounded-2xl border border-dashed border-gray-200">
                <svg class="w-10 h-10 text-gray-300 mx-auto mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M7 12l3-3 3 3 4-4M8 21l4-4 4 4M3 4h18M4 4h16v12a1 1 0 01-1 1H5a1 1 0 01-1-1V4z"/></svg>
                <p class="text-gray-400 font-semibold">Las presentaciones aparecerán aquí.</p>
                <p class="text-gray-400 text-sm mt-1">Se subiran proximamente.</p>
            </div>
            <% } %>
        </div>

        <!-- Panel Guías -->
        <div id="tab-guias" class="tab-panel hidden" data-aos="fade-up">
            <% const docKeys = Object.keys(settings).filter(k => k.startsWith('resource_doc_') && k.endsWith('_url') && settings[k]).sort(); %>
            <% if (docKeys.length > 0) { %>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <% docKeys.forEach(dKey => {
                    const id = dKey.replace('resource_doc_', '').replace('_url', '');
                    const url = settings[dKey];
                    const title = settings[`resource_doc_${id}_title`] || 'Documento';
                    const desc = settings[`resource_doc_${id}_desc`] || '';
                    const type = settings[`resource_doc_${id}_type`] || 'PDF';
                %>
                <a href="<%= url %>" target="_blank" rel="noopener" class="group bg-white rounded-2xl p-5 border border-gray-100 shadow-sm hover:shadow-md hover:-translate-y-0.5 transition-all flex items-center gap-4">
                    <div class="w-10 h-10 rounded-xl flex items-center justify-center flex-shrink-0 font-black text-xs" style="background:#61B4E415; color:#61B4E4;"><%= type %></div>
                    <div>
                        <h3 class="font-black text-gray-900 text-sm group-hover:text-blue-600 transition-colors"><%= title %></h3>
                        <% if (desc) { %><p class="text-xs text-gray-400 mt-0.5"><%= desc %></p><% } %>
