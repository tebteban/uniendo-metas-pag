            <% } %>
        </div>

        <!-- Panel Presentaciones -->
        <div id="tab-presentaciones" class="tab-panel hidden" data-aos="fade-up">
            <% const pptKeys = Object.keys(settings).filter(k => k.startsWith('resource_ppt_') && k.endsWith('_url') && settings[k]).sort(); %>
            <% if (pptKeys.length > 0) { %>
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
                <% pptKeys.forEach(pKey => {
                    const id = pKey.replace('resource_ppt_', '').replace('_url', '');
                    const url = settings[pKey];
                    const title = settings[`resource_ppt_${id}_title`] || 'Presentación';
                    const desc = settings[`resource_ppt_${id}_desc`] || '';
                %>
                <a href="<%= url %>" target="_blank" rel="noopener" class="group bg-white rounded-2xl p-6 border border-gray-100 shadow-sm hover:shadow-lg hover:-translate-y-1 transition-all flex items-start gap-4">
                    <div class="w-12 h-12 rounded-xl flex items-center justify-center flex-shrink-0" style="background:#E1582915;">
                        <svg class="w-6 h-6" style="color:#E15829;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 12l3-3 3 3 4-4M8 21l4-4 4 4M3 4h18M4 4h16v12a1 1 0 01-1 1H5a1 1 0 01-1-1V4z"/>
                        </svg>
                    </div>
                    <div class="flex-1 min-w-0">
                        <h3 class="font-black text-gray-900 group-hover:text-red-700 transition-colors"><%= title %></h3>
