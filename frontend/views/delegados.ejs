                %>
                <div class="bg-white rounded-2xl overflow-hidden border border-gray-100 shadow-sm hover:shadow-lg transition-all">
                    <div class="relative aspect-video bg-gray-100">
                        <iframe src="<%= embedUrl %>" class="w-full h-full" frameborder="0" allowfullscreen allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" loading="lazy"></iframe>
                    </div>
                    <div class="p-5">
                        <h3 class="font-black text-gray-900 mb-1"><%= title %></h3>
                        <% if (desc) { %><p class="text-sm text-gray-500"><%= desc %></p><% } %>
                    </div>
                </div>
