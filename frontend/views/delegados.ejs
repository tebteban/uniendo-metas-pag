                { tKey: 'text_del_test_2_name', qKey: 'text_del_test_2_quote', roleKey: 'text_del_test_2_role', defN: 'Tomás, 16 años', defQ: 'Me tocó un país con una ideología completamente distinta a la mía. Te abre la mente conocer otras culturas. Siento que mi conocimiento sobre el mundo se expandió muchísimo.', defR: 'Escuela privada, Santiago del Estero', color: '#FFB819' },
                { tKey: 'text_del_test_3_name', qKey: 'text_del_test_3_quote', roleKey: 'text_del_test_3_role', defN: 'Lucía, 15 años', defQ: 'Fue muy desafiante y con muchos nervios, pero me di cuenta de que soy capaz, y eso me enorgullece.', defR: 'Escuela privada, Bahía Blanca', color: '#A02140' }
